@page
@model App.Pages.EleUISamples.UsersModel

@{
    ViewData["Title"] = "用户列表";
}

@section body {
    <EleTable Title="用户列表" FormPage="UserForm" EnableBatch="true">
        <Toolbar>
            <Filters >
                <EleInput For="Item.Name" Label="账号" Width="200px"></EleInput>
                <EleInput For="Item.ChineseName" Label="中文名" Width="200px"></EleInput>
                <EleSelect For="Item.RoleName" Label="角色" Items="Model.RoleList" Clearable="true" Width="200px"></EleSelect>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit"   Icon="Edit" Tooltip="编辑"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="账号" Link="true" MinWidth="140"></EleColumn>
            <EleColumn For="Item.ChineseName" Label="中文名" MinWidth="140"></EleColumn>
            <EleColumn For="Item.RoleName" Label="角色" MinWidth="120"></EleColumn>
            <EleLinkColumn For="Item.Url" Label="主页" MinWidth="160" Text="打开"></EleLinkColumn>
            <EleColumn For="Item.Age" Label="年龄" Width="90"></EleColumn>
            <EleColumn For="Item.Score" Label="分数" Width="110"></EleColumn>
            <EleColumn For="Item.Birthday" Label="生日" Width="140" FormatString="yyyy-MM-dd"></EleColumn>
            <EleColumn For="Item.IsEnabled" Label="启用" Width="90"></EleColumn>
        </Columns>
    </EleTable>
}

@page
@{
    Layout = "_Layout";
    ViewData["Title"] = "分隔面板 Splitter";
}

@section body {
    <Grid id="app" class="h-full m-8" Cols="1" LargeCols="2" Gap="4" MaxWidth="max-w-none" Center="false" PaddingX="0" Overflow="AutoY">
        <EleLabel Label="EleSplitPanel 基础用法示例" Size="2xl" Bold="true" FillRow="true" />
        <EleSplitPanel Height="220px" Radius="8px" Border="1px solid #d1d5db">
            <PanelItem Size="220">
                <div class="flex h-full items-center justify-center bg-blue-100 text-blue-700">Left (220px)</div>
            </PanelItem>
            <PanelItem>
                <div class="flex h-full items-center justify-center bg-green-100 text-green-700">Right (Auto)</div>
            </PanelItem>
        </EleSplitPanel>

        <EleLabel Label="EleSplitPanel 基础用法示例" Size="2xl" Bold="true" FillRow="true" />
        <EleSplitPanel Layout="Vertical" Height="220px" Radius="8px">
            <PanelItem Size="100">
                <div class="flex h-full items-center justify-center bg-yellow-100 text-yellow-700">Top (100px)</div>
            </PanelItem>
            <PanelItem>
                <div class="flex h-full items-center justify-center bg-red-100 text-red-700">Bottom (Auto)</div>
            </PanelItem>
        </EleSplitPanel>

        <EleLabel Label="可折叠 (Collapsible)" Size="2xl" Bold="true" FillRow="true" />
        <EleSplitPanel Height="240px">
            <PanelItem Size="220" Min="0" Collapsible="true">
                <div class="flex h-full items-center justify-center bg-purple-100 text-purple-700">Collapsible Left</div>
            </PanelItem>
            <PanelItem>
                <div class="flex h-full items-center justify-center bg-gray-100 text-gray-700">Right</div>
            </PanelItem>
        </EleSplitPanel>

        <EleLabel Label="嵌套 (Nested)" Size="2xl" Bold="true" FillRow="true" />
        <EleSplitPanel Height="240px" Direction="Vertical">
            <PanelItem Size="100" Collapsible="true">
                <div class="flex h-full items-center justify-center bg-pink-100 text-slate-700">Header</div>
            </PanelItem>
            <PanelItem Size="220" Min="0" Collapsible="false">
                <EleSplitPanel Direction="Horizontal">
                    <PanelItem Size="220" Min="140" Max="280" Collapsible="true">
                        <div class="flex h-full items-center justify-center bg-blue-50 text-blue-700">Sidebar</div>
                    </PanelItem>
                    <PanelItem>
                        <div class="flex h-full items-center justify-center bg-gray-50 text-gray-700">Main Content</div>
                    </PanelItem>
                </EleSplitPanel>
            </PanelItem>
        </EleSplitPanel>
    </Grid>
    <EleApp />
}

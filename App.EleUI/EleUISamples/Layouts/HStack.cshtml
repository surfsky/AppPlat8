@page
@{
    Layout = "_Layout";
    ViewData["Title"] = "HStack 布局";
}

@section body {
    <div class="p-4 space-y-6" id="app">
        <EleCard Title="HStack 基础" class="shadow-sm">
            <HStack>
                <EleButton Type="Primary" BorderColor="blue-500">Primary</EleButton>
                <EleButton Type="Success" BorderColor="blue-500">Success</EleButton>
                <EleButton Type="Warning" BorderColor="blue-500">Warning</EleButton>
                <EleButton Type="Danger" BorderColor="blue-500">Danger</EleButton>
            </HStack>
        </EleCard>

        <EleCard Title="对齐与分布" class="shadow-sm">
            <VStack Gap="4">
                <HStack Items="center" Gap="4" Rounded="lg" Border="true" BorderColor="slate-200" Bg="slate-50" P="4">
                    <EleButton>操作一</EleButton>
                    <EleButton>操作二</EleButton>
                    <EleButton>操作二</EleButton>
                </HStack>

                <HStack Justify="between" Items="center" Rounded="lg" Border="true" BorderColor="slate-200" Bg="white" P="4">
                    <span class="font-medium text-slate-700">justify-between</span>
                    <HStack>
                        <EleButton Type="Info">详情</EleButton>
                        <EleButton Type="Primary">编辑</EleButton>
                    </HStack>
                </HStack>
            </VStack>
        </EleCard>

        <EleCard Title="和 Column 组合" class="shadow-sm">
            <HStack Gap="4">
                <VStack MinW="[220px]" Rounded="lg" Border="true" BorderColor="blue-100" Bg="blue-50" P="4" Gap="2">
                    <h3 class="font-semibold text-blue-700">左侧信息</h3>
                    <p class="text-sm text-blue-600">EleRow + EleColumn 可以快速搭建面板式布局。</p>
                </VStack>
                <VStack Grow="true" Rounded="lg" Border="true" BorderColor="emerald-100" Bg="emerald-50" P="4" Gap="2">
                    <h3 class="font-semibold text-emerald-700">右侧内容</h3>
                    <p class="text-sm text-emerald-600">设置 Grow=true 后会自动填充剩余空间。</p>
                </VStack>
            </HStack>
        </EleCard>
    </div>

    <EleApp />
}

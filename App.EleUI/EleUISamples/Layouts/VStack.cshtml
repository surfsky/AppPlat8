@page
@{
    Layout = "_Layout";
    ViewData["Title"] = "VStack 布局";
}

@section body {
    <div class="p-4 space-y-6 overflow-y-auto w-full h-full">
        <EleCard Title="VStack 基础" class="shadow-sm">
            <VStack Gap="3" class="rounded-lg border border-slate-200 bg-slate-50 p-4">
                <div class="rounded-md bg-white p-3 text-slate-700">第一行内容</div>
                <div class="rounded-md bg-white p-3 text-slate-700">第二行内容</div>
                <div class="rounded-md bg-white p-3 text-slate-700">第三行内容</div>
            </VStack>
        </EleCard>

        <EleCard Title="纵向对齐" class="shadow-sm">
            <HStack Gap="4">
                <VStack Items="start" Gap="2" class="h-[220px] w-full rounded-lg border border-indigo-100 bg-indigo-50 p-4">
                    <span class="font-semibold text-indigo-700">items-start</span>
                    <EleButton Type="Primary">按钮</EleButton>
                </VStack>

                <VStack Items="center" Gap="2" class="h-[220px] w-full rounded-lg border border-cyan-100 bg-cyan-50 p-4">
                    <span class="font-semibold text-cyan-700">items-center</span>
                    <EleButton Type="Success">按钮</EleButton>
                </VStack>

                <VStack Items="end" Gap="2" class="h-[220px] w-full rounded-lg border border-rose-100 bg-rose-50 p-4">
                    <span class="font-semibold text-rose-700">items-end</span>
                    <EleButton Type="Danger">按钮</EleButton>
                </VStack>
            </HStack>
        </EleCard>

        <EleCard Title="反向排列" class="shadow-sm">
            <VStack Reverse="true" Gap="2" class="rounded-lg border border-amber-100 bg-amber-50 p-4">
                <div class="rounded-md bg-white p-3 text-slate-700">A</div>
                <div class="rounded-md bg-white p-3 text-slate-700">B</div>
                <div class="rounded-md bg-white p-3 text-slate-700">C</div>
            </VStack>
        </EleCard>

        <!-- 固定在页面底部的 AppBar -->
        <HStack class="fixed bottom-0 left-0 w-full bg-white border-t border-slate-200 shadow-sm p-4 justify-center">
            <EleButton Look="Circle" Icon="Edit"    Type="Primary"></EleButton>
            <EleButton Look="Circle" Icon="Check"   Type="Success"></EleButton>
            <EleButton Look="Circle" Icon="Message" Type="Danger"></EleButton>
            <EleButton Look="Circle" Icon="Star"    Type="Info"></EleButton>
        </HStack>
    </div>

    <EleApp />
}

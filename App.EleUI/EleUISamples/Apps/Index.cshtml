@page
@{
    ViewData["Title"] = "Application Mobile";
}

@section body {
<div id="app" class="h-full w-full bg-slate-100 flex items-center justify-center p-3 md:p-6">
    <div class="relative w-full max-w-[430px] h-full max-h-[900px] rounded-[28px] border border-slate-200 bg-white shadow-xl overflow-hidden">
        <div class="h-full pb-16 bg-slate-50">
            <iframe :src="tabUrlMap[activeTab]" class="w-full h-full border-0" frameborder="0"></iframe>
        </div>

        <nav class="absolute left-0 right-0 bottom-0 h-16 border-t border-slate-200 bg-white grid grid-cols-3">
            <button type="button" class="flex flex-col items-center justify-center gap-1 text-xs transition-colors"
                    :class="activeTab === 'home' ? 'text-blue-600' : 'text-slate-500'" @@click="switchTab('home')">
                <el-icon><House /></el-icon>
                <span>Home</span>
            </button>
            <button type="button" class="flex flex-col items-center justify-center gap-1 text-xs transition-colors"
                    :class="activeTab === 'list' ? 'text-blue-600' : 'text-slate-500'" @@click="switchTab('list')">
                <el-icon><List /></el-icon>
                <span>List</span>
            </button>
            <button type="button" class="flex flex-col items-center justify-center gap-1 text-xs transition-colors"
                    :class="activeTab === 'about' ? 'text-blue-600' : 'text-slate-500'" @@click="switchTab('about')">
                <el-icon><User /></el-icon>
                <span>About</span>
            </button>
        </nav>
    </div>
</div>
}

@section script {
    <script>
        const { ref } = Vue;

        window.model = {
            activeTab: ref('home'),
            tabUrlMap: {
                home: '/EleUISamples/Apps/Home',
                list: '/EleUISamples/Apps/List',
                about: '/EleUISamples/Apps/About'
            },
            switchTab(tab) {
                this.activeTab = tab;
            }
        };
    </script>

    <EleApp />
}

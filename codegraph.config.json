{
  "exclude": [
    "**/node_modules/**",
    "**/.git/**",
    "**/bin/**",
    "**/obj/**",
    "**/dist/**",
    "**/.vs/**",
    "**/.vscode/**",
    "**/.codegraph/**",
    "**/wwwroot/lib/**"
  ],
  "include": [
    "**/*.cs",
    "**/*.js",
    "**/*.ts",
    "**/*.vue",
    "**/*.cshtml",
    "**/*.html",
    "**/*.json"
  ],
  "watcher": {
    "enabled": true,
    "ignored": [
      "**/node_modules/**",
      "**/.git/**",
      "**/bin/**",
      "**/obj/**"
    ]
  }
}

@page
@using Newtonsoft.Json
@model App.Pages.Admins.OrgFormModel
@{
    ViewData["Title"] = "组织表单";
}

@section body {
    <EleForm LabelWidth="100px">
        <EleInput For="Item.Name" Label="名称" Required="true"></EleInput>
        <EleTreeSelect For="Item.ParentId" Label="上级组织" Api="/httpapi/orgs/GetAuthOrgTree"  Clearable="true" CheckStrictly="true"></EleTreeSelect>
        <EleNumber For="Item.SortId" Label="排序" Min="0" Max="1000"></EleNumber>
        <EleInput For="Item.Remark" Label="备注" Rows="3"></EleInput>
    </EleForm>
}

@page
@model App.Pages.Admins.UserPasswordFormModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "修改密码";
}

@section body {
    <EleForm LabelWidth="100px">
        <EleLabel For="Id" Label="Id"></EleLabel>
        <EleInput For="Name" Label="账号" ReadOnly="true"></EleInput>
        <EleInput For="Password" Label="新密码" Type="Password" Required="true" ShowPassword="true"></EleInput>
    </EleForm>
}

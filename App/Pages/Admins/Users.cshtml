@page
@using Newtonsoft.Json
@model App.Pages.Admins.UsersModel
@{
    ViewData["Title"] = "用户管理";
}


@section body {
    <EleTable Title="用户" FormPage="UserForm" EnableBatch="false" >
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Label="账号" Width="260px"></EleInput>
                <EleInput For="Item.RealName" Label="姓名" Width="260px"></EleInput>
                <EleTreeSelect For="Item.OrgId" Label="部门" Api="/httpapi/orgs/GetAuthOrgTree" Clearable="true" Width="280px"></EleTreeSelect>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
                <EleButton Type="Info" Click="navigateTo('/Admins/Orgs')" IconCls="fas fa-sitemap">组织管理</EleButton>
                <EleButton Type="Success" Command="Export" Icon="Download">导出</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.UserEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.UserDelete)"></Op>
            </EleOpColumn>
            <EleImageColumn For="Item.Photo" Label="头像" Width="60" Sortable="false"></EleImageColumn>
            <EleColumn For="Item.Name" Label="账号" Link="true" MinWidth="120" Sortable="true"></EleColumn>
            <EleColumn For="Item.RealName" Label="姓名" Width="120" Sortable="true"></EleColumn>
            <EleColumn For="Item.Org.Name" Label="部门" Width="150" Prop="orgName"></EleColumn>
            <EleColumn For="Item.Title" Label="职务" Width="120"></EleColumn>
            <EleColumn For="Item.InUsed" Label="启用" Width="80" ></EleColumn>
            <EleColumn For="Item.Gender" Label="性别" Width="60"></EleColumn>
            <EleColumn For="Item.Email" Label="邮箱" Width="180"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="200" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}


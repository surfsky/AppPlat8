@page
@model App.Pages.Admins.RolesModel
@{
    ViewData["Title"] = "角色管理";
}

@section body {
    <EleTable Title="角色" FormPage="RoleForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Label="名称" Width="200px"></EleInput>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
                <EleButton Type="Info" Click="navigateTo('/Admins/RolePower')" Icon="Key">权限设置</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.RoleEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.RoleDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="120" Sortable="true"></EleColumn>
            <EleColumn For="Item.Remark" Label="备注"></EleColumn>
        </Columns>
    </EleTable>
}

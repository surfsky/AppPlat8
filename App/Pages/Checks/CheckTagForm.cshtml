@page
@using Newtonsoft.Json
@model App.Pages.Checks.CheckTagFormModel
@{
    ViewData["Title"] = "菜单表单";
    var currentId = Request.Query["id"].ToString();
    var selectedId = Request.Query["selectId"].ToString();
}

@section body {
    <EleForm LabelWidth="100px">
        <EleInput For="Item.Name" Label="名称" Required="true"></EleInput>
        <EleTreeSelect For="Item.ParentId" Label="上级" Api="/httpapi/checks/GetCheckTagTree?excludeId=@currentId&selectedId=@selectedId"></EleTreeSelect>
        <EleTreeSelect For="Item.OrgId" Label="组织" Api="/httpapi/orgs/GetAuthOrgTree" ></EleTreeSelect>
        <EleNumber For="Item.SortId" Label="排序" Min="0" Max="1000"></EleNumber>
    
        <Bottom>
            <EleButton Type="Primary" Command="SaveClose" Visible="@(Model.Mode != PageMode.View)">保存</EleButton>
            <EleButton Type="Primary" Command="SaveNew" Visible="@(Model.Mode != PageMode.View)">保存并新增</EleButton>
            <EleButton Command="Close">关闭</EleButton>
        </Bottom>
    </EleForm>
}
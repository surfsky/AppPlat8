@page
@model App.Pages.Checks.CheckPointsModel
@{
    ViewData["Title"] = "风险点管理";
    var objectNameEncoded = System.Net.WebUtility.UrlEncode(Model.ObjectName ?? string.Empty);
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="风险点" FormPage="CheckPointForm?objectId=@Model.ObjectId&objectName=@objectNameEncoded" EnableBatch="true" DataHandler="?handler=Data&objectId=@Model.ObjectId" DeleteHandler="?handler=Delete&objectId=@Model.ObjectId">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Width="240px" Label="风险点名称"></EleInput>
                <EleSelect For="Item.RiskLevel" Width="220px" Label="风险等级" Clearable="true"></EleSelect>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" PopupUrl="CheckPointForm?objectId=@Model.ObjectId&objectName=@objectNameEncoded" Icon="Plus" Visible="Model.Mode == PageMode.Edit">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="@Auth.CheckPower(Power.CheckPointEdit)">删除</EleButton>
                <EleButton Type="Warning" Icon="Upload" Handler="Import" Visible="@Auth.CheckPower(Power.CheckPointEdit)">导入</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit"   Icon="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.CheckObjectEdit)"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.CheckObjectEdit)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="风险点名称" Width="200" Sortable="true"></EleColumn>
            <EleColumn For="Item.RiskLevel" Label="风险等级" Width="110"></EleColumn>
            <EleColumn For="Item.Gps" Label="坐标" Width="200"></EleColumn>
            <EleImageColumn For="Item.Picture" Label="图片" Width="100"></EleImageColumn>
            <EleColumn For="Item.CheckObjectName" Label="所属对象" MinWidth="150"></EleColumn>
        </Columns>
    </EleTable>
}

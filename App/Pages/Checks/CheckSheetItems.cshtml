@page
@model App.Pages.Checks.CheckSheetItemsModel
@{
    ViewData["Title"] = "检查项管理";
    var sheetNameEncoded = System.Net.WebUtility.UrlEncode(Model.SheetName ?? string.Empty);
}

@section body {
    <EleTable Title="检查项" FormPage="CheckSheetItemForm?sheetId=@Model.SheetId&sheetName=@sheetNameEncoded" EnableBatch="true" DataHandler="?handler=Data&sheetId=@Model.SheetId" DeleteHandler="?handler=Delete&sheetId=@Model.SheetId">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Width="250px" Label="名称"></EleInput>
                <EleSelect For="Item.RiskLevel" Width="220px" Label="层级" Clearable="true"></EleSelect>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" PopupUrl="CheckSheetItemForm?sheetId=@Model.SheetId&sheetName=@sheetNameEncoded" Icon="Plus" Visible="Model.Mode == PageMode.Edit">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="Model.Mode == PageMode.Edit">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.CheckSheetEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.CheckSheetEdit)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" MinWidth="180" Sortable="true"></EleColumn>
            <EleColumn For="Item.RiskLevel" Label="层级" Width="120"></EleColumn>
            <EleColumn For="Item.SortId" Label="排序" Width="100"></EleColumn>
        </Columns>
    </EleTable>
}

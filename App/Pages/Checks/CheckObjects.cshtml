@page
@model App.Pages.Checks.CheckObjectsModel
@{
    ViewData["Title"] = "检查对象管理";
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="检查对象" FormPage="CheckObjectForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Width="250px" Label="检查对象名称" ></EleInput>
                <EleSelect For="Item.ObjectType" Width="250px" Label="类型" Clearable="true"></EleSelect>
                <EleSelect For="Item.Scope" Width="250px" Label="所属领域" Clearable="true"></EleSelect>
                <EleSelect For="Item.IsDel" Width="250px" Label="已删除"  Clearable="true"></EleSelect>
                <EleSelect For="Item.IsChecked" Width="250px" Label="是否检查" Clearable="true"></EleSelect>
                <EleTreeSelect For="Item.DutyOrgId" Width="250px" Label="所属网格" Api="/httpapi/orgs/GetAuthOrgTree" Clearable="true"></EleTreeSelect>
                <EleInput For="Item.Address" Width="250px" Label="详细地址" ></EleInput>
                <EleSelect For="Item.HasHarzard" Width="250px" Label="存在隐患" Clearable="true"></EleSelect>
                <EleInput For="Item.SocialCreditCode" Width="250px" Label="统一社会信用代码" ></EleInput>
                <EleSelect For="Item.RiskLevel" Width="250px" Label="风险等级" Clearable="true"></EleSelect>
                <EleInput For="Item.Code" Width="250px" Label="对象标识" ></EleInput>
                <EleSelect For="Item.IndustryType" Width="250px" Label="行业" Clearable="true"></EleSelect>
                <EleInput For="Item.DutyUserName" Width="250px" Label="责任人" ></EleInput>
                <EleDatePicker Prop="createStartDt" Width="250px" Label="创建时间起" Type="DateTime" ></EleDatePicker>
                <EleDatePicker Prop="createEndDt" Width="250px" Label="创建时间止" Type="DateTime" ></EleDatePicker>
                <EleDatePicker Prop="latestCheckStartDt" Width="250px" Label="巡查时间起" Type="DateTime" ></EleDatePicker>
                <EleDatePicker Prop="latestCheckEndDt" Width="250px" Label="巡查时间止" Type="DateTime" ></EleDatePicker>
                <EleSelect For="Item.IndustryRisk" Width="250px" Label="行业风险类型" Clearable="true"></EleSelect>

                <EleTreePicker For="Item.TagIds" Label="标签" Api="/httpapi/checks/GetCheckTagTree" Multiple="true" CollapseTags="false" FillRow="true" Clearable="true"></EleTreePicker>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus" Visible="@Auth.CheckPower(Power.CheckObjectNew)">新增</EleButton>
                <EleButton Type="Warning" Icon="Upload" Handler="Import" Visible="@Auth.CheckPower(Power.CheckObjectEdit)">导入</EleButton>
                <EleButton Type="Primary" Command="Export" Icon="Download" Visible="@Auth.CheckPower(Power.CheckObjectView)">导出</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="@Auth.CheckPower(Power.CheckObjectDelete)">删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit"   Icon="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.CheckObjectEdit)"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.CheckObjectDelete)"></Op>
                <Op Popup="/Checks/ObjectContacts?objectId={id}&objectName={name}"   Icon="User" Text="联系人" Visible="@Auth.CheckPower(Power.CheckObjectView)"></Op>
                <Op Popup="/Shared/Atts?uniId=CheckObject-{id}&name={name}"   Icon="Paperclip" Text="附件" Visible="@Auth.CheckPower(Power.CheckObjectView)"></Op>
                <Op Popup="/Checks/CheckHazards?objectId={id}&objectName={name}"   Icon="WarningFilled" Text="隐患" Visible="@Auth.CheckPower(Power.CheckHazardView)"></Op>
                <Op Popup="/Checks/Checks?objectId={id}&objectName={name}"   Icon="DocumentChecked" Text="排查" Visible="@Auth.CheckPower(Power.CheckView)"></Op>
                <Op Popup="/Checks/CheckPoints?objectId={id}&objectName={name}"   Icon="DocumentChecked" Text="风险点" Visible="@Auth.CheckPower(Power.CheckObjectView)"></Op>
                <Op Popup="/Checks/CheckObjectEvents?objectId={id}&objectName={name}"   Icon="DocumentChecked" Text="事件" Visible="@Auth.CheckPower(Power.CheckObjectView)"></Op>
                <Op Popup="/Checks/CheckFlow?objectId={id}&objectName={name}"   Icon="DocumentChecked" Text="开始排查" Visible="@Auth.CheckPower(Power.CheckNew)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Id" Label="Id" Link="true" Width="60" Sortable="true"></EleColumn>
            <EleColumn For="Item.Code" Label="编码" Width="120" Sortable="true"></EleColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="250" Sortable="true"></EleColumn>
            <EleColumn For="Item.ObjectType" Label="类型" Width="100" Format="Enum"></EleColumn>
            <EleColumn For="Item.IndustryType" Label="行业" Width="110" Format="Enum"></EleColumn>
            <EleColumn For="Item.DutyOrgName" Label="责任组织" Width="200"></EleColumn>
            <EleColumn For="Item.SocialCreditCode" Label="社会信用代码" Width="180"></EleColumn>
            <EleColumn For="Item.DutyUserName" Label="负责人" Width="120"></EleColumn>
            <EleColumn For="Item.RiskLevel" Label="风险等级" Width="100"></EleColumn>
            <EleColumn For="Item.Scope" Label="领域" Width="100"></EleColumn>
            <EleColumn For="Item.Scale" Label="规模" Width="100"></EleColumn>
            <EleColumn For="Item.ObjectType" Label="对象类型" Width="100"></EleColumn>
            <EleColumn For="Item.Address" Label="地址" Width="200"></EleColumn>
            <EleColumn For="Item.BuildingType" Label="建筑类型" Width="100" Format="Enum"></EleColumn>
            <EleColumn For="Item.HasHarzard" Label="存在隐患" Width="100" Format="Switch"></EleColumn>
            <EleColumn For="Item.IsDel" Label="是否失效" Width="100" Format="Switch"></EleColumn>
            <EleColumn For="Item.FailReason" Label="失效原因" Width="180"></EleColumn>
            <EleColumn For="Item.CheckerName" Label="检查人" Width="120"></EleColumn>
            <EleColumn For="Item.SocialCheckerName" Label="网格员" Width="120"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="建档日期" Width="110" FormatString="yyyy-MM-dd"></EleColumn>
            <EleColumn For="Item.LatestCheckDt" Label="最新巡查时间" Width="150" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
            <EleColumn For="Item.TagNames" Label="标签列表" MinWidth="220"></EleColumn>
        </Columns>
    </EleTable>
}

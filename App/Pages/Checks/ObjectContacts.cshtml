@page
@model App.Pages.Checks.ObjectContactsModel
@{
    ViewData["Title"] = "对象联系人管理";
    var objectNameEncoded = System.Net.WebUtility.UrlEncode(Model.ObjectName ?? string.Empty);
}

@section body {
    <EleTable Title="对象联系人" FormPage="ObjectContactForm?objectId=@Model.ObjectId&objectName=@objectNameEncoded" EnableBatch="true" DataHandler="?handler=Data&objectId=@Model.ObjectId" DeleteHandler="?handler=Delete&objectId=@Model.ObjectId">
        <Toolbar>
            <Filters>
            <EleInput For="Item.Name" Width="220px" Label="姓名"></EleInput>
            <EleInput For="Item.Phone" Width="220px" Label="联系方式"></EleInput>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" PopupUrl="ObjectContactForm?objectId=@Model.ObjectId&objectName=@objectNameEncoded" Icon="Plus" Visible="Model.Mode == PageMode.Edit">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="Model.Mode == PageMode.Edit">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Handler="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.CheckObjectEdit)"></Op>
                <Op Handler="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.CheckObjectEdit)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="姓名" Width="140" Sortable="true"></EleColumn>
            <EleColumn For="Item.Phone" Label="联系方式" Width="150"></EleColumn>
            <EleColumn For="Item.IdCard" Label="证件号" Width="210"></EleColumn>
            <EleColumn For="Item.CertDt" Label="执证日期" Width="130" Format="Date"></EleColumn>
            <EleColumn For="Item.CertExpireDt" Label="过期日期" Width="130" Format="Date"></EleColumn>
        </Columns>
    </EleTable>
}

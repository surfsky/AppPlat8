@page
@model App.Pages.Checks.CheckTasksModel
@{
    ViewData["Title"] = "检查任务管理";
}

@section body {
    <EleTable Title="检查任务" FormPage="CheckTaskForm" EnableBatch="true" >
        <Toolbar>
            <EleInput For="Item.Name" Width="250px" Label="名称" ></EleInput>
            <EleDatePicker For="Item.ExpireDt" Width="250px"Label="截止时间" ></EleDatePicker>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn UPower="CheckTaskEdit" DPower="CheckTaskDelete" Width="100" Fixed="right"></EleOpColumn>
            <EleColumn For="Item.Name" Label="任务名称" Link="true" MinWidth="150"></EleColumn>
            <EleColumn For="Item.Publisher.Name" Label="发布人" Width="120"></EleColumn>
            <EleColumn For="Item.ExpireDt" Label="截止时间" Width="120" FormatString="yyyy-MM-dd"></EleColumn>
            <EleColumn For="Item.Progress" Label="进度" Width="100">
                <template #default="{ row }">
                    <el-progress :percentage="row.progress"></el-progress>
                </template>
            </EleColumn>
            <EleColumn For="Item.CreateDt" Label="发布时间" Width="200" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

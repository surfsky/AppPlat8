@page
@model App.Pages.Checks.CheckObjectEventsModel
@{
    ViewData["Title"] = "对象事件管理";
    var objectNameEncoded = System.Net.WebUtility.UrlEncode(Model.ObjectName ?? string.Empty);
}

@section body {
    <EleTable Title="对象事件" FormPage="CheckObjectEventForm?objectId=@Model.ObjectId&objectName=@objectNameEncoded" EnableBatch="true" DataHandler="?handler=Data&objectId=@Model.ObjectId" DeleteHandler="?handler=Delete&objectId=@Model.ObjectId">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Title" Width="240px" Label="标题"></EleInput>
                <EleSelect For="Item.Type" Width="220px" Label="类别" Clearable="true"></EleSelect>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" PopupUrl="CheckObjectEventForm?objectId=@Model.ObjectId&objectName=@objectNameEncoded" Icon="Plus" Visible="Model.Mode == PageMode.Edit">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="Model.Mode == PageMode.Edit">批量删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.CheckObjectEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.CheckObjectEdit)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Title" Label="标题" Width="220" Sortable="true"></EleColumn>
            <EleColumn For="Item.Type" Label="类别" Width="110"></EleColumn>
            <EleColumn For="Item.TriggleDt" Label="发生时间" Width="160" Format="DateTime"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="160" Format="DateTime"></EleColumn>
            <EleColumn For="Item.Content" Label="内容"></EleColumn>
        </Columns>
    </EleTable>
}

@page
@model App.Pages.Checks.CheckHazardsModel
@{
    ViewData["Title"] = "隐患管理";
}

@section body {
    <EleTable Title="隐患列表" FormPage="CheckHazardForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
            <EleInput For="Item.Description" Width="250px" Label="描述" ></EleInput>
            <EleInput For="Item.Check.CheckObject.Name" Width="250px" Label="对象" ></EleInput>
            <EleSelect For="Item.Status" Width="250px" Label="状态" Clearable="true" Items="@(new List<string>{"待整改", "整改中", "已整改"}.Select(s => new SelectListItem(s, s)))"></EleSelect>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn UPower="CheckHazardEdit" DPower="CheckHazardDelete" Width="100" Fixed="right"></EleOpColumn>
            <EleColumn For="Item.Check.CheckObject.Name" Label="检查对象" MinWidth="150"></EleColumn>
            <EleColumn For="Item.CheckItemText" Label="检查项" MinWidth="150" ShowOverflowTooltip="true"></EleColumn>
            <EleColumn For="Item.Description" Label="隐患描述" MinWidth="200" ShowOverflowTooltip="true"></EleColumn>
            <EleColumn For="Item.Status" Label="状态" Width="100">
                <template #default="{ row }">
                    <el-tag :type="row.status === '已整改' ? 'success' : 'danger'">{{ row.status }}</el-tag>
                </template>
            </EleColumn>
            <EleColumn For="Item.ExpireDt" Label="整改期限" Width="200" FormatString="yyyy-MM-dd"></EleColumn>
            <EleColumn For="Item.RectifyDt" Label="整改日期" Width="200" FormatString="yyyy-MM-dd"></EleColumn>
            <EleColumn For="Item.IsIn141" Label="141" Width="80">
                <template #default="{ row }">
                    <el-tag :type="row.isIn141 ? 'success' : 'info'">{{ row.isIn141 ? '是' : '否' }}</el-tag>
                </template>
            </EleColumn>
        </Columns>
    </EleTable>
}

@page
@model App.Pages.Checks.CheckHazardFormModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "隐患信息";
}

@section body {
    <EleForm Model="form" LabelWidth="120px">
        <EleSelector For="Item.ObjectId" TextFor="Item.ObjectName" Label="检查对象" Enabled="@(Model.Mode == PageMode.New)" FillRow="true" PopupUrl="CheckObjects?md=select"></EleSelector>
        <EleSelector For="Item.CheckSheetId" TextFor="Item.CheckSheetName" Label="检查单" Visible="false"  Enabled="@(Model.Mode == PageMode.New)" FillRow="true" PopupUrl="CheckSheets?md=select"></EleSelector>
        <EleSelector For="Item.CheckItemId" TextFor="Item.CheckItemText" Label="检查项" Enabled="@(Model.Mode == PageMode.New)" FillRow="true" PopupUrl="CheckSheetItems?md=select"></EleSelector>

        <EleInput For="Item.CheckItemText" Label="检查项内容" Enabled="false" FillRow="true"></EleInput>
        <EleInput For="Item.Description" Label="隐患描述" Rows="1" FillRow="true"></EleInput>
        <EleImageUpload For="Item.ImageUrls" Label="隐患图片" Multi="true" FillRow="true"></EleImageUpload>
        
        <EleSelect For="Item.Status" Label="状态"></EleSelect>
        <EleDatePicker For="Item.ExpireDt" Label="整改期限"></EleDatePicker>
        <EleDatePicker For="Item.RectifyDt" Label="整改日期" Enabled="false"></EleDatePicker>
        
        <EleSwitch For="Item.IsIn141" Label="录入141"></EleSwitch>
    
        <Bottom>
            <EleButton Type="Primary" Command="SaveClose" Visible="@(Model.Mode != PageMode.View)">保存</EleButton>
            <EleButton Command="Close">关闭</EleButton>
        </Bottom>
    </EleForm>
}

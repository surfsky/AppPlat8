@page
@using System.Text.Json
@{
    Layout = null;
    var src = Request.Query["src"].ToString();
    var name = Request.Query["name"].ToString();
    var srcJson = JsonSerializer.Serialize(src ?? string.Empty);
    var nameJson = JsonSerializer.Serialize(name ?? string.Empty);
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/docx-preview@0.3.6/dist/docx-preview.css" />
    <script src="https://cdn.jsdelivr.net/npm/docx-preview@0.3.6/dist/docx-preview.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/mammoth@1.8.0/mammoth.browser.min.js"></script>
    <style>
        html, body { margin: 0; height: 100%; background: #eef2f7; }
        #wrap {
            height: 100%;
            position: relative;
        }
        #office {
            width: 100%;
            height: 100%;
            border: 0;
            display: none;
            background: #fff;
        }
        #word {
            height: 100%;
            overflow: auto;
            box-sizing: border-box;
            padding: 16px;
            display: none;
        }
        #word.native-mode .docx-wrapper {
            background: #e2e8f0 !important;
            padding: 16px !important;
        }
        #word.native-mode .docx-wrapper > section.docx {
            margin: 0 auto 14px !important;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.14);
        }
        #word.compat-mode .docx-wrapper {
            background: transparent !important;
            padding: 0 !important;
        }
        .word-fallback {
            background: #fff;
            border-radius: 6px;
            box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05);
            padding: 18px 22px;
            line-height: 1.65;
            color: #0f172a;
        }
        .word-pages {
            max-width: 860px;
            margin: 0 auto;
        }
        .word-page {
            width: 794px;
            min-height: 1123px;
            margin: 0 auto 16px;
            background: #fff;
            border-radius: 2px;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.12);
            overflow: hidden;
        }
        .word-page-body {
            box-sizing: border-box;
            min-height: 1123px;
            padding: 72px;
            line-height: 1.65;
            color: #0f172a;
            font-size: 16px;
            word-break: break-word;
        }
        .word-page-body p {
            margin: 0 0 0.9em;
        }
        .word-fallback-tip {
            margin: 0 0 10px;
            font-size: 12px;
            color: #64748b;
        }
        #hint {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px;
            box-sizing: border-box;
            color: #334155;
            font-size: 14px;
            text-align: center;
        }
        .word-actions {
            position: absolute;
            top: 10px;
            right: 10px;
            z-index: 10;
            display: flex;
            gap: 8px;
        }
        .word-btn {
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            background: #ffffff;
            color: #334155;
            font-size: 12px;
            line-height: 1;
            padding: 7px 10px;
            cursor: pointer;
        }
        .word-btn:hover {
            background: #f8fafc;
        }
    </style>
</head>
<body>
    <div id="wrap">
        <div class="word-actions">
            <button id="btnOffice" type="button" class="word-btn">微软预览</button>
            <button id="btnNative" type="button" class="word-btn">原生模式</button>
            <button id="btnCompat" type="button" class="word-btn">兼容模式</button>
        </div>
        <iframe id="office" title="Office Word Preview"></iframe>
        <div id="word"></div>
        <div id="hint">正在加载微软 Office 预览...</div>
    </div>
    <script>
        const src = @Html.Raw(srcJson);
        const name = @Html.Raw(nameJson);
        const ext = (name.split('.').pop() || '').toLowerCase();
        const host = document.getElementById('word');
        const office = document.getElementById('office');
        const hint = document.getElementById('hint');

        function showHint(text) {
            hint.innerHTML = text;
            hint.style.display = 'flex';
        }

        function hideHint() {
            hint.style.display = 'none';
        }

        function showOffice() {
            office.style.display = 'block';
            host.style.display = 'none';
            host.classList.remove('native-mode', 'compat-mode');
        }

        function showHost(modeClass) {
            office.style.display = 'none';
            host.style.display = 'block';
            host.classList.remove('native-mode', 'compat-mode');
            if (modeClass) {
                host.classList.add(modeClass);
            }
        }

        function renderOffice() {
            if (!src) {
                showHint('文件地址不存在');
                return;
            }
            const absUrl = new URL(src, window.location.origin).toString();
            const officeUrl = 'https://view.officeapps.live.com/op/embed.aspx?src=' + encodeURIComponent(absUrl);
            showOffice();
            showHint('正在加载微软 Office 预览...');
            office.src = officeUrl;
            office.onload = () => {
                hideHint();
            };

            // Office在线页在localhost场景常显示内部报错页，给出兜底提示。
            window.setTimeout(() => {
                if (hint.style.display !== 'none') {
                    showHint('微软 Office 预览可能不可用（本地地址常被拦截）。<br/>可点击右上角“兼容模式”。');
                }
            }, 4500);
        }

        async function renderNative() {
            if (!src) {
                showHint('文件地址不存在');
                return;
            }

            if (ext === 'doc') {
                showHint('暂不支持 .doc 原生模式预览。<br/>请使用微软预览或兼容模式。');
                return;
            }

            if (!window.docx || typeof window.docx.renderAsync !== 'function') {
                showHint('原生模式组件不可用。<br/>可切换兼容模式。');
                return;
            }

            try {
                showHost('native-mode');
                showHint('正在加载原生模式预览...');
                host.innerHTML = '';

                const resp = await fetch(src);
                if (!resp.ok) throw new Error('文档请求失败');
                const buffer = await resp.arrayBuffer();

                await window.docx.renderAsync(buffer, host, null, {
                    breakPages: true,
                    renderHeaders: true,
                    renderFooters: true,
                    ignoreWidth: false,
                    ignoreHeight: false,
                    className: 'docx-preview'
                });

                // 有些文档在特定浏览器环境里 renderAsync 不报错但不会产出可见内容。
                const hasPage = host.querySelector('section.docx, .docx-wrapper section, .docx') !== null;
                const hasText = (host.textContent || '').trim().length > 0;
                if (!hasPage && !hasText) {
                    throw new Error('原生模式未产出可见内容');
                }

                hideHint();
            } catch (e) {
                console.error(e);
                const msg = e && e.message ? e.message : '未知错误';
                showHint('原生模式预览失败：' + msg + '<br/>正在自动切换到兼容模式...');
                await renderCompat();
            }
        }

        async function renderCompat() {
            const src = @Html.Raw(srcJson);
            const name = @Html.Raw(nameJson);
            const ext = (name.split('.').pop() || '').toLowerCase();

            if (!src) {
                showHint('文件地址不存在');
                return;
            }

            if (ext === 'doc') {
                showHint('暂不支持 .doc 兼容模式预览。<br/>请使用微软预览或下载后打开。');
                return;
            }

            try {
                showHost('compat-mode');
                showHint('正在加载兼容模式预览...');
                host.innerHTML = '';
                const resp = await fetch(src);
                if (!resp.ok) throw new Error('文档请求失败');
                const buffer = await resp.arrayBuffer();

                if (!window.mammoth || typeof window.mammoth.convertToHtml !== 'function') {
                    throw new Error('兼容模式组件不可用');
                }

                const result = await window.mammoth.convertToHtml({ arrayBuffer: buffer });
                const html = result && result.value ? result.value : '<p>文档内容为空</p>';
                renderPagedFallback(host, html);

                hideHint();
            } catch (e) {
                console.error(e);
                const msg = e && e.message ? e.message : '未知错误';
                showHint('文档预览失败：' + msg + '<br/>可下载后使用 Office/WPS 查看。');
                showHost('compat-mode');
            }
        }

        function renderPagedFallback(container, html) {
            const PAGE_HEIGHT = 1123;
            const PAGE_PADDING = 72;
            const BODY_LIMIT = PAGE_HEIGHT - PAGE_PADDING * 2;

            container.innerHTML = '';

            const pages = document.createElement('div');
            pages.className = 'word-pages';

            const tip = document.createElement('p');
            tip.className = 'word-fallback-tip';
            tip.textContent = '兼容模式预览（按 A4 视觉分页，与 Office 可能存在细微差异）';
            pages.appendChild(tip);

            const template = document.createElement('template');
            template.innerHTML = html || '<p>文档内容为空</p>';

            const toNodeArray = (list) => Array.from(list || []).filter(Boolean);

            const extractBlocks = (tpl) => {
                const topLevel = toNodeArray(tpl.content.childNodes)
                    .filter((n) => !(n.nodeType === Node.TEXT_NODE && !String(n.textContent || '').trim()));

                if (topLevel.length === 0) {
                    return [document.createElement('p')];
                }

                // mammoth 通常会输出一个外层 div 包裹全部正文，展开后再分页。
                if (topLevel.length === 1 && topLevel[0].nodeType === Node.ELEMENT_NODE) {
                    const only = topLevel[0];
                    const children = toNodeArray(only.childNodes)
                        .filter((n) => !(n.nodeType === Node.TEXT_NODE && !String(n.textContent || '').trim()));
                    if (children.length > 1) {
                        return children;
                    }
                }

                return topLevel;
            };

            const createPage = () => {
                const page = document.createElement('div');
                page.className = 'word-page';
                const body = document.createElement('div');
                body.className = 'word-page-body';
                page.appendChild(body);
                pages.appendChild(page);
                return body;
            };

            let currentBody = createPage();
            const nodes = extractBlocks(template);

            for (let i = 0; i < nodes.length; i += 1) {
                const node = nodes[i].cloneNode(true);
                currentBody.appendChild(node);

                if (currentBody.scrollHeight > BODY_LIMIT) {
                    currentBody.removeChild(node);
                    const nextBody = createPage();
                    nextBody.appendChild(node);

                    // 单节点超高时允许该页溢出，避免死循环
                    if (nextBody.scrollHeight > BODY_LIMIT) {
                        nextBody.style.overflow = 'visible';
                    }

                    currentBody = nextBody;
                }
            }

            container.appendChild(pages);
        }

        document.getElementById('btnOffice').addEventListener('click', renderOffice);
        document.getElementById('btnNative').addEventListener('click', renderNative);
        document.getElementById('btnCompat').addEventListener('click', renderCompat);

        renderOffice();
    </script>
</body>
</html>

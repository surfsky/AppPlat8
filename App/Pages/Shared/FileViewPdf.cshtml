@page
@{
    Layout = null;
    var src = Request.Query["src"].ToString();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
        html, body { margin: 0; height: 100%; background: #0f172a; }
        iframe { width: 100%; height: 100%; border: 0; }
    </style>
</head>
<body>
    <iframe src="@src"></iframe>
</body>
</html>

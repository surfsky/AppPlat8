@page
@using System.Text.Json
@{
    Layout = null;
    var src = Request.Query["src"].ToString();
    var name = Request.Query["name"].ToString();
    var srcJson = JsonSerializer.Serialize(src ?? string.Empty);
    var nameJson = JsonSerializer.Serialize(name ?? string.Empty);
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/x-data-spreadsheet@1.1.5/dist/xspreadsheet.css" />
    <script src="https://cdn.jsdelivr.net/npm/x-data-spreadsheet@1.1.5/dist/xspreadsheet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <style>
        html, body { margin: 0; height: 100%; background: #f8fafc; overflow: hidden; }
        #excel {
            width: 100%;
            height: 100%;
            display: none;
        }
        #hint {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 18px;
            box-sizing: border-box;
            color: #334155;
            font-size: 14px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div id="excel"></div>
    <div id="hint">正在加载 Excel 预览...</div>
    <script>
        function workbookToSpreadsheetData(workbook) {
            const data = [];
            workbook.SheetNames.forEach((sheetName) => {
                const ws = workbook.Sheets[sheetName];
                if (!ws || !ws['!ref']) {
                    data.push({ name: sheetName, rows: {} });
                    return;
                }

                const range = XLSX.utils.decode_range(ws['!ref']);
                const rows = {};
                for (let r = range.s.r; r <= range.e.r; r += 1) {
                    const cells = {};
                    for (let c = range.s.c; c <= range.e.c; c += 1) {
                        const ref = XLSX.utils.encode_cell({ r, c });
                        const cell = ws[ref];
                        if (!cell) continue;
                        const text = XLSX.utils.format_cell(cell);
                        cells[c] = { text: text == null ? '' : String(text) };
                    }
                    if (Object.keys(cells).length > 0) {
                        rows[r] = { cells };
                    }
                }

                data.push({
                    name: sheetName,
                    rows
                });
            });
            return data;
        }

        async function run() {
            const src = @Html.Raw(srcJson);
            const name = @Html.Raw(nameJson);
            const ext = (name.split('.').pop() || '').toLowerCase();
            const host = document.getElementById('excel');
            const hint = document.getElementById('hint');
            if (!src) {
                hint.textContent = '文件地址不存在';
                return;
            }

            if (ext !== 'xls' && ext !== 'xlsx' && ext !== 'csv') {
                hint.innerHTML = '当前文件不是 Excel 格式。<br/>请下载后使用 Office/WPS 查看。';
                return;
            }

            try {
                const resp = await fetch(src);
                if (!resp.ok) throw new Error('表格请求失败');
                const buffer = await resp.arrayBuffer();
                const workbook = XLSX.read(buffer, { type: 'array' });
                const sheetData = workbookToSpreadsheetData(workbook);

                host.style.display = 'block';

                const xs = x_spreadsheet(host, {
                    mode: 'read',
                    showToolbar: false,
                    showContextmenu: false,
                    showBottomBar: true,
                    row: { len: 200, height: 24 },
                    col: { len: 80, width: 100 },
                    view: {
                        height: () => host.clientHeight,
                        width: () => host.clientWidth
                    }
                });
                xs.loadData(sheetData);

                hint.style.display = 'none';
                window.addEventListener('resize', () => {
                    if (typeof xs.reRender === 'function') xs.reRender();
                });
            } catch (e) {
                console.error(e);
                hint.innerHTML = 'Excel 预览失败。<br/>可下载后使用 Office/WPS 查看。';
            }
        }

        run();
    </script>
</body>
</html>

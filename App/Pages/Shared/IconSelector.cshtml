@page
@{
    ViewData["Title"] = "图标选择";
}

@section head {
    <style>
        .icon-item {
            cursor: pointer;
            transition: all 0.2s;
        }
        .icon-item:hover {
            background-color: #f3f4f6;
            transform: scale(1.1);
        }
    </style>
}

@section body {
    <div class="p-4 bg-white w-full h-full overflow-y-auto">
        <div class="mb-4">
            <input type="text" id="searchInput" placeholder="搜索图标..." class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div class="grid grid-cols-6 gap-4" id="iconGrid">
            <!-- Icons will be populated here -->
        </div>
    </div>
}

@section script {
    <script>
        // FontAwesome 图标列表
        // 参考 https://element-plus.org/en-US/component/icon
        const icons = [
            "user","users","user-tag","user-cog","user-shield",
            "home","tachometer-alt","chart-line","chart-bar","chart-pie",
            "cog","cogs","wrench","tools","sliders-h",
            "envelope","envelope-open","comment","comments","bullhorn",
            "file","file-alt","file-pdf","file-word","file-excel",
            "folder","folder-open","folder-plus","folder-minus","file",
            "check","check-circle","check-square","check-double",
            "times","times-circle","plus","plus-circle","minus",
            "edit","pen","pencil-alt","trash","trash-alt",
            "search","search-plus","search-minus","filter",
            "lock","unlock","key","shield-alt",
            "calendar","calendar-alt","calendar-check","clock",
            "map","map-marked-alt","map-marker-alt","map-pin","map-signs",
            "location-arrow","compass","crosshairs","route","directions",
            "draw-polygon","layer-group","street-view",
            "globe","globe-asia","globe-americas","globe-europe","globe-africa",
            "link","external-link-alt","share","share-alt",
            "download","upload","cloud","cloud-upload-alt",
            "sun","sunrise","sunset","moon","cloud-moon","cloud-sun",
            "cloud","cloud-rain","cloud-showers-heavy","cloud-sun-rain","bolt",
            "wind","umbrella","water","smog","temperature-high","temperature-low",
            "satellite","satellite-dish",
            "list","list-alt","list-ul","list-ol","th","th-large",
            "bars","ellipsis-h","ellipsis-v",
            "info-circle","question-circle","exclamation-circle","exclamation-triangle",
            "sitemap","project-diagram","tasks","clipboard-list",
            "cubes","cube","box","boxes",
            "desktop","laptop","mobile-alt","tablet-alt",
            "print","camera","video","image",
            "shopping-cart","money-bill","credit-card",
            "briefcase","building","university","hospital",
            "bell","bell-slash","book","book-open","graduation-cap",
            "rocket","heart","star","star-half-alt","thumbs-up",
            "thumbs-down","handshake","award","trophy","medal",
            "lightbulb","battery-full","battery-half","battery-quarter","battery-empty",
            "music","headphones","microphone","gift","birthday-cake",
            "utensils","wifi","sync","sync-alt","redo","undo",
            "clipboard","flag","rss",
            "bug","hands-helping","hand-holding-heart"
        ];

        const grid = document.getElementById('iconGrid');
        const searchInput = document.getElementById('searchInput');

        /** 渲染图标网格 */
        function renderIcons(filter = '') {
            grid.innerHTML = '';
            icons.forEach(icon => {
                if (icon.toLowerCase().includes(filter.toLowerCase())) {
                    iconCls = 'fas fa-' + icon;
                    const div = document.createElement('div');
                    div.className = 'icon-item flex flex-col items-center justify-center p-3 border border-gray-100 rounded hover:shadow-sm';
                    div.innerHTML = `
                        <i class="${iconCls} text-2xl text-gray-600 mb-2"></i>
                        <span class="text-xs text-gray-500 truncate w-full text-center" title="${iconCls}">${icon}</span>
                    `;
                    div.onclick = () => selectIcon(iconCls);
                    grid.appendChild(div);
                }
            });
        }

        /** 选择图标 */
        function selectIcon(iconCls) {
            const data = { id: iconCls, name: iconCls };
            const payload = { type: 'ElePicker', data };

            // 统一关闭协议：优先使用 EleManager.closePage。
            if (window.EleManager && typeof window.EleManager.closePage === 'function') {
                window.EleManager.closePage(payload);
                return;
            }

            console.error('EleManager.closePage is unavailable.');
        }

        // 监听搜索输入变化
        searchInput.addEventListener('input', (e) => renderIcons(e.target.value));

        // Initial render
        renderIcons();
    </script>
}

@page
@using System.Text.Json
@{
    Layout = null;
    var src = Request.Query["src"].ToString();
    var srcJson = JsonSerializer.Serialize(src ?? string.Empty);
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
        html, body {
            margin: 0;
            height: 100%;
            background: #0b1120;
        }
        .wrap {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at 20% 20%, #1e293b 0, #0b1120 45%, #020617 100%);
        }
        video {
            width: 100%;
            height: 100%;
            max-width: 100%;
            max-height: 100%;
            background: #000;
            outline: none;
        }
        .tip {
            position: fixed;
            top: 10px;
            left: 10px;
            font-size: 12px;
            color: #cbd5e1;
            background: rgba(15, 23, 42, 0.7);
            border: 1px solid rgba(148, 163, 184, 0.35);
            border-radius: 6px;
            padding: 4px 8px;
            z-index: 2;
        }
        .err {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: #e2e8f0;
            background: rgba(2, 6, 23, 0.92);
            padding: 20px;
            z-index: 3;
        }
    </style>
</head>
<body>
    <div class="tip">可使用空格键播放或暂停</div>
    <div class="wrap">
        <video id="player" controls preload="metadata" playsinline></video>
    </div>
    <div id="err" class="err"></div>

    <script>
        const src = @Html.Raw(srcJson);
        const player = document.getElementById('player');
        const errEl = document.getElementById('err');

        function showError(message) {
            errEl.textContent = message;
            errEl.style.display = 'flex';
        }

        if (!src) {
            showError('视频地址不存在');
        } else {
            player.src = src;
            player.addEventListener('error', () => {
                showError('视频加载失败，请检查文件格式或内容。');
            });
        }

        document.addEventListener('keydown', (e) => {
            if (e.code !== 'Space') return;
            e.preventDefault();
            if (player.paused) player.play().catch(() => {});
            else player.pause();
        });
    </script>
</body>
</html>

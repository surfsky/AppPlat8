@page
@model App.Pages.Shared.AttFormModel
@{
    ViewData["Title"] = "附件信息";
}

@section body {
    <EleForm Model="form" LabelWidth="120px" SaveHandler="?handler=Save&uniId=@Model.UniId">
        <EleInput For="Item.Key" Label="关联键" Disabled="true"></EleInput>
        <EleSelect For="Item.Type" Label="类型" Required="true"></EleSelect>
        <EleImageUpload For="Item.Content" Label="上传图片" FillRow="true"></EleImageUpload>
        <EleInput For="Item.Content" Label="附件地址" FillRow="true" Required="true"></EleInput>
        <EleInput For="Item.FileName" Label="文件名" FillRow="true"></EleInput>
        <EleNumber For="Item.SortId" Label="排序"></EleNumber>
        <EleSwitch For="Item.Protect" Label="保护"></EleSwitch>
        <EleInput For="Item.Remark" Label="备注" Rows="3" FillRow="true"></EleInput>
    </EleForm>
}

@page "/Shared/FileViews/Markdown"
@using System.Text.Json
@{
    Layout = null;
    var src = Request.Query["src"].ToString();
    var name = Request.Query["name"].ToString();
    var srcJson = JsonSerializer.Serialize(src ?? string.Empty);
    var nameJson = JsonSerializer.Serialize(name ?? string.Empty);
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script src="https://cdn.jsdelivr.net/npm/markdown-it@14.1.0/dist/markdown-it.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/highlight.js@11.10.0/lib/common.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.10.0/styles/github.min.css" />
    <style>
        html, body {
            margin: 0;
            height: 100%;
            background: #f1f5f9;
            overflow: hidden;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }
        .md-wrap {
            height: 100%;
            overflow: auto;
            box-sizing: border-box;
            padding: 16px;
        }
        .md-page {
            max-width: 900px;
            margin: 0 auto;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 10px rgba(15, 23, 42, 0.10);
            padding: 28px 34px;
            color: #0f172a;
            line-height: 1.7;
            word-break: break-word;
        }
        .md-page h1, .md-page h2, .md-page h3 {
            margin-top: 1.2em;
            margin-bottom: 0.55em;
            line-height: 1.3;
        }
        .md-page pre {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            padding: 12px;
            overflow: auto;
        }
        .md-page code {
            background: #f1f5f9;
            border-radius: 4px;
            padding: 0.1em 0.35em;
            font-size: 0.95em;
        }
        .md-page pre code {
            background: transparent;
            padding: 0;
        }
        .md-hint {
            max-width: 900px;
            margin: 0 auto 8px;
            font-size: 12px;
            color: #64748b;
        }
    </style>
</head>
<body>
    <div class="md-wrap">
        <div class="md-hint" id="mdHint">Markdown 预览</div>
        <article class="md-page" id="mdHost">正在加载...</article>
    </div>
    <script>
        const src = @Html.Raw(srcJson);
        const name = @Html.Raw(nameJson);
        const host = document.getElementById('mdHost');
        const hint = document.getElementById('mdHint');

        function setHint(text) {
            hint.textContent = text;
        }

        function render(content) {
            const md = window.markdownit({
                html: false,
                linkify: true,
                breaks: true,
                highlight: function(str, lang) {
                    if (lang && window.hljs && window.hljs.getLanguage(lang)) {
                        try {
                            return window.hljs.highlight(str, { language: lang }).value;
                        } catch {
                        }
                    }
                    return '';
                }
            });

            host.innerHTML = md.render(content || '');
            if (window.hljs) {
                host.querySelectorAll('pre code').forEach((block) => {
                    try { window.hljs.highlightElement(block); } catch {}
                });
            }
        }

        async function run() {
            if (!src) {
                host.textContent = '文件地址不存在';
                return;
            }
            setHint(`Markdown 预览 · ${name || ''}`);
            try {
                const resp = await fetch(src);
                if (!resp.ok) throw new Error('加载失败');
                const text = await resp.text();
                render(text);
            } catch (e) {
                console.error(e);
                host.textContent = '预览失败：' + (e && e.message ? e.message : '未知错误');
            }
        }

        run();
    </script>
</body>
</html>

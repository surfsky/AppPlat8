@page "/Shared/FileViews/Model"
@using System.Text.Json
@{
    Layout = null;
    var src = Request.Query["src"].ToString();
    var srcJson = JsonSerializer.Serialize(src ?? string.Empty);
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script type="module" src="https://unpkg.com/@@google/model-viewer/dist/model-viewer.min.js"></script>
    <style>
        html, body {
            margin: 0;
            height: 100%;
            background: #020617;
            overflow: hidden;
        }
        #viewerWrap {
            width: 100%;
            height: 100%;
            position: relative;
        }
        model-viewer {
            width: 100%;
            height: 100%;
            display: block;
            background: #020617;
        }
        #tip {
            position: absolute;
            top: 12px;
            left: 12px;
            z-index: 2;
            font-size: 12px;
            color: #cbd5e1;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(148, 163, 184, 0.35);
            border-radius: 6px;
            padding: 6px 8px;
        }
        #err {
            position: absolute;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: #e2e8f0;
            padding: 16px;
            font-size: 14px;
            background: #020617;
            z-index: 3;
        }
    </style>
</head>
<body>
    <div id="viewerWrap">
        <div id="tip">左键旋转，右键平移，滚轮缩放</div>
        <div id="err"></div>
        <model-viewer id="mv" camera-controls auto-rotate shadow-intensity="1" exposure="1.1"></model-viewer>
    </div>
    <script>
        const src = @Html.Raw(srcJson);
        const host = document.getElementById('viewerWrap');
        const errEl = document.getElementById('err');
        const mv = document.getElementById('mv');

        const showError = (msg) => {
            errEl.textContent = msg;
            errEl.style.display = 'flex';
        };

        if (!src) {
            showError('模型地址不存在');
        } else {
            const targetUrl = new URL(src, window.location.origin).toString();
            mv.src = targetUrl;
            mv.addEventListener('error', () => {
                showError('模型加载失败，请检查文件内容或网络。');
            });
        }
    </script>
</body>
</html>

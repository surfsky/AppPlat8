@page
@model App.Pages.Shared.FileViewerModel
@using System.Text.Json
@{
    Layout = "_Layout";
    ViewData["Title"] = "文件预览";
    var viewerUrlJson = JsonSerializer.Serialize(Model.ViewerUrl ?? string.Empty);
    var downloadUrlJson = JsonSerializer.Serialize(Model.DownloadUrl ?? string.Empty);
}

@section head {
    <style>
        .fv-root {
            height: calc(100vh - 20px);
            padding: 10px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            gap: 8px;
            background: #f8fafc;
        }
        .fv-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 8px 12px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #ffffff;
        }
        .fv-title {
            font-size: 14px;
            color: #0f172a;
            font-weight: 600;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .fv-content {
            flex: 1;
            min-height: 0;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            background: #ffffff;
            overflow: auto;
            position: relative;
        }
        .fv-iframe {
            width: 100%;
            height: 100%;
            border: 0;
            display: block;
        }
        .fv-empty {
            color: #64748b;
            padding: 20px;
        }
        .fv-actions {
            display: inline-flex;
            gap: 8px;
        }
        .toolbar-btn {
            border: 1px solid #dbeafe;
            border-radius: 6px;
            background: #ffffff;
            color: #1d4ed8;
            font-size: 12px;
            line-height: 1;
            padding: 7px 10px;
            cursor: pointer;
        }
        .toolbar-btn:hover {
            background: #eff6ff;
        }
    </style>
}

@section body {
    <div class="fv-root">
        <div class="fv-toolbar">
            <div class="fv-title" id="fv-title">@Model.FileName</div>
            <div class="fv-actions">
                <button type="button" id="fv-open" class="toolbar-btn">新窗口</button>
                <button type="button" id="fv-download" class="toolbar-btn">下载</button>
                <button type="button" id="fv-close" class="toolbar-btn">关闭</button>
            </div>
        </div>
        <div class="fv-content" id="fv-content">
            @if (!string.IsNullOrWhiteSpace(Model.Error))
            {
                <div class="fv-empty">@Model.Error</div>
            }
            else if (!string.IsNullOrWhiteSpace(Model.ViewerUrl))
            {
                <iframe class="fv-iframe" src="@Model.ViewerUrl"></iframe>
            }
            else
            {
                <div class="fv-empty">预览地址不存在</div>
            }
        </div>
    </div>
}

@section script {
    <script>
        const viewerUrl = @Html.Raw(viewerUrlJson);
        const downloadUrl = @Html.Raw(downloadUrlJson);

        function downloadFile() {
            if (!downloadUrl) {
                if (window.EleManager && typeof EleManager.showWarning === 'function')
                    EleManager.showWarning('下载地址不存在');
                return;
            }
            const a = document.createElement('a');
            a.href = downloadUrl;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        function openInNewTab() {
            if (!viewerUrl) return;
            window.open(viewerUrl, '_blank');
        }

        function closeViewer() {
            if (window.EleManager && typeof EleManager.closeDrawer === 'function') {
                EleManager.closeDrawer();
            } else {
                window.close();
            }
        }

        const btnOpen = document.getElementById('fv-open');
        if (btnOpen) btnOpen.addEventListener('click', openInNewTab);
        const btnDownload = document.getElementById('fv-download');
        if (btnDownload) btnDownload.addEventListener('click', downloadFile);
        const btnClose = document.getElementById('fv-close');
        if (btnClose) btnClose.addEventListener('click', closeViewer);
    </script>
}

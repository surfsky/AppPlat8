@page
@model App.Pages.OA.CommentsModel
@{
    ViewData["Title"] = "评论管理";
}

@section body {
    <EleTable Title="评论" FormPage="CommentForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
                <EleInput For="Item.Content" Width="200px" Label="内容" LabelWidth="60px"></EleInput>
                <EleInput For="Item.Author"  Width="200px" Label="评论人" LabelWidth="80px"></EleInput>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.CommentEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.CommentDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Type" Label="类别" Width="100"></EleColumn>
            <EleColumn For="Item.Author" Label="评论人" Width="120"></EleColumn>
            <EleColumn For="Item.Content" Label="内容" MinWidth="200"></EleColumn>
            <EleColumn For="Item.Rating" Label="评分" Width="80"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="时间" Width="200" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

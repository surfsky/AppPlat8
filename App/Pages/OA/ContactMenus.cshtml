@page
@model App.Pages.OA.ContactMenusModel
@{
    ViewData["Title"] = "联系人目录管理";
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="联系人目录" FormPage="ContactMenuForm" EnableBatch="false" RowKey="id">
        <Toolbar>
            <Buttons>
                <EleButton Type="Primary" Command="Add" Icon="Plus" Width="120px" Visible="@Auth.CheckPower(Power.ContactMenuNew)">新增目录</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleOpColumn Width="100">
                <Op Command="Edit" Icon="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.ContactMenuEdit)"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.ContactMenuDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Width="260"></EleColumn>
            <EleColumn For="Item.Id" Label="ID" Width="120"></EleColumn>
            <EleColumn For="Item.SortId" Label="排序" Width="100"></EleColumn>
            <EleColumn For="Item.FullName" Label="全称" MinWidth="320"></EleColumn>
        </Columns>
    </EleTable>
}

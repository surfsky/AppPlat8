@page
@model App.Pages.OA.AssetsModel
@{
    ViewData["Title"] = "固定资产管理";
}

@section body {
    <EleTable Title="固定资产" FormPage="AssetForm" EnableBatch="true" >
        <Toolbar>
            <EleInput For="Item.Name" Label="名称" Width="200px"></EleInput>
            <EleSelect For="Item.Category" Label="类别" Width="200px" Clearable="true"></EleSelect>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
                <EleButton Type="Info" Click="navigateTo('/OA/AssetCategories')" Icon="Setting" VPower="AssetCategoryEdit">类别管理</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn UPower="AssetEdit" DPower="AssetDelete" Width="100" Fixed="right"></EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="150" Sortable="true"></EleColumn>
            <EleColumn For="Item.Category" Label="类别" Width="100" Prop="categoryName"></EleColumn>
            <EleImageColumn For="Item.Image" Label="图片" Width="60"></EleImageColumn>
            <EleColumn For="Item.Org.Name" Label="组织" Width="120" Prop="orgName"></EleColumn>
            <EleColumn For="Item.ChargeUser.Name" Label="责任人" Width="100" Prop="chargeUserName"></EleColumn>
            <EleColumn For="Item.Location" Label="位置" Width="120"></EleColumn>
            <EleColumn For="Item.Manufacturer" Label="厂商" Width="120"></EleColumn>
            <EleColumn For="Item.EnableDt" Label="启用时间" Width="110" FormatString="yyyy-MM-dd"></EleColumn>
            <EleColumn For="Item.ExpireDt" Label="过期时间" Width="110" FormatString="yyyy-MM-dd"></EleColumn>
            <EleColumn For="Item.IsExpireAlert" Label="提醒" Width="80" Type="Switch"></EleColumn>>
        </Columns>
    </EleTable>
}

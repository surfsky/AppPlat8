@page
@model App.Pages.Admin.AnnouncesModel
@{
    ViewData["Title"] = "Announcements";
}

@section body {
    <EleTable Title="公告" FormPage="AnnounceForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
                <EleSelect For="Item.Status" Width="200px" Label="状态" ></EleSelect>
                <EleDatePicker For="Item.CreateTime" Type="DateRange" StartPlaceholder="开始日期" EndPlaceholder="结束日期" Width="600px" Label="创建时间" ></EleDatePicker>
                <EleInput For="Item.Title" Width="200px" Label="标题" ></EleInput>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="@Auth.CheckPower(Power.AnnounceDelete)">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn ></EleNumColumn>
            <EleOpColumn Width="80" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.AnnounceEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.AnnounceDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Title" Label="标题" Link="true" MinWidth="200" Sortable="true"></EleColumn>
            <EleColumn For="Item.Author" Label="作者" Width="120" Sortable="true"></EleColumn>
            <EleColumn For="Item.StatusName" Label="状态" Width="100"></EleColumn>
            <EleColumn For="Item.PublishTime" Label="发布时间" Width="180" Format="@ColumnFormat.DateTime" Sortable="true"></EleColumn>
            <EleColumn For="Item.ViewCount" Label="浏览次数" Width="110" Sortable="true"></EleColumn>
            <EleColumn For="Item.IsTop" Label="是否置顶" Width="90"></EleColumn>
            <EleColumn For="Item.CreateTime" Label="创建时间" Width="180" Format="@ColumnFormat.Date" Sortable="true"></EleColumn>
        </Columns>
    </EleTable>
}

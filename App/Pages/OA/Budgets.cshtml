@page
@model App.Pages.OA.BudgetsModel
@{
    ViewData["Title"] = "预算管理";
}

@section body {
    <EleTable Title="预算" FormPage="BudgetForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
            <EleInput For="Item.Name" Width="200px" Label="名称" LabelWidth="60px"></EleInput>
            <EleNumber For="Item.Year" Width="120px" Label="年份" LabelWidth="60px"></EleNumber>
            <EleSelect For="Item.TypeId" Width="150px" Label="分类" LabelWidth="60px" Items="Model.BudgetTypes" Clearable="true"></EleSelect>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Info" Click="navigateTo('/OA/BudgetTypes')" Icon="Setting" VPower="BudgetTypeEdit">类别管理</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn UPower="BudgetEdit" DPower="BudgetDelete" Width="100" Fixed="right"></EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="150" Sortable="true"></EleColumn>
            <EleColumn For="Item.Year" Label="年份" Width="80"></EleColumn>
            <EleColumn For="Item.Type.Name" Label="分类" Width="100"></EleColumn>
            <EleColumn For="Item.Org.Name" Label="组织" Width="120"></EleColumn>
            <EleColumn For="Item.Company" Label="厂商" Width="120"></EleColumn>
            <EleColumn For="Item.Project" Label="关联项目" Width="120"></EleColumn>
            <EleColumn For="Item.PayDt" Label="支付日期" Width="110" FormatString="yyyy-MM-dd"></EleColumn>
            <EleColumn For="Item.PayStatus" Label="支付状态" Width="100"></EleColumn>
        </Columns>
    </EleTable>
}

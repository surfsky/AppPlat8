@page
@model App.Pages.OA.ContactsModel
@{
    ViewData["Title"] = "联系人管理";
    var queryMenuId = Request.Query["menuId"].ToString();
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="联系人" FormPage="ContactForm" EnableBatch="true">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Width="180px" Label="姓名"></EleInput>
                <EleInput For="Item.Tel" Width="180px" Label="电话"></EleInput>
                <EleInput For="Item.Title" Width="180px" Label="职务"></EleInput>
                <EleTreeSelect For="Item.MenuId" Width="220px" Label="目录" Api="/httpapi/oa/GetContactMenuTree?selectedId=@queryMenuId" Clearable="true" CheckStrictly="true"></EleTreeSelect>
                <EleTreeSelect For="Item.OrgId" Width="220px" Label="组织" Api="/httpapi/orgs/GetAuthOrgTree" Clearable="true" CheckStrictly="true"></EleTreeSelect>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus" Visible="@Auth.CheckPower(Power.ContactNew)">新增</EleButton>
                <EleButton Type="Warning" Icon="Upload" Handler="Import" Visible="@Auth.CheckPower(Power.ContactNew)">导入</EleButton>
                <EleButton Type="Info" PopupUrl="ContactMenus" Icon="FolderOpened" Visible="@Auth.CheckPower(Power.ContactMenuView)">目录管理</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="@Auth.CheckPower(Power.ContactDelete)">删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Icon="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.ContactEdit)"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.ContactDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="姓名" Link="true" Width="160" Sortable="true"></EleColumn>
            <EleColumn For="Item.Tel" Label="电话" Width="160"></EleColumn>
            <EleColumn For="Item.Title" Label="职务" Width="140"></EleColumn>
            <EleColumn For="Item.MenuName" Label="目录" Width="160" Prop="menuName"></EleColumn>
            <EleColumn For="Item.OrgName" Label="组织" Width="180" Prop="orgName"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="180" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

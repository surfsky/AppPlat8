@page
@model App.Pages.AI.AIConfigsModel
@{
    ViewData["Title"] = "AI配置管理";
}

@section body {
    <EleTable Title="AI配置" FormPage="AIConfigForm" EnableBatch="false">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Label="名称" Width="220px"></EleInput>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑"></Op>
                <Op Command="Delete" Tooltip="删除"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" MinWidth="140"></EleColumn>
            <EleColumn For="Item.BaseUrl" Label="地址" MinWidth="240"></EleColumn>
            <EleColumn For="Item.Model" Label="模型" Width="160"></EleColumn>
            <EleColumn For="Item.Services" Label="服务" Width="120"></EleColumn>
            <EleColumn For="Item.ApiKeyMask" Label="Key" Width="160"></EleColumn>
            <EleColumn For="Item.IsDefault" Label="默认" Width="80"></EleColumn>
            <EleColumn For="Item.InUsed" Label="启用" Width="80"></EleColumn>
            <EleColumn For="Item.TimeoutSeconds" Label="超时(秒)" Width="100"></EleColumn>
        </Columns>
    </EleTable>
}

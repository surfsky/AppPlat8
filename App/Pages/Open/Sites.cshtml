@page
@model App.Pages.Open.SitesModel
@{
    ViewData["Title"] = "参考网站管理";
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="参考网站" FormPage="SiteForm" EnableBatch="true">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Type" Width="180px" Label="分组"></EleInput>
                <EleInput For="Item.Name" Width="220px" Label="名称"></EleInput>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus" Visible="@Auth.CheckPower(Power.SiteNew)">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="@Auth.CheckPower(Power.SiteDelete)">删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Icon="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.SiteEdit)"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.SiteDelete)"></Op>
            </EleOpColumn>
            <EleImageColumn For="Item.Icon" Label="图标" Width="60" Sortable="false"></EleImageColumn>
            <EleColumn For="Item.Type" Label="分组" Width="120"></EleColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="180" Sortable="true"></EleColumn>
            <EleColumn For="Item.Desc" Label="描述" MinWidth="220"></EleColumn>
            <EleColumn For="Item.Url" Label="网址" MinWidth="260">
                <template #default="scope">
                    <a :href="scope.row.url || '#'" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:text-blue-700 hover:underline">
                        {{ scope.row.url || '' }}
                    </a>
                </template>
            </EleColumn>
            <EleColumn For="Item.SortId" Label="排序" Width="90"></EleColumn>
        </Columns>
    </EleTable>
}

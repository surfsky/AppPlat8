@page
@model App.Pages.OA.ArticlesModel
@{
    ViewData["Title"] = "文档管理";
}

@section body {
    <EleTable Title="文档" FormPage="ArticleForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
            <EleInput For="Item.Name" Label="名称" Width="400px"></EleInput>
            <EleTreeSelect For="Item.CategoryId" Label="目录" Items="Model.Categories" Clearable="true" Width="400px"></EleTreeSelect>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
                <EleButton Type="Info" Click="navigateTo('/OA/ArticleCategories')" Icon="Setting" VPower="ArticleCategoryEdit">目录管理</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn UPower="ArticleEdit" DPower="ArticleDelete" Width="100" Fixed="right"></EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="200" Sortable="true"></EleColumn>
            <EleColumn For="Item.Category.Name" Label="目录" Width="120"></EleColumn>
            <EleColumn For="Item.CommentCount" Label="评论数" Width="80"></EleColumn>
            <EleColumn For="Item.AllowComment" Label="允许评论" Width="80" Format="@ColumnFormat.Switch"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="200" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

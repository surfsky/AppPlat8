@page
@model App.Pages.GIS.SceneMenusModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "场景图层关联";
}

@section body {
    <div id="app" class="h-full flex flex-col p-4 bg-white overflow-hidden">
        <div class="flex-1 overflow-auto border border-slate-200 rounded p-2 mb-4">
            <el-tree
                ref="tree"
                :data="menus"
                show-checkbox
                node-key="id"
                default-expand-all
                :props="defaultProps">
            </el-tree>
        </div>
        <div class="flex justify-center pt-1">
            <el-button type="primary" @@click="save" :loading="saving">保存</el-button>
        </div>
    </div>
}

@section script {
    <script>
        const app = Vue.createApp({
            data() {
                return {
                    menus: [],
                    checkedIds: [],
                    saving: false,
                    defaultProps: {
                        children: 'children',
                        label: 'name'
                    }
                }
            },
            mounted() {
                this.loadData();
            },
            methods: {
                async loadData() {
                    const res = await axios.get('?handler=Data&sceneId=@Model.SceneId');
                    if (res.data.code === 0) {
                        this.menus = res.data.data.menus;
                        this.checkedIds = res.data.data.checkedIds;
                        this.$nextTick(() => {
                            this.$refs.tree.setCheckedKeys(this.checkedIds);
                        });
                    }
                },
                async save() {
                    this.saving = true;
                    try {
                        // 仅保存真正勾选的节点，避免半选父节点被持久化后，
                        // 下次回填时把整个目录错误地恢复为“已选中”。
                        const checkedKeys = this.$refs.tree.getCheckedKeys(false);

                        const res = await axios.post('?handler=Save&sceneId=@Model.SceneId', checkedKeys, {
                            headers: {
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            }
                        });
                        if (res.data.code === 0) {
                            this.$message.success('保存成功');
                            setTimeout(() => {
                                this.close();
                            }, 300);
                        } else {
                            this.$message.error(res.data.msg);
                        }
                    } catch (err) {
                        this.$message.error('请求失败');
                    } finally {
                        this.saving = false;
                    }
                },
                close() {
                    const manager = (window.top && window.top.EleManager) ? window.top.EleManager : window.EleManager;
                    if (manager && typeof manager.closeDrawer === 'function') {
                        manager.closeDrawer();
                    }
                }
            }
        });
        app.use(ElementPlus);
        app.mount('#app');
    </script>
}

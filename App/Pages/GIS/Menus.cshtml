@page
@model App.Pages.GIS.MenusModel
@{
    ViewData["Title"] = "GIS菜单管理";
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="GIS菜单管理" FormPage="MenuForm" EnableBatch="false" RowKey="id">
        <Toolbar>
            <Buttons>
                <EleButton Type="Primary" Command="Add" Icon="Plus" Width="120px">新增菜单</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleOpColumn Width="100">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.GisGeometryEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.GisGeometryDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Width="220"></EleColumn>
            <EleImageColumn For="Item.Icon" Label="图标" Width="70" ThumbnailWidth="28" ThumbnailHeight="28"></EleImageColumn>
            <EleColumn For="Item.Id" Label="ID" Width="100"></EleColumn>
            <EleColumn For="Item.SortId" Label="排序" Width="90"></EleColumn>
            <EleColumn For="Item.IsDefaultShow" Label="默认显示" Width="100"></EleColumn>
            <EleColumn For="Item.DataCnt" Label="点位数" Width="90"></EleColumn>
            <EleColumn For="Item.DataDt" Label="最后数据时间" Width="180" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
            <EleColumn For="Item.OrgName" Label="责任组织"></EleColumn>
        </Columns>
    </EleTable>
}

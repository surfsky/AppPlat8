@page
@model App.Pages.GIS.ApisModel
@{
    ViewData["Title"] = "GIS接口管理";
    var queryMenuId = Request.Query["menuId"].ToString();
    var formPageUrl = string.IsNullOrWhiteSpace(queryMenuId)
        ? "/GIS/ApiForm"
        : $"/GIS/ApiForm?menuId={queryMenuId}";
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="GIS接口" FormPage="@formPageUrl" EnableBatch="true">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Width="220px" Label="名称"></EleInput>
                <EleTreeSelect For="Item.MenuId" Width="240px" Label="所属菜单" Api="/httpapi/gis/GetMenuTree?selectedId=@queryMenuId" Clearable="true" CheckStrictly="true"></EleTreeSelect>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">删除</EleButton>
                <EleButton Type="Success" NavigateUrl="/GIS/ApiData" Icon="View">调试窗口</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit"   Icon="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.GisGeometryEdit)"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.GisGeometryDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" MinWidth="160"></EleColumn>
            <EleColumn For="Item.MenuName" Label="所属菜单" Width="180"></EleColumn>
            <EleColumn For="Item.DataUrl" Label="接口地址" MinWidth="320"></EleColumn>
            <EleColumn For="Item.IsLive" Label="状态" Width="80"></EleColumn>
            <EleColumn For="Item.DataCnt" Label="数据量" Width="90"></EleColumn>
            <EleColumn For="Item.DataDt" Label="更新时间" Width="170" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
            <EleColumn For="Item.LastErr" Label="最近错误" MinWidth="220"></EleColumn>
            <EleColumn For="Item.SortId" Label="排序" Width="80"></EleColumn>
        </Columns>
    </EleTable>
}

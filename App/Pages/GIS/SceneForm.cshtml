@page
@model App.Pages.GIS.SceneFormModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "GIS场景信息";
}

@section body {
    <EleForm>
        <EleIconPicker For="Item.Icon" Label="图标" FillRow="true" Popup="/Shared/IconSelector" ></EleIconPicker>
        <EleInput For="Item.Id" Label="ID" Enabled="false"></EleInput>
        <EleNumber For="Item.SortId" Label="排序" Min="0" Max="9999"></EleNumber>
        <EleInput For="Item.Name" Label="名称" Required="true"></EleInput>
        <EleInput For="Item.Desc" Label="描述" Rows="1" FillRow="false"></EleInput>
        <EleNumber For="Item.MapZoom" Label="地图缩放级别" Min="1" Max="20"></EleNumber>
        <ElePicker For="Item.MapCenter" TextFor="Item.MapCenter" Label="地图中心坐标" PopupUrl="Locator" Icon="Location" Editable="true" Placeholder="lng, lat"></ElePicker>
        <EleNumber For="Item.MapPitch" Label="地图倾斜角" Min="0" Max="85"></EleNumber>
        <EleSelect For="Item.MapStyle" Label="地图样式" Items="Model.Styles"></EleSelect>
        <EleSelect For="Item.MapProjection" Label="地图投影" ></EleSelect>
        <EleSwitch For="Item.Map3D" Label="启用3D"></EleSwitch>
        <EleSwitch For="Item.AutoRotate" Label="自动旋转"></EleSwitch>
        
        <Bottom>
            <EleButton Type="Primary" Command="SaveClose" Visible="@(Model.Mode != PageMode.View)">保存</EleButton>
            <EleButton Command="Close">关闭</EleButton>
        </Bottom>
    </EleForm>
}

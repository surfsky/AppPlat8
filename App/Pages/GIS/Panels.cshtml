@page
@model App.Pages.GIS.PanelsModel
@{
    ViewData["Title"] = "统计面板管理";
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="统计面板" FormPage="PanelForm" EnableBatch="true">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Title" Width="220px" Label="标题"></EleInput>
                <EleSelect For="Item.InGis" Width="180px" Label="GIS显示" Clearable="true"></EleSelect>
                <EleSelect For="Item.InDashboard" Width="200px" Label="Dashboard显示" Clearable="true"></EleSelect>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus" Visible="@Auth.CheckPower(Power.GisGeometryEdit)">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="@Auth.CheckPower(Power.GisGeometryDelete)">删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit"   Icon="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.GisGeometryEdit)"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.GisGeometryDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Title" Label="标题" Link="true" MinWidth="180" Sortable="true"></EleColumn>
            <EleColumn For="Item.Info" Label="提示信息" MinWidth="220"></EleColumn>
            <EleColumn For="Item.Position" Label="位置/排序" Width="110" Sortable="true"></EleColumn>
            <EleColumn For="Item.InGis" Label="GIS显示" Width="110" Format="Switch"></EleColumn>
            <EleColumn For="Item.InDashboard" Label="Dashboard显示" Width="130" Format="Switch"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="180" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
            <EleColumn For="Item.UpdateDt" Label="更新时间" Width="180" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

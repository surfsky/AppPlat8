@section body {
    <div id="map"></div>

    <div class="header-bar">
        <div class="header-title">
            <span>应急驾驶舱</span>
        </div>
        <span id="header-datetime" class="header-datetime" aria-label="当前日期时间"></span>
    </div>

    <div class="map-toolbar">
        <input id="address-input" class="toolbar-input" placeholder="搜索地址或经纬度，如：120.62915,27.517297" />
        <button id="btn-search" class="toolbar-btn toolbar-icon-btn" title="搜索" aria-label="搜索">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
        <div id="address-suggest-list" class="address-suggest-list"></div>
    </div>

    <div class="floating-toggle-group">
        <button id="btn-layer-toggle" class="floating-toggle" aria-label="显示/隐藏图层列表">
            <i class="fa-solid fa-layer-group toggle-icon"></i>
        </button>
        <button id="btn-stats-toggle" class="floating-toggle" aria-label="显示/隐藏统计面板">
            <i class="fa-solid fa-chart-column toggle-icon"></i>
        </button>
        <button id="btn-scene-toggle" class="floating-toggle" aria-label="切换场景">
            <i class="fa-solid fa-mountain-sun toggle-icon"></i>
        </button>
    </div>
    <div class="floating-toggle-group floating-toggle-group-right">
        <button id="btn-site-toggle" class="floating-toggle" aria-label="显示参考网站">
            <i class="fa-solid fa-globe toggle-icon"></i>
        </button>
        <button id="btn-toolbar-toggle" class="floating-toggle" aria-label="显示/隐藏工具栏">
            <i class="fa-solid fa-magnifying-glass toggle-icon"></i>
        </button>
    </div>

    <div id="scene-menu" class="view-menu" style="display:none" aria-label="场景菜单">
    </div>

    <div id="layer-panel" class="panel-left">
        <gis-panel class="layer-gis-panel" title="图层" width="100%" height="100%">
            <div class="layer-tabs" data-panel-actions role="tablist" aria-label="图层分类">
                <button type="button" id="btn-layer-tab-resource" class="layer-tab-btn active" data-tab="resource" role="tab" aria-selected="true">资源</button>
                <button type="button" id="btn-layer-tab-view" class="layer-tab-btn" data-tab="view" role="tab" aria-selected="false">视图</button>
                <button type="button" id="btn-layer-tab-weather" class="layer-tab-btn" data-tab="weather" role="tab" aria-selected="false">图层</button>
                <button type="button" id="btn-layer-tab-iot" class="layer-tab-btn" data-tab="iot" role="tab" aria-selected="false">物联</button>
            </div>
            <div class="layer-tab-panels">
                <div id="layer-tab-panel-resource" class="layer-tab-panel active" data-tab-panel="resource" role="tabpanel">
                    <div class="layer-tree">
                        <div id="menu-tree" class="menu-tree-wrap"></div>
                    </div>
                </div>
                <div id="layer-tab-panel-view" class="layer-tab-panel" data-tab-panel="view" role="tabpanel" aria-hidden="true">
                    <div class="layer-view-panel">
                        <div class="view-menu-section-title">底图样式</div>
                        <div id="view-style-list" class="view-menu-options" role="radiogroup" aria-label="底图样式"></div>
                        <div class="view-menu-divider" role="separator"></div>
                        <div class="view-menu-section-title">地图投影</div>
                        <div id="view-projection-list" class="view-menu-options" role="radiogroup" aria-label="投影方式"></div>
                        <div class="view-menu-divider" role="separator"></div>
                        <label class="view-menu-option view-menu-checkbox">
                            <input type="checkbox" id="btn-toggle-3d">
                            <span>3D地形</span>
                        </label>
                        <label class="view-menu-option view-menu-checkbox">
                            <input type="checkbox" id="btn-toggle-rotate">
                            <span>自动旋转</span>
                        </label>
                    </div>
                </div>
                <div id="layer-tab-panel-weather" class="layer-tab-panel" data-tab-panel="weather" role="tabpanel" aria-hidden="true">
                    <div id="view-overlay-menu" class="view-overlay-menu layer-overlay-menu" aria-label="气象图层菜单"></div>
                </div>
                <div id="layer-tab-panel-iot" class="layer-tab-panel" data-tab-panel="iot" role="tabpanel" aria-hidden="true">
                    <div class="layer-empty">物联设备图层待接入</div>
                </div>
            </div>
        </gis-panel>
        <div id="layer-panel-resize-handle" class="layer-panel-resize-handle" aria-hidden="true"></div>
    </div>

    <div id="stats-overlay" class="stats-overlay" aria-label="统计面板">
        <div id="stats-column-left" class="stats-column stats-column-left">
            <div class="stats-column-scroll"></div>
            <div class="stats-scroll-hint" aria-hidden="true"><i class="fa-solid fa-angle-down"></i></div>
        </div>
        <div id="stats-column-right" class="stats-column stats-column-right">
            <div class="stats-column-scroll"></div>
            <div class="stats-scroll-hint" aria-hidden="true"><i class="fa-solid fa-angle-down"></i></div>
        </div>
    </div>

    <div id="geo-detail-panel" class="geo-detail-panel" aria-label="图形详情">
        <gis-panel id="geo-detail-gis-panel" class="geo-detail-gis-panel" title="点位信息" width="100%" height="100%" closable="true" close-label="关闭">
            <div data-panel-actions>
                @if (Auth.CheckPower(Power.GisGeometryEdit))
                {
                    <button class="gis-panel-close" type="button" title="编辑" aria-label="编辑" data-panel-edit-geometry>
                        <i class="fa-regular fa-pen-to-square"></i>
                    </button>
                }
            </div>
            <div id="geo-detail-body" class="geo-detail-body">请选择图形</div>
        </gis-panel>
    </div>

    <div id="geo-point-list-panel" class="geo-detail-panel geo-point-list-panel" aria-label="点位清单">
        <gis-panel id="geo-point-list-gis-panel" class="geo-detail-gis-panel" title="点位清单" width="100%" height="100%" closable="true" close-label="关闭">
            <div id="geo-point-list-body" class="geo-detail-body">请选择图层节点</div>
        </gis-panel>
    </div>
}

@section script {
    <script>
        mapboxgl.accessToken = "@SiteConfig.Instance.MapKey";

        const state = {
            objects: [],
            selectedId: null,
            markerMap: new Map(),
            menus: [],
            menuRoots: [],
            menuNodeMap: new Map(),
            geometries: [],
            geometryPointMarkerMap: new Map(),
            geometryByMenuId: new Map(),
            geometryVisibleMap: new Map(),
            selectedGeometryId: null,
            geometryInteractionBound: false,
            preservedVisibleGeometryIds: new Set(),
            currentStyle: 'street',
            currentProjection: 'mercator',
            is3D: false,
            isAutoRotate: false,
            toolbarCollapsed: true,
            layerCollapsed: true,
            statsMode: false,
            statsPanels: [],
            activePointListMenuId: null,
            activePointListMenuName: '',
            pointListFilterMenuId: null,
            pointListFilterIds: null,
            currentMapZoom: @mapZoom.ToString(CultureInfo.InvariantCulture),
            mapStyles: [],
            scenes: [],
            currentSceneId: null,
            defaultSceneView: {
                center: [@mapCenterLng.ToString(CultureInfo.InvariantCulture), @mapCenterLat.ToString(CultureInfo.InvariantCulture)],
                zoom: @mapZoom.ToString(CultureInfo.InvariantCulture),
                pitch: 0,
                bearing: 0
            },
            currentSceneDetail: null,
            currentSceneView: null,
            sceneMenuOpen: false,
            activeLayerTab: 'resource',
            collapsedMenuIds: new Set()
        };
        const GisIndexUI = window.GisIndexUI;
        const GisIndexData = window.GisIndexData;
        const GisIndexAction = window.GisIndexAction;
        const GisIndexView = window.GisIndexView;
        const GisIndexMap = window.GisIndexMap;
        const GisIndexScene = window.GisIndexScene;
        const GisIndexBootstrap = window.GisIndexBootstrap;
        const GisIndexObject = window.GisIndexObject;
        const GisIndexDetail = window.GisIndexDetail;
        const GisIndexPanels = window.GisIndexPanels;
        const GisIndexPointList = window.GisIndexPointList;
        const pageTheme = (() => {
            try {
                const t = new URLSearchParams(window.location.search || '').get('theme');
                return (t || 'dark').toLowerCase() === 'light' ? 'light' : 'dark';
            } catch {
                return 'dark';
            }
        })();
        function getCsrfToken() {
            const input = document.querySelector('input[name="__RequestVerificationToken"]');
            return input ? input.value : '';
        }


        //--------------------------------------------------------------
        // 地图基础设置
        //--------------------------------------------------------------
        // map
        let geometryLayerManager = null;
        const terrainSourceId = 'mapbox-dem';
        const geometryDisplayLayerIds = [
            'gis-geometry-fill-layer',
            'gis-geometry-line-layer',
            'gis-geometry-point-layer',
            'gis-geometry-label-layer',
            'gis-geometry-line-label-layer'
        ];
        const map = new mapboxgl.Map({
            container: 'map',
            style: 'mapbox://styles/mapbox/streets-v11',
            center: [@mapCenterLng.ToString(CultureInfo.InvariantCulture), @mapCenterLat.ToString(CultureInfo.InvariantCulture)],
            zoom: @mapZoom.ToString(CultureInfo.InvariantCulture),
            pitch: 0,
            projection: 'mercator',
            attributionControl: false,
            localIdeographFontFamily: "'Microsoft YaHei','PingFang SC','Hiragino Sans GB','Noto Sans CJK SC',sans-serif"
        });

        //---------------------------------------------------------------
        // APIs
        //---------------------------------------------------------------
        const dataApi = GisIndexData.create({
            state,
            map,
            getGeometryLayerManager: () => geometryLayerManager,
            onGeometryMarkerClick: (id, evt) => showGeometryDetail(id, evt),
            onMenuBadgeClick: (menuNode, geometryItems) => openPointListPanel(menuNode, geometryItems)
        });
        const actionApi = GisIndexAction.create({
            map,
            state,
            geometryDisplayLayerIds,
            isGeometrySelectable: (menuId) => dataApi.isGeometrySelectable(menuId),
            onOpenGeometryDetail: (id) => openGeometryDetailPanel(id),
            onCloseGeometryDetail: () => closeGeometryDetailPanel(),
            onClosePointList: () => closePointListPanel(),
            onGeometryEdited: () => refreshGeometryViews(),
            onGeometrySelectedChanged: () => syncGeometryPointMarkerVisibility(),
            onStatsModeChanged: () => {
                setTimeout(() => panelApi.resizeCharts(), 260);
            }
        });
        const viewApi = GisIndexView.create({
            map,
            state,
            terrainSourceId,
            closeViewMenu: () => {}
        });
        const mapApi = GisIndexMap.create({
            map,
            center: [@mapCenterLng.ToString(CultureInfo.InvariantCulture), @mapCenterLat.ToString(CultureInfo.InvariantCulture)],
            zoom: @mapZoom.ToString(CultureInfo.InvariantCulture)
        });
        const objectApi = GisIndexObject.create({
            map,
            state,
            onOpenDetail: (id) => openCheckObjectDrawer(id)
        });
        const detailApi = GisIndexDetail.create({
            panelId: 'geo-detail-panel',
            bodyId: 'geo-detail-body',
            endpointBuilder: (id) => `?handler=GeometryDetail&id=${encodeURIComponent(id)}`
        });
        const pointListApi = GisIndexPointList.create({
            panelId: 'geo-point-list-panel',
            panelComponentId: 'geo-point-list-gis-panel',
            bodyId: 'geo-point-list-body',
            map,
            state,
            onLoadMenuItems: async ({ menuId, keyword, isVisible, pageIndex, pageSize }) => {
                const q = new URLSearchParams();
                q.set('handler', 'MenuItems');
                q.set('menuId', menuId);
                q.set('pageIndex', pageIndex ?? 0);
                q.set('pageSize', pageSize ?? 20);
                if (keyword) q.set('keyword', keyword);
                if (isVisible !== undefined && isVisible !== null && String(isVisible) !== '') q.set('isVisible', isVisible);

                const resp = await fetch(`?${q.toString()}`);
                if (!resp.ok) {
                    const msg = `加载点位失败(${resp.status})`;
                    return { code: -1, message: msg };
                }
                return await resp.json();
            },
            onRefreshMenuData: async (menuId) => {
                const resp = await fetch('?handler=RefreshMenuData', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getCsrfToken()
                    },
                    body: JSON.stringify({ menuId })
                });

                if (!resp.ok) {
                    const msg = `刷新失败(${resp.status})`;
                    if (window.EleManager && typeof window.EleManager.showError === 'function') {
                        window.EleManager.showError(msg);
                    }
                    return { code: -1, message: msg };
                }

                const res = await resp.json();
                const code = res?.code ?? res?.Code ?? -1;
                if (code !== 0) {
                    const msg = res?.message || res?.msg || '刷新失败';
                    if (window.EleManager && typeof window.EleManager.showError === 'function') {
                        window.EleManager.showError(msg);
                    }
                    return { code, message: msg };
                }

                await loadMenus();
                await loadGeometries();

                if (window.EleManager && typeof window.EleManager.showSuccess === 'function') {
                    const data = res?.data || res?.Data || {};
                    window.EleManager.showSuccess(`刷新完成：成功${data.okCount ?? 0}，失败${data.failCount ?? 0}`);
                }

                return { code: 0, data: res?.data ?? res?.Data };
            },
            onItemsChanged: ({ menuId, mapIds }) => {
                const hasMenuId = menuId !== null && menuId !== undefined && menuId !== '';
                state.pointListFilterMenuId = hasMenuId ? Number(menuId) : null;
                state.pointListFilterIds = Array.isArray(mapIds)
                    ? new Set(mapIds.map(id => String(id)))
                    : null;
                if (dataApi && typeof dataApi.applyGeometryVisibility === 'function') {
                    dataApi.applyGeometryVisibility();
                }
            },
            onOpenDetail: (id) => showGeometryDetail(id),
            onClose: ({ preserveFilter } = {}) => {
                if (preserveFilter) return;
                state.pointListFilterMenuId = null;
                state.pointListFilterIds = null;
                if (dataApi && typeof dataApi.applyGeometryVisibility === 'function') {
                    dataApi.applyGeometryVisibility();
                }
            }
        });
        const panelApi = GisIndexPanels.create({
            state,
            theme: pageTheme
        });
        const sceneApi = GisIndexScene.create({
            state,
            map,
            viewApi,
            dataApi,
            panelApi,
            closeGeometryDetailPanel: () => closeGeometryDetailPanel(),
            closePointListPanel: () => closePointListPanel({ preserveFilter: false })
        });
        const bootstrapApi = GisIndexBootstrap.create({
            map,
            state,
            mapApi,
            viewApi,
            objectApi,
            panelApi,
            getGeometryLayerManager: () => geometryLayerManager,
            getGeometryRowsForDisplay: () => dataApi.getGeometryRowsForLayerRender(),
            createGeometryLayerManager: () => {
                geometryLayerManager = window.MapGeometryHelper.createDisplayLayerManager({
                    map,
                    sourceId: 'gis-geometry-source',
                    layerPrefix: 'gis-geometry'
                });
                return geometryLayerManager;
            },
            bindGeometryMapInteractions: () => bindGeometryMapInteractions(),
            loadMapStyles: () => loadMapStyles(),
            loadScenes: () => loadScenes(),
            loadMenus: () => loadMenus(),
            loadGeometries: () => loadGeometries(),
            applyGeometryVisibility: () => applyGeometryVisibility(),
            renderMenuTree: () => renderMenuTree(),
            searchAddress: () => searchAddress(),
            resetView: () => resetView(),
            toggleSceneMenu: () => toggleSceneMenu(),
            closeSceneMenu: () => closeSceneMenu(),
            toggleViewMenu: () => toggleViewMenu(),
            closeViewMenu: () => closeViewMenu(),
            toggleToolbar: () => toggleToolbar(),
            toggleLayerPanel: () => toggleLayerPanel(),
            toggleStatsMode: () => toggleStatsMode(),
            switchLayerTab: tab => switchLayerTab(tab),
            syncToolbarUI: () => syncToolbarUI(),
            syncLayerPanelUI: () => syncLayerPanelUI(),
            syncLayerTabsUI: () => syncLayerTabsUI(),
            syncViewMenuUI: () => syncViewMenuUI(),
            syncStatsModeUI: () => syncStatsModeUI(),
            closeGeometryDetailDrawer: () => closeGeometryDetailDrawer(),
            closePointListPanel: () => closePointListPanel(),
            openGeometryEditDrawer: () => actionApi.openGeometryEditDrawer()
        });

        /**同步菜单缩放显示*/
        function syncMenuZoomDisplay() {
            state.currentMapZoom = typeof map.getZoom === 'function' ? map.getZoom() : state.currentMapZoom;
            dataApi.applyGeometryVisibility();
            dataApi.renderMenuTree();
        }

        map.on('zoomend', syncMenuZoomDisplay);
        window.__gisIndexContext = {
            map,
            state,
            dataApi,
            actionApi,
            viewApi,
            sceneApi,
            bootstrapApi,
            mapApi,
            panelApi,
            closeViewMenu: () => closeViewMenu()
        };
        bootstrapApi.initialize();

        async function refreshGeometryViews() {
            await loadGeometries();
            rebuildGeometryPointMarkers();
            applyGeometryVisibility();
            syncGeometryPointMarkerVisibility();
            renderMenuTree();

            const detailPanel = document.getElementById('geo-detail-panel');
            if (detailPanel && detailPanel.classList.contains('open') && state.selectedGeometryId) {
                detailApi.reload();
            }

            const pointListPanel = document.getElementById('geo-point-list-panel');
            if (pointListPanel && pointListPanel.classList.contains('open') && state.activePointListMenuId) {
                const keyNum = Number(state.activePointListMenuId);
                const menuNode = state.menuNodeMap.get(state.activePointListMenuId)
                    || state.menuNodeMap.get(keyNum)
                    || null;
                if (menuNode) {
                    pointListApi.open(menuNode);
                }
            }
        }

        window.addEventListener('message', e => {
            const payload = e?.data;
            if (!payload || typeof payload !== 'object') return;
            if (payload.__eleRefreshData === true) {
                refreshGeometryViews();
            }
        });

        //---------------------------------------------------------------
        // 样式与视图
        //---------------------------------------------------------------
        function switchStyle(type) { viewApi.switchStyle(type); }
        function resetView() { sceneApi.resetCurrentSceneView(); }
        async function searchAddress() { return mapApi.searchAddress(); }

        //--------------------------------------------------------------
        // 工具栏和视图控制（拆分至 /gis/gis-index-ui.js）
        //--------------------------------------------------------------
        function toggleToolbar() { GisIndexUI.toggleToolbar(state); }
        function syncToolbarUI() { GisIndexUI.syncToolbarUI(state); }
        function toggleLayerPanel() { GisIndexUI.toggleLayerPanel(state);}
        function syncLayerPanelUI() { GisIndexUI.syncLayerPanelUI(state); }
        function switchLayerTab(tab) { GisIndexUI.switchLayerTab(state, tab); }
        function syncLayerTabsUI() { GisIndexUI.syncLayerTabsUI(state); }
        function toggleViewMenu() { GisIndexUI.toggleViewMenu(state); }
        function closeViewMenu() { GisIndexUI.closeViewMenu(state); }
        function syncViewMenuUI() { GisIndexUI.syncViewMenuUI(state); }
        function syncStatsModeUI() { GisIndexUI.syncStatsModeUI(state); }
        function toggleStatsMode() { actionApi.toggleStatsMode(); }

        //--------------------------------------------------------------
        // 检查对象相关
        //--------------------------------------------------------------
        /** 打开检查对象详情抽屉*/
        function openCheckObjectDrawer(id) { actionApi.openCheckObjectDrawer(id); }
        function selectObject(item, openDrawer = true) { return objectApi.selectObject(item, openDrawer); }
        async function loadObjects() { return objectApi.loadObjects(); }
        function buildMarkers(items) { return objectApi.buildMarkers(items); }
        function setLayerVisible(visible) { return objectApi.setLayerVisible(visible); }

        //--------------------------------------------------------------
        // 图形详情面板
        //--------------------------------------------------------------
        function openGeometryDetailPanel(id) {
            return detailApi.open(id);
        }
        function closeGeometryDetailPanel() { return detailApi.close(); }
        function openPointListPanel(menuNode, geometryItems) {
            closeGeometryDetailPanel();
            return pointListApi.open(menuNode, geometryItems);
        }
        function closePointListPanel(options) { return pointListApi.close(options); }


        //--------------------------------------------------------------
        // 菜单树
        //--------------------------------------------------------------
        function buildMenuNodes() { return dataApi.buildMenuNodes(); }
        function renderMenuTree() { return dataApi.renderMenuTree(); }
        function renderViewStyleMenu() { return sceneApi.renderViewStyleMenu(); }
        async function loadMapStyles() { return sceneApi.loadMapStyles(); }
        async function loadScenes() { return sceneApi.loadScenes(); }
        async function switchScene(scene) { return sceneApi.switchScene(scene); }
        async function loadMenus() { return dataApi.loadMenus();}
        function toggleSceneMenu() { return sceneApi.toggleSceneMenu(); }
        function closeSceneMenu() { return sceneApi.closeSceneMenu(); }
        function applyGeometryVisibility() { return dataApi.applyGeometryVisibility(); }
        function rebuildGeometryPointMarkers() { return dataApi.rebuildGeometryPointMarkers(); }
        function syncGeometryPointMarkerVisibility() { return dataApi.syncGeometryPointMarkerVisibility(); }
        function getActiveGeometryDisplayLayerIds() { return actionApi.getActiveGeometryDisplayLayerIds(); }
        async function loadGeometries() { return dataApi.loadGeometries(); }

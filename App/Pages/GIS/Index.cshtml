@page
@model App.Pages.GIS.IndexModel
@using System.Globalization
@{
    Layout = "_Layout";
    ViewData["Title"] = "数据驾驶舱";

    // 地图中心和缩放级别
    var mapZoom = SiteConfig.Instance.MapZoom > 0 ? SiteConfig.Instance.MapZoom : 11;
    var mapCenterText = (SiteConfig.Instance.MapCenter ?? string.Empty).Replace("，", ",").Trim();
    var mapCenterLng = 120.6034;
    var mapCenterLat = 27.5686;
    if (!string.IsNullOrWhiteSpace(mapCenterText))
    {
        var parts = mapCenterText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length >= 2
            && double.TryParse(parts[0], NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedLng)
            && double.TryParse(parts[1], NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedLat))
        {
            mapCenterLng = parsedLng;
            mapCenterLat = parsedLat;
        }
    }
}

@section head {
    <script src='https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.js'></script>
    <link href='https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.css' rel='stylesheet' />
    <script src="/js/echarts.min.js"></script>
    <link rel="stylesheet" href="/gis/gis-index.css?v=@DateTime.Now.Ticks" />
    <script src="/gis/maphelper.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-chart-helper.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-panels.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-point-list.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-public-cameras.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-data.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-action.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-map.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-object.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-detail.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-panel-element.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-ui.js?v=@DateTime.Now.Ticks"></script>
    <script type="module" src="/gis/gis-index-overlays.js?v=@DateTime.Now.Ticks"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
}

@section body {
    <div id="map"></div>

    <div class="header-bar">
        <div class="header-title">
            <span>应急驾驶舱</span>
        </div>
        <span id="header-datetime" class="header-datetime" aria-label="当前日期时间"></span>
    </div>

    <div class="map-toolbar">
        <input id="address-input" class="toolbar-input" placeholder="搜索地址，如：杭州西湖" />
        <button id="btn-search" class="toolbar-btn">查找</button>
        <div id="address-suggest-list" class="address-suggest-list"></div>
    </div>

    <div class="floating-toggle-group">
        <button id="btn-layer-toggle" class="floating-toggle" title="图层" aria-label="显示/隐藏图层列表">
            <i class="fa-solid fa-layer-group toggle-icon"></i>
        </button>
        <button id="btn-stats-toggle" class="floating-toggle" title="统计" aria-label="显示/隐藏统计面板">
            <i class="fa-solid fa-chart-column toggle-icon"></i>
        </button>
        <button id="btn-scene-toggle" class="floating-toggle" title="场景" aria-label="切换场景">
            <i class="fa-solid fa-mountain-sun toggle-icon"></i>
        </button>
        <button id="btn-view-toggle" class="floating-toggle" title="视图" aria-label="显示/隐藏视图工具栏">
            <i class="fa-solid fa-eye toggle-icon"></i>
        </button>
        <button id="btn-toolbar-toggle" class="floating-toggle" title="工具栏" aria-label="显示/隐藏工具栏">
            <i class="fa-solid fa-magnifying-glass toggle-icon"></i>
        </button>
    </div>
    <div id="view-menu" class="view-menu" aria-label="视图菜单">
        <div id="view-style-list"></div>
        <div class="view-menu-section-title">---------------</div>
        <button id="btn-toggle-3d" class="view-menu-item">3D地形</button>
    </div>

    <div id="scene-menu" class="view-menu" style="left: 60px; top: 10px; display:none" aria-label="场景菜单">
    </div>

    <div id="layer-panel" class="panel-left">
        <gis-panel class="layer-gis-panel" title="图层" width="100%" height="100%">
            <div class="layer-tabs" data-panel-actions role="tablist" aria-label="图层分类">
                <button type="button" id="btn-layer-tab-resource" class="layer-tab-btn active" data-tab="resource" role="tab" aria-selected="true">资源</button>
                <button type="button" id="btn-layer-tab-weather" class="layer-tab-btn" data-tab="weather" role="tab" aria-selected="false">气象</button>
                <button type="button" id="btn-layer-tab-iot" class="layer-tab-btn" data-tab="iot" role="tab" aria-selected="false">物联设备</button>
            </div>
            <div class="layer-tab-panels">
                <div id="layer-tab-panel-resource" class="layer-tab-panel active" data-tab-panel="resource" role="tabpanel">
                    <div class="layer-tree">
                        <div id="menu-tree" class="menu-tree-wrap"></div>
                    </div>
                </div>
                <div id="layer-tab-panel-weather" class="layer-tab-panel" data-tab-panel="weather" role="tabpanel" aria-hidden="true">
                    <div id="view-overlay-menu" class="view-overlay-menu layer-overlay-menu" aria-label="气象图层菜单"></div>
                </div>
                <div id="layer-tab-panel-iot" class="layer-tab-panel" data-tab-panel="iot" role="tabpanel" aria-hidden="true">
                    <div class="layer-empty">物联设备图层待接入</div>
                </div>
            </div>
        </gis-panel>
    </div>

    <div id="stats-overlay" class="stats-overlay" aria-label="统计面板">
        <div id="stats-column-left" class="stats-column stats-column-left"></div>
        <div id="stats-column-right" class="stats-column stats-column-right"></div>
    </div>

    <div id="geo-detail-panel" class="geo-detail-panel" aria-label="图形详情">
        <gis-panel id="geo-detail-gis-panel" class="geo-detail-gis-panel" title="点位信息" width="100%" height="100%" closable="true" close-label="关闭">
            <div id="geo-detail-body" class="geo-detail-body">请选择图形</div>
        </gis-panel>
    </div>

    <div id="geo-point-list-panel" class="geo-detail-panel geo-point-list-panel" aria-label="点位清单">
        <gis-panel id="geo-point-list-gis-panel" class="geo-detail-gis-panel" title="点位清单" width="100%" height="100%" closable="true" close-label="关闭">
            <div id="geo-point-list-body" class="geo-detail-body">请选择图层节点</div>
        </gis-panel>
    </div>
}

@section script {
    <script>
        mapboxgl.accessToken = "@SiteConfig.Instance.MapKey";

        const state = {
            objects: [],
            selectedId: null,
            markerMap: new Map(),
            menus: [],
            menuRoots: [],
            menuNodeMap: new Map(),
            geometries: [],
            geometryPointMarkerMap: new Map(),
            geometryByMenuId: new Map(),
            geometryVisibleMap: new Map(),
            selectedGeometryId: null,
            geometryInteractionBound: false,
            preservedVisibleGeometryIds: new Set(),
            currentStyle: 'street',
            currentProjection: 'mercator',
            is3D: false,
            toolbarCollapsed: true,
            layerCollapsed: false,
            viewMenuOpen: false,
            statsMode: false,
            statsPanels: [],
            activePointListMenuId: null,
            activePointListMenuName: '',
            mapStyles: [],
            scenes: [],
            currentSceneId: null,
            sceneMenuOpen: false,
            activeLayerTab: 'resource',
            collapsedMenuIds: new Set()
        };
        const GisIndexUI = window.GisIndexUI;
        const GisIndexData = window.GisIndexData;
        const GisIndexAction = window.GisIndexAction;
        const GisIndexMap = window.GisIndexMap;
        const GisIndexObject = window.GisIndexObject;
        const GisIndexDetail = window.GisIndexDetail;
        const GisIndexPanels = window.GisIndexPanels;
        const GisIndexPointList = window.GisIndexPointList;
        const pageTheme = (() => {
            try {
                const t = new URLSearchParams(window.location.search || '').get('theme');
                return (t || 'dark').toLowerCase() === 'light' ? 'light' : 'dark';
            } catch {
                return 'dark';
            }
        })();


        //--------------------------------------------------------------
        // 地图基础设置
        //--------------------------------------------------------------
        // map
        let geometryLayerManager = null;
        const terrainSourceId = 'mapbox-dem';
        const geometryDisplayLayerIds = [
            'gis-geometry-fill-layer',
            'gis-geometry-line-layer',
            'gis-geometry-point-layer',
            'gis-geometry-label-layer',
            'gis-geometry-line-label-layer'
        ];
        const map = new mapboxgl.Map({
            container: 'map',
            style: 'mapbox://styles/mapbox/streets-v11',
            center: [@mapCenterLng.ToString(CultureInfo.InvariantCulture), @mapCenterLat.ToString(CultureInfo.InvariantCulture)],
            zoom: @mapZoom.ToString(CultureInfo.InvariantCulture),
            pitch: 0,
            projection: 'mercator',
            attributionControl: false
        });
        const dataApi = GisIndexData.create({
            state,
            map,
            getGeometryLayerManager: () => geometryLayerManager,
            onGeometryMarkerClick: (id) => openGeometryDetailDrawer(id),
            onMenuBadgeClick: (menuNode, geometryItems) => openPointListPanel(menuNode, geometryItems)
        });
        const actionApi = GisIndexAction.create({
            map,
            state,
            geometryDisplayLayerIds,
            onOpenGeometryDetail: (id) => openGeometryDetailPanel(id),
            onCloseGeometryDetail: () => closeGeometryDetailPanel(),
            onClosePointList: () => closePointListPanel(),
            onGeometrySelectedChanged: () => syncGeometryPointMarkerVisibility(),
            onStatsModeChanged: () => {
                setTimeout(() => panelApi.resizeCharts(), 260);
            }
        });
        const mapApi = GisIndexMap.create({
            map,
            state,
            terrainSourceId,
            center: [@mapCenterLng.ToString(CultureInfo.InvariantCulture), @mapCenterLat.ToString(CultureInfo.InvariantCulture)],
            zoom: @mapZoom.ToString(CultureInfo.InvariantCulture),
            closeViewMenu: () => closeViewMenu()
        });
        const objectApi = GisIndexObject.create({
            map,
            state,
            onOpenDetail: (id) => openCheckObjectDrawer(id)
        });
        const detailApi = GisIndexDetail.create({
            panelId: 'geo-detail-panel',
            bodyId: 'geo-detail-body',
            endpointBuilder: (id) => `?handler=GeometryDetail&id=${encodeURIComponent(id)}`
        });
        const pointListApi = GisIndexPointList.create({
            panelId: 'geo-point-list-panel',
            panelComponentId: 'geo-point-list-gis-panel',
            bodyId: 'geo-point-list-body',
            map,
            state,
            onRefreshMenuData: async (menuId) => {
                const resp = await fetch('?handler=RefreshMenuData', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ menuId })
                });

                if (!resp.ok) {
                    const msg = `刷新失败(${resp.status})`;
                    if (window.EleManager && typeof window.EleManager.showError === 'function') {
                        window.EleManager.showError(msg);
                    }
                    return { code: -1, message: msg };
                }

                const res = await resp.json();
                const code = res?.code ?? res?.Code ?? -1;
                if (code !== 0) {
                    const msg = res?.message || res?.msg || '刷新失败';
                    if (window.EleManager && typeof window.EleManager.showError === 'function') {
                        window.EleManager.showError(msg);
                    }
                    return { code, message: msg };
                }

                await loadMenus();
                await loadGeometries();

                if (window.EleManager && typeof window.EleManager.showSuccess === 'function') {
                    const data = res?.data || res?.Data || {};
                    window.EleManager.showSuccess(`刷新完成：成功${data.okCount ?? 0}，失败${data.failCount ?? 0}`);
                }

                return { code: 0, data: res?.data ?? res?.Data };
            }
        });
        const panelApi = GisIndexPanels.create({
            state,
            theme: pageTheme
        });
        window.__gisIndexContext = {
            map,
            state,
            dataApi,
            actionApi,
            mapApi,
            panelApi,
            closeViewMenu: () => closeViewMenu()
        };

        // 添加地图控件
        map.addControl(new mapboxgl.NavigationControl(), 'top-right');
        map.addControl(new mapboxgl.GeolocateControl({
            positionOptions: { enableHighAccuracy: true },
            trackUserLocation: true,
            showUserHeading: true
        }), 'top-right');
        map.addControl(new mapboxgl.ScaleControl({ unit: 'metric' }), 'bottom-left');
        map.addControl(new mapboxgl.AttributionControl({ compact: true }), 'bottom-right');
        const centerCoordControl = mapApi.createCenterCoordControl();
        map.addControl(centerCoordControl, 'bottom-right');
        map.addControl(mapApi.createResetControl(resetView), 'top-right');
        map.addControl(new mapboxgl.FullscreenControl({ container: document.documentElement }), 'top-right');

        // 地图事件
        map.on('move', () => centerCoordControl.update());
        map.on('load', async () => {
            const mapHelperReady = await mapApi.ensureMapGeometryHelperReady();
            if (!mapHelperReady) {
                EleManager.showError('地图图形组件加载失败');
                return;
            }
            geometryLayerManager = window.MapGeometryHelper.createDisplayLayerManager({
                map,
                sourceId: 'gis-geometry-source',
                layerPrefix: 'gis-geometry'
            });
            bindGeometryMapInteractions();

            // 加载数据
            // loadObjects();
            await loadMapStyles();
            await loadScenes();
            await loadMenus();
            await loadGeometries();
            await panelApi.loadPanels();
            mapApi.applyChineseLabels();

            // 初始化按钮
            startHeaderDatetime();
            positionHeaderDatetime();
            document.getElementById('btn-search').addEventListener('click', searchAddress);
            document.getElementById('btn-scene-toggle').addEventListener('click', (e) => {
                e.stopPropagation();
                toggleSceneMenu();
            });
            document.getElementById('btn-view-toggle').addEventListener('click', (e) => {
                e.stopPropagation();
                toggleViewMenu();
            });
            document.getElementById('btn-toolbar-toggle').addEventListener('click', toggleToolbar);
            document.getElementById('btn-layer-toggle').addEventListener('click', toggleLayerPanel);
            document.getElementById('btn-stats-toggle').addEventListener('click', toggleStatsMode);
            document.getElementById('btn-layer-tab-resource').addEventListener('click', () => switchLayerTab('resource'));
            document.getElementById('btn-layer-tab-weather').addEventListener('click', () => switchLayerTab('weather'));
            document.getElementById('btn-layer-tab-iot').addEventListener('click', () => switchLayerTab('iot'));
            document.getElementById('geo-detail-gis-panel').addEventListener('panel-close', closeGeometryDetailDrawer);
            document.getElementById('geo-point-list-gis-panel').addEventListener('panel-close', closePointListPanel);
            document.getElementById('address-input').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') searchAddress();
            });
            document.getElementById('btn-toggle-3d').addEventListener('click', () => {
                if (state.is3D) mapApi.disable3DBuildings();
                else mapApi.enable3DBuildings();
                closeViewMenu();
            });

            document.addEventListener('click', (e) => {
                if (state.viewMenuOpen) {
                    const menu = document.getElementById('view-menu');
                    const trigger = document.getElementById('btn-view-toggle');
                    const target = e.target;
                    if (!(menu && menu.contains(target)) && !(trigger && trigger.contains(target))) {
                        closeViewMenu();
                    }
                }
                if (state.sceneMenuOpen) {
                    const menu = document.getElementById('scene-menu');
                    const trigger = document.getElementById('btn-scene-toggle');
                    const target = e.target;
                    if (!(menu && menu.contains(target)) && !(trigger && trigger.contains(target))) {
                        closeSceneMenu();
                    }
                }
            });

            syncToolbarUI();
            syncLayerPanelUI();
            syncLayerTabsUI();
            syncViewMenuUI();
            syncStatsModeUI();
            window.addEventListener('resize', positionHeaderDatetime);
            window.dispatchEvent(new CustomEvent('gis:index-ready', { detail: window.__gisIndexContext }));
        });

        map.on('style.load', async () => {
            mapApi.applyChineseLabels();
            objectApi.buildMarkers(state.objects);
            if (geometryLayerManager) {
                geometryLayerManager.setDataFromRows(state.geometries || []);
                geometryLayerManager.render();
                applyGeometryVisibility();
            }
            // 首次 style.load 可能早于菜单数据加载；菜单未就绪时不要重算可见性，避免覆盖 IsDefaultShow。
            if (state.menuNodeMap && state.menuNodeMap.size > 0) {
                await loadGeometries();
            }
            mapApi.applyProjection(state.currentProjection, { closeMenu: false });
            map.once('idle', () => applyGeometryVisibility());
            if (state.is3D) mapApi.enable3DBuildings({ closeMenu: false, adjustCamera: false });

            objectApi.setLayerVisible(true);
            renderMenuTree();
        });

        //--------------------------------------------------------------
        // 地图控制和交互
        //--------------------------------------------------------------
        function startHeaderDatetime() { GisIndexUI.startHeaderDatetime('header-datetime'); }
        function positionHeaderDatetime() {
            const headerBar = document.querySelector('.header-bar');
            const headerTitle = document.querySelector('.header-title');
            const dateTime = document.getElementById('header-datetime');
            if (!headerBar || !headerTitle || !dateTime) return;
            if (window.getComputedStyle(dateTime).display === 'none') return;

            const barRect = headerBar.getBoundingClientRect();
            const titleRect = headerTitle.getBoundingClientRect();
            const gap = 18;
            const left = titleRect.right - barRect.left + gap;

            dateTime.style.left = `${Math.round(left)}px`;
            dateTime.style.right = 'auto';
        }
        function switchStyle(type) { mapApi.switchStyle(type); }
        function resetView() { mapApi.resetView(); }
        async function searchAddress() { return mapApi.searchAddress(); }

        //--------------------------------------------------------------
        // 工具栏和视图控制（拆分至 /gis/gis-index-ui.js）
        //--------------------------------------------------------------
        function toggleToolbar() { GisIndexUI.toggleToolbar(state); }
        function syncToolbarUI() { GisIndexUI.syncToolbarUI(state); }
        function toggleLayerPanel() { GisIndexUI.toggleLayerPanel(state);}
        function syncLayerPanelUI() { GisIndexUI.syncLayerPanelUI(state); }
        function switchLayerTab(tab) { GisIndexUI.switchLayerTab(state, tab); }
        function syncLayerTabsUI() { GisIndexUI.syncLayerTabsUI(state); }
        function toggleViewMenu() { GisIndexUI.toggleViewMenu(state); }
        function closeViewMenu() { GisIndexUI.closeViewMenu(state); }
        function syncViewMenuUI() { GisIndexUI.syncViewMenuUI(state); }
        function syncStatsModeUI() { GisIndexUI.syncStatsModeUI(state); }
        function toggleStatsMode() { actionApi.toggleStatsMode(); }

        //--------------------------------------------------------------
        // 检查对象相关
        //--------------------------------------------------------------
        /** 打开检查对象详情抽屉*/
        function openCheckObjectDrawer(id) { actionApi.openCheckObjectDrawer(id); }
        function selectObject(item, openDrawer = true) { return objectApi.selectObject(item, openDrawer); }
        async function loadObjects() { return objectApi.loadObjects(); }
        function buildMarkers(items) { return objectApi.buildMarkers(items); }
        function setLayerVisible(visible) { return objectApi.setLayerVisible(visible); }

        //--------------------------------------------------------------
        // 图形详情面板
        //--------------------------------------------------------------
        function openGeometryDetailPanel(id) {
            closePointListPanel();
            return detailApi.open(id);
        }
        function closeGeometryDetailPanel() { return detailApi.close(); }
        function openPointListPanel(menuNode, geometryItems) {
            closeGeometryDetailPanel();
            return pointListApi.open(menuNode, geometryItems);
        }
        function closePointListPanel() { return pointListApi.close(); }


        //--------------------------------------------------------------
        // 菜单树
        //--------------------------------------------------------------
        function buildMenuNodes() { return dataApi.buildMenuNodes(); }
        function renderMenuTree() { return dataApi.renderMenuTree(); }
        function renderViewStyleMenu() {
            const host = document.getElementById('view-style-list');
            if (!host) return;

            host.innerHTML = '';
            state.mapStyles.forEach(style => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'view-menu-item' + (state.currentStyle === style.name ? ' active' : '');
                btn.dataset.viewStyle = style.name;
                btn.textContent = style.name;
                btn.addEventListener('click', () => switchStyle(style.name));
                host.appendChild(btn);
            });
        }

        async function loadMapStyles() {
            try {
                const res = await axios.get('/httpapi/gis/GetMapStyles');
                if (res.data.code !== 0) return;

                const list = Array.isArray(res.data.data) ? res.data.data : [];
                state.mapStyles = list
                    .map(item => ({
                        name: item.name || item.Name || '',
                        path: item.path || item.Path || ''
                    }))
                    .filter(item => item.name && item.path);

                if (!state.currentStyle && state.mapStyles.length > 0) {
                    state.currentStyle = state.mapStyles[0].name;
                }

                renderViewStyleMenu();
            } catch (err) {
                console.error('加载地图样式失败', err);
            }
        }

        async function loadScenes() {
            try {
                const res = await axios.get('/httpapi/gis/GetScenes');
                if (res.data.code === 0) {
                    state.scenes = res.data.data;
                    GisIndexUI.renderSceneMenu(state, switchScene);
                }
            } catch (err) {
                console.error('加载场景失败', err);
            }
        }

        async function switchScene(scene) {
            try {
                const res = await axios.get('/httpapi/gis/GetSceneDetail?id=' + scene.id);
                if (res.data.code === 0) {
                    const detail = res.data.data;
                    state.currentSceneId = detail.id;
                    const styleName = detail.mapStyle || detail.MapStyle || '';
                    const enable3D = detail.enable3D ?? detail.Enable3D;
                    const projection = detail.mapProjection ?? detail.MapProjection;
                    const scenePitch = detail.mapPitch ?? detail.MapPitch;

                    if (styleName || enable3D !== null && enable3D !== undefined || projection !== null && projection !== undefined) {
                        mapApi.applyViewConfig({
                            style: styleName,
                            projection: projection,
                            enable3D: enable3D,
                            closeMenu: false,
                            adjustCamera: false
                        });
                        renderViewStyleMenu();
                    }
                    
                    // 1. 切换地图中心和缩放 (兼容 camelCase 和 PascalCase)
                    const centerStr = detail.mapCenter || detail.MapCenter;
                    const zoomVal = detail.mapZoom ?? detail.MapZoom;
                    const pitchVal = (enable3D === true || enable3D === 'true')
                        ? (scenePitch !== null && scenePitch !== undefined ? scenePitch : 72)
                        : scenePitch;

                    if (centerStr) {
                        const parts = centerStr.split(/[,，\s]+/).filter(Boolean);
                        if (parts.length >= 2) {
                            const lng = parseFloat(parts[0]);
                            const lat = parseFloat(parts[1]);
                            if (!isNaN(lng) && !isNaN(lat)) {
                                map.flyTo({
                                    center: [lng, lat],
                                    zoom: (zoomVal !== null && zoomVal !== undefined) ? zoomVal : map.getZoom(),
                                    pitch: (pitchVal !== null && pitchVal !== undefined) ? pitchVal : map.getPitch(),
                                    duration: 2000 // 平滑过渡
                                });
                            }
                        }
                    } else if (zoomVal !== null && zoomVal !== undefined) {
                        map.flyTo({
                            zoom: zoomVal,
                            pitch: (pitchVal !== null && pitchVal !== undefined) ? pitchVal : map.getPitch(),
                            duration: 2000
                        });
                    } else if (pitchVal !== null && pitchVal !== undefined) {
                        map.flyTo({
                            pitch: pitchVal,
                            duration: 2000
                        });
                    }

                    // 2. 勾选图层 (兼容两种 Case)
                    const menuIds = detail.menuIds || detail.MenuIds || [];
                    dataApi.setBatchMenusChecked(menuIds);

                    // 3. 过滤面板
                    await panelApi.loadPanels(detail.id);

                    // 4. 关闭菜单并更新 UI
                    GisIndexUI.closeSceneMenu(state);
                    GisIndexUI.syncSceneMenuUI(state); // 同步图标等 UI
                    GisIndexUI.renderSceneMenu(state, switchScene);
                }
            } catch (err) {
                console.error('切换场景失败', err);
            }
        }

        async function loadMenus() { return dataApi.loadMenus();}
        function toggleSceneMenu() { GisIndexUI.toggleSceneMenu(state); }
        function closeSceneMenu() { GisIndexUI.closeSceneMenu(state); }
        function applyGeometryVisibility() {return dataApi.applyGeometryVisibility();}
        function rebuildGeometryPointMarkers() { return dataApi.rebuildGeometryPointMarkers(); }
        function syncGeometryPointMarkerVisibility() { return dataApi.syncGeometryPointMarkerVisibility(); }
        function getActiveGeometryDisplayLayerIds() { return actionApi.getActiveGeometryDisplayLayerIds(); }
        async function loadGeometries() { return dataApi.loadGeometries();}
        function bindGeometryMapInteractions() { actionApi.bindGeometryMapInteractions(); }
        function openGeometryDetailDrawer(id) {
            closePointListPanel();
            actionApi.openGeometryDetailDrawer(id);
        }
        function closeGeometryDetailDrawer() { actionApi.closeGeometryDetailDrawer(); }

    </script>
}

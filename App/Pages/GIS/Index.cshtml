@page
@model App.Pages.GIS.IndexModel
@using System.Globalization
@{
    Layout = "_Layout";
    ViewData["Title"] = "GIS驾驶舱";

    // 地图中心和缩放级别
    var mapZoom = SiteConfig.Instance.MapZoom > 0 ? SiteConfig.Instance.MapZoom : 11;
    var mapCenterText = (SiteConfig.Instance.MapCenter ?? string.Empty).Replace("，", ",").Trim();
    var mapCenterLng = 120.6034;
    var mapCenterLat = 27.5686;
    if (!string.IsNullOrWhiteSpace(mapCenterText))
    {
        var parts = mapCenterText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length >= 2
            && double.TryParse(parts[0], NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedLng)
            && double.TryParse(parts[1], NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedLat))
        {
            mapCenterLng = parsedLng;
            mapCenterLat = parsedLat;
        }
    }
}

@section head {
    <script src='https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.js'></script>
    <link href='https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.css' rel='stylesheet' />
    <link rel="stylesheet" href="/css/gis-index.css?v=@DateTime.Now.Ticks" />
    <script src="/js/maphelper.js?v=@DateTime.Now.Ticks"></script>
    <script src="/js/gis-index-data.js?v=@DateTime.Now.Ticks"></script>
    <script src="/js/gis-index-action.js?v=@DateTime.Now.Ticks"></script>
    <script src="/js/gis-index-map.js?v=@DateTime.Now.Ticks"></script>
    <script src="/js/gis-index-object.js?v=@DateTime.Now.Ticks"></script>
    <script src="/js/gis-index-detail.js?v=@DateTime.Now.Ticks"></script>
    <script src="/js/gis-panel-element.js?v=@DateTime.Now.Ticks"></script>
    <script src="/js/gis-index-ui.js?v=@DateTime.Now.Ticks"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
}

@section body {
    <div id="map"></div>

    <div class="header-bar">
        <div class="header-title">
            <span>应急驾驶舱</span>
            <span id="header-datetime" class="header-datetime" aria-label="当前日期时间"></span>
        </div>
    </div>

    <div class="map-toolbar">
        <input id="address-input" class="toolbar-input" placeholder="搜索地址，如：杭州西湖" />
        <button id="btn-search" class="toolbar-btn">查找</button>
    </div>

    <div class="floating-toggle-group">
        <button id="btn-layer-toggle" class="floating-toggle" title="图层" aria-label="显示/隐藏图层列表">
            <i class="fa-solid fa-layer-group toggle-icon"></i>
        </button>
        <button id="btn-view-toggle" class="floating-toggle" title="视图" aria-label="显示/隐藏视图工具栏">
            <i class="fa-solid fa-eye toggle-icon"></i>
        </button>
        <button id="btn-toolbar-toggle" class="floating-toggle" title="工具栏" aria-label="显示/隐藏工具栏">
            <i class="fa-solid fa-screwdriver-wrench toggle-icon"></i>
        </button>
        <button id="btn-stats-toggle" class="floating-toggle" title="统计" aria-label="显示/隐藏统计面板">
            <i class="fa-solid fa-chart-column toggle-icon"></i>
        </button>
    </div>
    <div id="view-menu" class="view-menu" aria-label="视图菜单">
        <button id="btn-style-street" class="view-menu-item active">默认视图</button>
        <button id="btn-style-sat" class="view-menu-item">遥感视图</button>
        <button id="btn-style-dark" class="view-menu-item">暗黑模式</button>
        <button id="btn-style-night" class="view-menu-item">黑蓝夜景</button>
        <button id="btn-toggle-3d" class="view-menu-item">三维模式</button>
    </div>

    <div id="layer-panel" class="panel-left">
        <gis-panel class="layer-gis-panel" title="图层" width="100%" height="100%">
            <div class="layer-tree">
                <div id="menu-tree" class="menu-tree-wrap"></div>
            </div>
        </gis-panel>
    </div>

    <div id="stats-overlay" class="stats-overlay" aria-label="统计面板">
        <div class="stats-column stats-column-left">
            <gis-panel class="stats-gis-panel" title="应急资源" info="应急资源信息" content="接入应急队伍、物资仓库、避难场所等关键资源统计信息。" width="100%" height="100%"></gis-panel>
            <gis-panel class="stats-gis-panel" title="风险监测" info="风险监测信息" content="展示灾害风险点、重点防御单元和当前监测预警态势。" width="100%" height="100%"></gis-panel>
            <gis-panel class="stats-gis-panel" title="处置效率" info="处置效率信息" content="汇总事件响应时长、处置进度和闭环率等核心效率指标。" width="100%" height="100%"></gis-panel>
        </div>
        <div class="stats-column stats-column-right">
            <gis-panel class="stats-gis-panel" title="事件总览" info="事件总览信息" content="按类型、区域、时间维度展示事件总量与趋势变化。" width="100%" height="100%"></gis-panel>
            <gis-panel class="stats-gis-panel" title="联动单位" info="联动单位信息" content="统计部门协同、任务下发与跨单位联动执行情况。" width="100%" height="100%"></gis-panel>
            <gis-panel class="stats-gis-panel" title="值守状态" info="值守状态信息" content="显示当班力量、值守在线状态和关键岗位覆盖情况。" width="100%" height="100%"></gis-panel>
        </div>
    </div>

    <div id="geo-detail-panel" class="geo-detail-panel" aria-label="图形详情">
        <gis-panel id="geo-detail-gis-panel" class="geo-detail-gis-panel" title="点位信息" width="100%" height="100%" closable="true" close-label="关闭">
            <div id="geo-detail-body" class="geo-detail-body">请选择图形</div>
        </gis-panel>
    </div>
}

@section script {
    <script>
        mapboxgl.accessToken = "@SiteConfig.Instance.MapKey";

        const state = {
            objects: [],
            selectedId: null,
            markerMap: new Map(),
            menus: [],
            menuRoots: [],
            menuNodeMap: new Map(),
            geometries: [],
            geometryPointMarkerMap: new Map(),
            geometryByMenuId: new Map(),
            geometryVisibleMap: new Map(),
            selectedGeometryId: null,
            geometryInteractionBound: false,
            preservedVisibleGeometryIds: new Set(),
            currentStyle: 'street',
            is3D: false,
            toolbarCollapsed: true,
            layerCollapsed: false,
            viewMenuOpen: false,
            statsMode: false
        };
        const GisIndexUI = window.GisIndexUI;
        const GisIndexData = window.GisIndexData;
        const GisIndexAction = window.GisIndexAction;
        const GisIndexMap = window.GisIndexMap;
        const GisIndexObject = window.GisIndexObject;
        const GisIndexDetail = window.GisIndexDetail;


        //--------------------------------------------------------------
        // 地图基础设置
        //--------------------------------------------------------------
        // map
        let geometryLayerManager = null;
        const terrainSourceId = 'mapbox-dem';
        const geometryDisplayLayerIds = [
            'gis-geometry-fill-layer',
            'gis-geometry-line-layer',
            'gis-geometry-point-layer',
            'gis-geometry-label-layer',
            'gis-geometry-line-label-layer'
        ];
        const map = new mapboxgl.Map({
            container: 'map',
            style: 'mapbox://styles/mapbox/streets-v12',
            center: [@mapCenterLng.ToString(CultureInfo.InvariantCulture), @mapCenterLat.ToString(CultureInfo.InvariantCulture)],
            zoom: @mapZoom.ToString(CultureInfo.InvariantCulture),
            pitch: 0,
            attributionControl: false
        });
        const dataApi = GisIndexData.create({
            state,
            map,
            getGeometryLayerManager: () => geometryLayerManager,
            onGeometryMarkerClick: (id) => openGeometryDetailDrawer(id)
        });
        const actionApi = GisIndexAction.create({
            map,
            state,
            geometryDisplayLayerIds,
            onOpenGeometryDetail: (id) => openGeometryDetailPanel(id),
            onCloseGeometryDetail: () => closeGeometryDetailPanel()
        });
        const mapApi = GisIndexMap.create({
            map,
            state,
            terrainSourceId,
            center: [@mapCenterLng.ToString(CultureInfo.InvariantCulture), @mapCenterLat.ToString(CultureInfo.InvariantCulture)],
            zoom: @mapZoom.ToString(CultureInfo.InvariantCulture),
            closeViewMenu: () => closeViewMenu()
        });
        const objectApi = GisIndexObject.create({
            map,
            state,
            onOpenDetail: (id) => openCheckObjectDrawer(id)
        });
        const detailApi = GisIndexDetail.create({
            panelId: 'geo-detail-panel',
            bodyId: 'geo-detail-body',
            endpointBuilder: (id) => `?handler=GeometryDetail&id=${encodeURIComponent(id)}`
        });
        map.addControl(new mapboxgl.NavigationControl(), 'top-right');
        map.addControl(new mapboxgl.GeolocateControl({
            positionOptions: { enableHighAccuracy: true },
            trackUserLocation: true,
            showUserHeading: true
        }), 'top-right');
        map.addControl(new mapboxgl.ScaleControl({ unit: 'metric' }), 'bottom-left');
        map.addControl(new mapboxgl.AttributionControl({ compact: true }), 'bottom-right');
        const centerCoordControl = mapApi.createCenterCoordControl();
        map.addControl(centerCoordControl, 'bottom-right');
        map.addControl(mapApi.createResetControl(resetView), 'top-right');
        map.addControl(new mapboxgl.FullscreenControl({ container: document.documentElement }), 'top-right');
        map.on('move', () => centerCoordControl.update());
        map.on('load', async () => {
            const mapHelperReady = await mapApi.ensureMapGeometryHelperReady();
            if (!mapHelperReady) {
                EleManager.showError('地图图形组件加载失败');
                return;
            }
            geometryLayerManager = window.MapGeometryHelper.createDisplayLayerManager({
                map,
                sourceId: 'gis-geometry-source',
                layerPrefix: 'gis-geometry'
            });
            bindGeometryMapInteractions();

            // 加载数据
            // loadObjects();
            await loadMenus();
            await loadGeometries();
            mapApi.applyChineseLabels();

            // 初始化按钮
            startHeaderDatetime();
            document.getElementById('btn-search').addEventListener('click', searchAddress);
            document.getElementById('btn-view-toggle').addEventListener('click', (e) => {
                e.stopPropagation();
                toggleViewMenu();
            });
            document.getElementById('btn-toolbar-toggle').addEventListener('click', toggleToolbar);
            document.getElementById('btn-layer-toggle').addEventListener('click', toggleLayerPanel);
            document.getElementById('btn-stats-toggle').addEventListener('click', toggleStatsMode);
            document.getElementById('geo-detail-gis-panel').addEventListener('panel-close', closeGeometryDetailDrawer);
            document.getElementById('address-input').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') searchAddress();
            });
            document.getElementById('btn-style-street').addEventListener('click', () => switchStyle('street'));
            document.getElementById('btn-style-sat').addEventListener('click', () => switchStyle('satellite'));
            document.getElementById('btn-style-dark').addEventListener('click', () => switchStyle('dark'));
            document.getElementById('btn-style-night').addEventListener('click', () => switchStyle('night'));
            document.getElementById('btn-toggle-3d').addEventListener('click', () => {
                if (state.is3D) mapApi.disable3DBuildings();
                else mapApi.enable3DBuildings();
                closeViewMenu();
            });

            document.addEventListener('click', (e) => {
                if (!state.viewMenuOpen) return;
                const menu = document.getElementById('view-menu');
                const trigger = document.getElementById('btn-view-toggle');
                const target = e.target;
                if (menu && menu.contains(target)) return;
                if (trigger && trigger.contains(target)) return;
                closeViewMenu();
            });

            syncToolbarUI();
            syncLayerPanelUI();
            syncViewMenuUI();
            syncStatsModeUI();
        });

        map.on('style.load', async () => {
            mapApi.applyChineseLabels();
            objectApi.buildMarkers(state.objects);
            if (geometryLayerManager) {
                geometryLayerManager.setDataFromRows(state.geometries || []);
                geometryLayerManager.render();
                applyGeometryVisibility();
            }
            // 首次 style.load 可能早于菜单数据加载；菜单未就绪时不要重算可见性，避免覆盖 IsDefaultShow。
            if (state.menuNodeMap && state.menuNodeMap.size > 0) {
                await loadGeometries();
            }
            map.once('idle', () => applyGeometryVisibility());
            if (state.is3D) mapApi.enable3DBuildings();

            objectApi.setLayerVisible(true);
            renderMenuTree();
        });

        //--------------------------------------------------------------
        // 地图控制和交互
        //--------------------------------------------------------------
        function startHeaderDatetime() { GisIndexUI.startHeaderDatetime('header-datetime'); }
        function switchStyle(type) { mapApi.switchStyle(type); }
        function resetView() { mapApi.resetView(); }
        async function searchAddress() { return mapApi.searchAddress(); }

        //--------------------------------------------------------------
        // 工具栏和视图控制（拆分至 /js/gis-index-ui.js）
        //--------------------------------------------------------------
        function toggleToolbar() { GisIndexUI.toggleToolbar(state); }
        function syncToolbarUI() { GisIndexUI.syncToolbarUI(state); }
        function toggleLayerPanel() { GisIndexUI.toggleLayerPanel(state);}
        function syncLayerPanelUI() { GisIndexUI.syncLayerPanelUI(state); }
        function toggleViewMenu() { GisIndexUI.toggleViewMenu(state); }
        function closeViewMenu() { GisIndexUI.closeViewMenu(state); }
        function syncViewMenuUI() { GisIndexUI.syncViewMenuUI(state); }
        function syncStatsModeUI() { GisIndexUI.syncStatsModeUI(state); }
        function toggleStatsMode() { actionApi.toggleStatsMode(); }

        //--------------------------------------------------------------
        // 检查对象相关
        //--------------------------------------------------------------
        /** 打开检查对象详情抽屉*/
        function openCheckObjectDrawer(id) { actionApi.openCheckObjectDrawer(id); }
        function selectObject(item, openDrawer = true) { return objectApi.selectObject(item, openDrawer); }
        async function loadObjects() { return objectApi.loadObjects(); }
        function buildMarkers(items) { return objectApi.buildMarkers(items); }
        function setLayerVisible(visible) { return objectApi.setLayerVisible(visible); }

        //--------------------------------------------------------------
        // 图形详情面板
        //--------------------------------------------------------------
        function openGeometryDetailPanel(id) { return detailApi.open(id); }
        function closeGeometryDetailPanel() { return detailApi.close(); }


        //--------------------------------------------------------------
        // 菜单树
        //--------------------------------------------------------------
        function buildMenuNodes() { return dataApi.buildMenuNodes(); }
        function renderMenuTree() { return dataApi.renderMenuTree(); }
        async function loadMenus() { return dataApi.loadMenus();}
        function applyGeometryVisibility() {return dataApi.applyGeometryVisibility();}
        function rebuildGeometryPointMarkers() { return dataApi.rebuildGeometryPointMarkers(); }
        function syncGeometryPointMarkerVisibility() { return dataApi.syncGeometryPointMarkerVisibility(); }
        function getActiveGeometryDisplayLayerIds() { return actionApi.getActiveGeometryDisplayLayerIds(); }
        async function loadGeometries() { return dataApi.loadGeometries();}
        function bindGeometryMapInteractions() { actionApi.bindGeometryMapInteractions(); }
        function openGeometryDetailDrawer(id) { actionApi.openGeometryDetailDrawer(id); }
        function closeGeometryDetailDrawer() { actionApi.closeGeometryDetailDrawer(); }

    </script>
}

    <script src="/gis/gis-index-data.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-action.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-address-search.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-address.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-view.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-map.js?v=@DateTime.Now.Ticks"></script>
    <script src="/gis/gis-index-scene.js?v=@DateTime.Now.Ticks"></script>

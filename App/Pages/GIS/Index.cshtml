@page
@model App.Pages.Gis.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "GIS驾驶舱";
}

@section head {
    <script src='https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.js'></script>
    <link href='https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.css' rel='stylesheet' />
    <script src="/js/maphelper.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        body { margin: 0; padding: 0; overflow: hidden; background: #eef2ff; color: #111827; }
        #map { position: absolute; top: 0; bottom: 0; width: 100%; }
        .glass-panel {
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(148, 163, 184, 0.24);
            border-radius: 8px;
            padding: 16px;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
        }
        .header-bar {
            position: absolute;
            top: -10px;
            left: 0;
            width: 100%;
            height: 96px;
            /*background: linear-gradient(to bottom, rgba(255,255,255,0.92), rgba(255,255,255,0));*/
            background-image: url("/gis/head.png");
            background-size: cover;
            background-position: center;
            opacity: 0.95;


            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .header-title {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 10px 18px;
            color: white;
            opacity: 0.95;
            font-size: 36px;
            font-family: 'Times New Roman', Times, serif, '方正小标宋简';
            letter-spacing: .08em;
        }
        .header-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: #2563eb;
            box-shadow: 0 0 0 6px rgba(59, 130, 246, 0.16);
        }
        .map-toolbar {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 11;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 12px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid rgba(148, 163, 184, 0.28);
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.15);
            transition: all .25s ease;
        }
        .map-toolbar.toolbar-collapsed {
            opacity: 0;
            pointer-events: none;
            transform: translateX(-50%) translateY(20px);
        }
        .view-menu {
            position: absolute;
            top: 68px;
            left: 70px;
            z-index: 12;
            min-width: 156px;
            padding: 8px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.96);
            border: 1px solid rgba(148, 163, 184, 0.32);
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.16);
            opacity: 0;
            pointer-events: none;
            transform: translateY(-6px);
            transition: all .2s ease;
        }
        .view-menu.menu-visible {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }
        .view-menu-item {
            width: 100%;
            text-align: left;
            border: 1px solid transparent;
            border-radius: 8px;
            background: transparent;
            color: #0f172a;
            font-size: 13px;
            padding: 7px 9px;
            cursor: pointer;
            margin: 2px 0;
        }
        .view-menu-item:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
        }
        .view-menu-item.active {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }
        .toolbar-btn {
            border: 1px solid #cbd5e1;
            background: #fff;
            color: #0f172a;
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 12px;
            line-height: 1;
            cursor: pointer;
        }
        .toolbar-btn:hover { background: #f8fafc; }
        .toolbar-btn.active {
            border-color: #2563eb;
            color: #fff;
            background: #2563eb;
        }
        .toolbar-input {
            width: 220px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 12px;
            color: #111827;
            outline: none;
            background: #fff;
        }
        .panel-left {
            position: absolute;
            top: 80px;
            left: 20px;
            bottom: 20px;
            width: 320px;
            z-index: 10;
            display: flex;
            flex-direction: column;
            gap: 14px;
            transition: transform .25s ease, opacity .25s ease;
        }
        .panel-left .glass-panel {
            height: 100%;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }
        .panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 10px;
        }
        .panel-head h2 {
            margin: 0;
        }
        .panel-minimize-btn {
            width: 28px;
            height: 28px;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.45);
            background: #ffffff;
            color: #334155;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all .2s ease;
        }
        .panel-minimize-btn:hover {
            color: #1d4ed8;
            border-color: #93c5fd;
            background: #eff6ff;
        }
        .panel-left.panel-hidden {
            transform: translateX(-125%);
            opacity: 0;
            pointer-events: none;
        }
        .layer-tree {
            flex: 1;
            overflow: auto;
            font-size: 13px;
        }
        .menu-tree-wrap {
            border: 1px solid rgba(148, 163, 184, 0.25);
            border-radius: 8px;
            background: rgba(248, 250, 252, 0.8);
            padding: 8px;
            margin-bottom: 10px;
        }
        .menu-node {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 5px 6px;
            border-radius: 6px;
            margin-bottom: 2px;
        }
        .menu-node:hover {
            background: #eff6ff;
        }
        .menu-node-check {
            width: 15px;
            height: 15px;
            accent-color: #2563eb;
            cursor: pointer;
        }
        .menu-node-label {
            flex: 1;
            text-align: left;
            border: none;
            background: transparent;
            color: #0f172a;
            font-size: 13px;
            padding: 0;
            cursor: pointer;
        }
        .menu-node-label:hover {
            color: #1d4ed8;
        }
        .menu-node-count {
            min-width: 18px;
            height: 18px;
            padding: 0 6px;
            border-radius: 999px;
            background: #e2e8f0;
            color: #334155;
            font-size: 11px;
            line-height: 18px;
            text-align: center;
        }
        .menu-node-count.empty {
            background: #f1f5f9;
            color: #94a3b8;
        }
        .menu-empty {
            font-size: 12px;
            color: #94a3b8;
            padding: 6px;
        }
        .geo-detail-drawer {
            position: absolute;
            top: 0;
            right: -460px;
            width: 440px;
            bottom: 0;
            z-index: 30;
            background: rgba(255, 255, 255, 0.98);
            border-left: 1px solid rgba(148, 163, 184, 0.35);
            box-shadow: -8px 0 24px rgba(15, 23, 42, 0.16);
            transition: right .25s ease;
            display: flex;
            flex-direction: column;
        }
        .geo-detail-drawer.open {
            right: 0;
        }
        .geo-drawer-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 16px;
            border-bottom: 1px solid #e2e8f0;
        }
        .geo-drawer-body {
            flex: 1;
            overflow: auto;
            padding: 12px 16px;
            font-size: 13px;
            color: #1f2937;
        }
        .geo-drawer-foot {
            padding: 10px 16px;
            border-top: 1px solid #e2e8f0;
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }
        .geo-kv {
            width: 100%;
            border-collapse: collapse;
        }
        .geo-kv td {
            border: 1px solid #e2e8f0;
            padding: 6px 8px;
            vertical-align: top;
            word-break: break-all;
        }
        .geo-kv td:first-child {
            width: 110px;
            font-size: 12px;
            color: #64748b;
            background: #f8fafc;
            font-weight: 600;
        }
        .geo-data-table {
            width: 100%;
            margin-top: 8px;
            border-collapse: collapse;
        }
        .geo-data-table th,
        .geo-data-table td {
            border: 1px solid #e2e8f0;
            padding: 6px 8px;
            text-align: left;
            vertical-align: top;
            word-break: break-all;
        }
        .geo-data-table th {
            background: #f8fafc;
            color: #64748b;
            font-size: 12px;
        }
        .floating-toggle-group {
            position: absolute;
            top: 18px;
            left: 20px;
            z-index: 12;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .floating-toggle {
            width: 42px;
            height: 42px;
            border: 1px solid rgba(148, 163, 184, 0.4);
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.95);
            color: #1e3a8a;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.2);
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .floating-toggle .toggle-icon {
            font-size: 18px;
            line-height: 1;
            width: 1em;
            text-align: center;
        }
        .floating-toggle.active {
            background: #2563eb;
            color: #fff;
            border-color: #2563eb;
        }
        .map-center-ctrl {
            min-width: 170px;
            padding: 6px 10px;
            border-radius: 6px;
            background: rgba(255, 255, 255, 0.94);
            border: 1px solid rgba(148, 163, 184, 0.35);
            box-shadow: 0 4px 14px rgba(15, 23, 42, 0.14);
            color: #0f172a;
            font-size: 12px;
            line-height: 1.2;
            user-select: none;
            white-space: nowrap;
        }
        @@media (max-width: 768px) {
            .header-bar { height: 76px; }
            .header-title { font-size: 28px; padding: 8px 12px; }
            .panel-left {
                width: 260px;
                top: 92px;
                bottom: 20px;
                left: 10px;
            }
            .map-toolbar {
                width: calc(100% - 20px);
                left: 10px;
                transform: none;
                justify-content: flex-start;
                overflow-x: auto;
                white-space: nowrap;
            }
            .view-menu {
                left: 56px;
                top: 58px;
                min-width: 140px;
            }
            .toolbar-input { width: 180px; }
            .floating-toggle-group {
                left: 10px;
                top: 12px;
            }
            .geo-detail-drawer {
                width: 100%;
                right: -100%;
            }
        }
    </style>
}

@section body {
    <div id="map"></div>

    <div class="header-bar">
        <div class="header-title">
            <span>应急驾驶舱</span>
        </div>
    </div>

    <div class="map-toolbar">
        <button id="btn-reset" class="toolbar-btn">回位</button>
        <button id="btn-fullscreen" class="toolbar-btn">全屏</button>
        <input id="address-input" class="toolbar-input" placeholder="搜索地址，如：杭州西湖" />
        <button id="btn-search" class="toolbar-btn">查找</button>
    </div>

    <div class="floating-toggle-group">
        <button id="btn-layer-toggle" class="floating-toggle" title="图层" aria-label="显示/隐藏图层列表">
            <i class="fa-solid fa-layer-group toggle-icon"></i>
        </button>
        <button id="btn-view-toggle" class="floating-toggle" title="视图" aria-label="显示/隐藏视图工具栏">
            <i class="fa-solid fa-eye toggle-icon"></i>
        </button>
        <button id="btn-toolbar-toggle" class="floating-toggle" title="工具栏" aria-label="显示/隐藏工具栏">
            <i class="fa-solid fa-screwdriver-wrench toggle-icon"></i>
        </button>
    </div>
    <div id="view-menu" class="view-menu" aria-label="视图菜单">
        <button id="btn-style-street" class="view-menu-item active">默认视图</button>
        <button id="btn-style-sat" class="view-menu-item">遥感视图</button>
        <button id="btn-toggle-3d" class="view-menu-item">三维建筑</button>
    </div>

    <div id="layer-panel" class="panel-left">
        <div class="glass-panel">
            <div class="panel-head">
                <h2 class="text-lg font-bold border-l-4 border-cyan-500 pl-2">图层</h2>
                <button id="btn-layer-minimize" class="panel-minimize-btn" title="最小化图层面板" aria-label="最小化图层面板">
                    <i class="fa-solid fa-minus"></i>
                </button>
            </div>
            <div class="layer-tree">
                <div id="menu-tree" class="menu-tree-wrap"></div>
            </div>
        </div>
    </div>

    <aside id="geo-detail-drawer" class="geo-detail-drawer" aria-label="图形详情">
        <div class="geo-drawer-head">
            <strong id="geo-detail-title">图形详情</strong>
            <button id="btn-geo-close" class="toolbar-btn">关闭</button>
        </div>
        <div id="geo-detail-body" class="geo-drawer-body">请选择图形</div>
        <div class="geo-drawer-foot">
            <button id="btn-geo-edit" class="toolbar-btn" style="display:none;">编辑</button>
        </div>
    </aside>
}

@section script {
    <script>
        mapboxgl.accessToken = "@SiteConfig.Instance.MapKey";

        const state = {
            objects: [],
            selectedId: null,
            markerMap: new Map(),
            menus: [],
            menuRoots: [],
            menuNodeMap: new Map(),
            geometries: [],
            geometryByMenuId: new Map(),
            geometryVisibleMap: new Map(),
            selectedGeometryId: null,
            currentStyle: 'street',
            is3D: false,
            toolbarCollapsed: true,
            layerCollapsed: false,
            viewMenuOpen: false
        };


        //--------------------------------------------------------------
        // 地图基础设置
        //--------------------------------------------------------------
        // map
        let geometryLayerManager = null;
        const map = new mapboxgl.Map({
            container: 'map',
            style: 'mapbox://styles/mapbox/streets-v12',
            center: [120.6034, 27.5686],
            zoom: 11,
            pitch: 0
        });
        map.addControl(new mapboxgl.NavigationControl(), 'top-right');
        map.addControl(new mapboxgl.GeolocateControl({
            positionOptions: { enableHighAccuracy: true },
            trackUserLocation: true,
            showUserHeading: true
        }), 'top-right');
        map.addControl(new mapboxgl.ScaleControl({ unit: 'metric' }), 'bottom-left');
        const centerCoordControl = createCenterCoordControl();
        map.addControl(centerCoordControl, 'bottom-right');
        map.on('move', () => centerCoordControl.update());
        map.on('load', () => {
            // MapGeometryHelper
            if (!window.MapGeometryHelper || typeof window.MapGeometryHelper.createDisplayLayerManager !== 'function') {
                EleManager.showError('地图图形组件加载失败');
                return;
            }
            geometryLayerManager = window.MapGeometryHelper.createDisplayLayerManager({
                map,
                sourceId: 'gis-geometry-source',
                layerPrefix: 'gis-geometry'
            });

            // 加载数据
            // loadObjects();
            loadMenus().then(() => loadGeometries());
            applyChineseLabels();

            // 初始化按钮
            document.getElementById('btn-reset').addEventListener('click', resetView);
            document.getElementById('btn-fullscreen').addEventListener('click', toggleFullscreen);
            document.getElementById('btn-search').addEventListener('click', searchAddress);
            document.getElementById('btn-view-toggle').addEventListener('click', (e) => {
                e.stopPropagation();
                toggleViewMenu();
            });
            document.getElementById('btn-toolbar-toggle').addEventListener('click', toggleToolbar);
            document.getElementById('btn-layer-toggle').addEventListener('click', toggleLayerPanel);
            document.getElementById('btn-layer-minimize').addEventListener('click', () => {
                if (!state.layerCollapsed) {
                    state.layerCollapsed = true;
                    syncLayerPanelUI();
                }
            });
            document.getElementById('btn-geo-close').addEventListener('click', closeGeometryDetailDrawer);
            document.getElementById('address-input').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') searchAddress();
            });
            document.getElementById('btn-style-street').addEventListener('click', () => switchStyle('street'));
            document.getElementById('btn-style-sat').addEventListener('click', () => switchStyle('satellite'));
            document.getElementById('btn-toggle-3d').addEventListener('click', () => {
                if (state.is3D) disable3DBuildings();
                else enable3DBuildings();
                closeViewMenu();
            });

            document.addEventListener('click', (e) => {
                if (!state.viewMenuOpen) return;
                const menu = document.getElementById('view-menu');
                const trigger = document.getElementById('btn-view-toggle');
                const target = e.target;
                if (menu && menu.contains(target)) return;
                if (trigger && trigger.contains(target)) return;
                closeViewMenu();
            });

            document.addEventListener('fullscreenchange', () => {
                const btn = document.getElementById('btn-fullscreen');
                if (!btn) return;
                const isFull = !!document.fullscreenElement;
                btn.classList.toggle('active', isFull);
                btn.textContent = isFull ? '退出全屏' : '全屏';
            });

            syncToolbarUI();
            syncLayerPanelUI();
            syncViewMenuUI();
        });

        map.on('style.load', () => {
            applyChineseLabels();
            buildMarkers(state.objects);
            if (geometryLayerManager) {
                geometryLayerManager.render();
                applyGeometryVisibility();
            }
            if (state.is3D) enable3DBuildings();

            setLayerVisible(true);
            renderMenuTree();
        });

        //--------------------------------------------------------------
        // 地图控制和交互
        //--------------------------------------------------------------
        // apply chinese labels
        function applyChineseLabels() {
            const style = map.getStyle();
            if (!style || !Array.isArray(style.layers)) return;
            style.layers.forEach(layer => {
                if (layer.type !== 'symbol') return;
                const textField = map.getLayoutProperty(layer.id, 'text-field');
                if (!textField) return;
                if (typeof textField !== 'string') return;
                try {
                    map.setLayoutProperty(layer.id, 'text-field', [
                        'coalesce',
                        ['get', 'name_zh-Hans'],
                        ['get', 'name_zh'],
                        ['get', 'name'],
                        ''
                    ]);
                } catch {
                    // ignore incompatible text-field expression
                }
            });
        }

        // Create a custom control to display the current center coordinates of the map
        function createCenterCoordControl() {
            let container = null;
            const setText = () => {
                if (!container) return;
                const center = map.getCenter();
                container.textContent = `中心: ${center.lng.toFixed(6)}, ${center.lat.toFixed(6)}`;
            };

            return {
                onAdd() {
                    container = document.createElement('div');
                    container.className = 'mapboxgl-ctrl map-center-ctrl';
                    setText();
                    return container;
                },
                onRemove() {
                    if (container && container.parentNode) {
                        container.parentNode.removeChild(container);
                    }
                    container = null;
                },
                update: setText
            };
        }

        /** 启用 3D 地图效果*/
        function enable3DBuildings() {
            const layers = map.getStyle().layers;
            const labelLayerId = layers.find(l => l.type === 'symbol' && l.layout && l.layout['text-field'])?.id;
            if (!map.getLayer('3d-buildings')) {
                map.addLayer({
                    id: '3d-buildings',
                    source: 'composite',
                    'source-layer': 'building',
                    filter: ['==', 'extrude', 'true'],
                    type: 'fill-extrusion',
                    minzoom: 15,
                    paint: {
                        'fill-extrusion-color': '#94a3b8',
                        'fill-extrusion-height': ['get', 'height'],
                        'fill-extrusion-base': ['get', 'min_height'],
                        'fill-extrusion-opacity': 0.55
                    }
                }, labelLayerId);
            }
            map.easeTo({ pitch: 60, bearing: -18, duration: 600 });
            state.is3D = true;
            document.getElementById('btn-toggle-3d').classList.add('active');
        }

        function disable3DBuildings() {
            if (map.getLayer('3d-buildings')) {
                map.removeLayer('3d-buildings');
            }
            map.easeTo({ pitch: 0, bearing: 0, duration: 600 });
            state.is3D = false;
            document.getElementById('btn-toggle-3d').classList.remove('active');
        }

        /** 切换地图样式*/
        function switchStyle(type) {
            state.currentStyle = type;
            map.setStyle(type === 'satellite' ? 'mapbox://styles/mapbox/satellite-streets-v12' : 'mapbox://styles/mapbox/streets-v12');
            document.getElementById('btn-style-street').classList.toggle('active', type === 'street');
            document.getElementById('btn-style-sat').classList.toggle('active', type === 'satellite');
            closeViewMenu();
        }

        /** 地址搜索*/
        async function searchAddress() {
            const input = document.getElementById('address-input');
            const keyword = (input?.value || '').trim();
            if (!keyword) return;
            const endpoint = `https://api.mapbox.com/geocoding/v5/mapbox.places/${encodeURIComponent(keyword)}.json?access_token=${encodeURIComponent(mapboxgl.accessToken)}&language=zh-Hans&limit=1`;
            try {
                const resp = await fetch(endpoint);
                const data = await resp.json();
                const feature = data?.features?.[0];
                if (!feature) {
                    EleManager.showWarning('未找到该地址');
                    return;
                }
                const [lng, lat] = feature.center;
                map.flyTo({ center: [lng, lat], zoom: 15, speed: 0.9 });
            } catch {
                EleManager.showError('地址搜索失败');
            }
        }

        //--------------------------------------------------------------
        // 工具栏和视图控制
        //--------------------------------------------------------------
        /** 切换全屏模式*/
        async function toggleFullscreen() {
            const btn = document.getElementById('btn-fullscreen');
            try {
                if (!document.fullscreenElement) await document.documentElement.requestFullscreen();
                else await document.exitFullscreen();
            } catch {
                EleManager.showWarning('当前环境不支持全屏切换');
            }
            const isFull = !!document.fullscreenElement;
            if (btn) {
                btn.classList.toggle('active', isFull);
                btn.textContent = isFull ? '退出全屏' : '全屏';
            }
        }

        /** 切换工具栏显示状态*/
        function toggleToolbar() {
            state.toolbarCollapsed = !state.toolbarCollapsed;
            syncToolbarUI();
        }

        function syncToolbarUI() {
            const toolbar = document.querySelector('.map-toolbar');
            const toggleBtn = document.getElementById('btn-toolbar-toggle');
            toolbar.classList.toggle('toolbar-collapsed', state.toolbarCollapsed);
            if (toggleBtn) {
                toggleBtn.classList.toggle('active', !state.toolbarCollapsed);
                toggleBtn.title = state.toolbarCollapsed ? '展开工具栏' : '收起工具栏';
            }
        }

        /** 切换图层面板显示状态*/
        function toggleLayerPanel() {
            state.layerCollapsed = !state.layerCollapsed;
            syncLayerPanelUI();
        }

        function syncLayerPanelUI() {
            const panel = document.getElementById('layer-panel');
            const toggleBtn = document.getElementById('btn-layer-toggle');
            panel.classList.toggle('panel-hidden', state.layerCollapsed);
            if (toggleBtn) {
                toggleBtn.classList.toggle('active', !state.layerCollapsed);
                toggleBtn.title = state.layerCollapsed ? '展开图层列表' : '收起图层列表';
            }
        }

        /** 切换视图菜单显示状态*/
        function toggleViewMenu() {
            state.viewMenuOpen = !state.viewMenuOpen;
            syncViewMenuUI();
        }

        function closeViewMenu() {
            state.viewMenuOpen = false;
            syncViewMenuUI();
        }

        function syncViewMenuUI() {
            const menu = document.getElementById('view-menu');
            const toggleBtn = document.getElementById('btn-view-toggle');
            if (menu) menu.classList.toggle('menu-visible', state.viewMenuOpen);
            if (toggleBtn) {
                toggleBtn.classList.toggle('active', state.viewMenuOpen);
                toggleBtn.title = state.viewMenuOpen ? '收起视图菜单' : '展开视图菜单';
            }
        }

        /** 重置视图*/
        function resetView() {
            if (state.is3D) disable3DBuildings();
            switchStyle('street');
            map.flyTo({ center: [120.1551, 30.2741], zoom: 11, speed: 0.9, curve: 1.2 });
        }

        //--------------------------------------------------------------
        // 检查对象相关
        //--------------------------------------------------------------
        /** 打开检查对象详情抽屉*/
        function openCheckObjectDrawer(id) {
            if (!id) return;
            const manager = (window.top && window.top.EleManager) ? window.top.EleManager : window.EleManager;
            if (!manager || typeof manager.openDrawer !== 'function') {
                window.open(`/Checks/CheckObjectForm?id=${id}&md=view`, '_blank');
                return;
            }
            manager.openDrawer({
                title: '检查对象详情',
                url: `/Checks/CheckObjectForm?id=${id}&md=view`,
                direction: 'rtl',
                size: window.innerWidth < 768 ? '100%' : '25%',
                resizable: true,
                closeOnClickModal: false,
                destroyOnClose: true
            });
        }

        /** 选择检查对象*/
        function selectObject(item, openDrawer = true) {
            if (!item) return;
            state.selectedId = item.id;
            if (openDrawer) openCheckObjectDrawer(item.id);
        }

        /** 加载检查对象数据*/
        async function loadObjects() {
            const resp = await fetch('?handler=LayerData');
            const res = await resp.json();
            if (res.code !== 0 || !Array.isArray(res.data)) return;

            state.objects = res.data;
            buildMarkers(state.objects);
            if (state.objects.length > 0) selectObject(state.objects[0], false);
        }

        /** 构建地图上的标记*/
        function buildMarkers(items) {
            state.markerMap.forEach(marker => marker.remove());
            state.markerMap.clear();

            items.forEach(item => {
                const el = document.createElement('div');
                el.style.width = '26px';
                el.style.height = '26px';
                el.style.borderRadius = '999px';
                el.style.background = 'linear-gradient(135deg,#60a5fa,#1d4ed8)';
                el.style.border = '2px solid rgba(255,255,255,0.85)';
                el.style.boxShadow = '0 0 12px rgba(96,165,250,0.7)';
                el.style.cursor = 'pointer';
                el.title = item.name || '检查对象';
                el.addEventListener('click', () => selectObject(item, true));

                const marker = new mapboxgl.Marker(el).setLngLat([item.lng, item.lat]).addTo(map);
                state.markerMap.set(item.id, marker);
            });
        }

        /** 设置标记图层是否可见*/
        function setLayerVisible(visible) {
            state.markerMap.forEach(marker => {
                marker.getElement().style.display = visible ? '' : 'none';
            });
        }


        //--------------------------------------------------------------
        // 菜单树
        //--------------------------------------------------------------
        /** 构建菜单树结构*/
        function buildMenuNodes() {
            const nodes = state.menus.map(item => ({ ...item, children: [] }));
            const byId = new Map(nodes.map(n => [n.id, n]));
            const roots = [];

            nodes.forEach(node => {
                if (node.parentId && byId.has(node.parentId)) {
                    byId.get(node.parentId).children.push(node);
                } else {
                    roots.push(node);
                }
            });

            const sortFn = (a, b) => (a.sortId || 0) - (b.sortId || 0) || a.id - b.id;
            const sortTree = list => {
                list.sort(sortFn);
                list.forEach(node => sortTree(node.children || []));
            };
            sortTree(roots);
            state.menuRoots = roots;
            state.menuNodeMap = byId;
        }

        /** 获取菜单及其子菜单关联的几何图形ID*/
        function getMenuGeometryIds(node, cache = new Map()) {
            if (!node) return [];
            if (cache.has(node.id)) return cache.get(node.id);

            const own = state.geometryByMenuId.get(node.id) || [];
            const childIds = (node.children || []).flatMap(child => getMenuGeometryIds(child, cache));
            const result = [...own, ...childIds];
            cache.set(node.id, result);
            return result;
        }

        /** 获取菜单及其子菜单关联的叶子几何图形数量*/
        function getLeafGeometryCount(menuId) {
            const list = state.geometryByMenuId.get(menuId) || [];
            return list.length;
        }

        /** 设置菜单节点的选中状态*/
        function setMenuChecked(node, checked, cache = new Map()) {
            const ids = getMenuGeometryIds(node, cache);
            ids.forEach(id => state.geometryVisibleMap.set(id, !!checked));
            applyGeometryVisibility();
        }

        /** 渲染菜单树*/
        function renderMenuTree() {
            const container = document.getElementById('menu-tree');
            if (!container) return;
            container.innerHTML = '';

            if (!state.menuRoots || state.menuRoots.length === 0) {
                container.innerHTML = '<div class="menu-empty">加载中...</div>';
                return;
            }

            const geometryCache = new Map();
            const renderNode = (node, depth) => {
                const row = document.createElement('div');
                row.className = 'menu-node';
                row.style.marginLeft = `${depth * 14}px`;

                const ids = getMenuGeometryIds(node, geometryCache);
                const visibleCount = ids.filter(id => state.geometryVisibleMap.get(id) !== false).length;

                const checkbox = document.createElement('input');
                checkbox.type = 'checkbox';
                checkbox.className = 'menu-node-check';
                checkbox.disabled = ids.length === 0;
                checkbox.checked = ids.length > 0 && visibleCount === ids.length;
                checkbox.indeterminate = visibleCount > 0 && visibleCount < ids.length;
                checkbox.addEventListener('change', () => setMenuChecked(node, !!checkbox.checked, geometryCache));

                const labelBtn = document.createElement('button');
                labelBtn.type = 'button';
                labelBtn.className = 'menu-node-label';
                labelBtn.textContent = node.name || `菜单${node.id}`;
                labelBtn.addEventListener('click', () => {
                    if (ids.length > 0) {
                        openGeometryDetailDrawer(ids[0]);
                    }
                });

                row.appendChild(checkbox);
                row.appendChild(labelBtn);

                const isLeaf = !node.children || node.children.length === 0;
                if (isLeaf) {
                    const count = getLeafGeometryCount(node.id);
                    const badge = document.createElement('span');
                    badge.className = `menu-node-count ${count > 0 ? '' : 'empty'}`;
                    badge.textContent = `${count}`;
                    row.appendChild(badge);
                }

                container.appendChild(row);

                (node.children || []).forEach(child => renderNode(child, depth + 1));
            };

            state.menuRoots.forEach(node => renderNode(node, 0));
        }

        /** 加载菜单数据*/
        async function loadMenus() {
            try {
                const resp = await fetch('?handler=MenuData');
                const res = await resp.json();
                if (res.code !== 0 || !Array.isArray(res.data)) return;

                const flatMenus = [];
                const walk = (nodes) => {
                    (nodes || []).forEach(n => {
                        flatMenus.push({
                            id: n.id,
                            parentId: n.parentId,
                            name: n.name,
                            sortId: n.sortId
                        });
                        walk(n.children || []);
                    });
                };
                walk(res.data);

                state.menus = flatMenus;
                buildMenuNodes();
                renderMenuTree();
            } catch {
                // ignore menu loading failures
            }
        }

        //--------------------------------------------------------------
        // 图形相关
        //--------------------------------------------------------------
        /** 图形可见性*/
        function applyGeometryVisibility() {
            if (!geometryLayerManager) return;
            geometryLayerManager.setVisible(true);

            const visibleIds = state.geometries
                .filter(g => state.geometryVisibleMap.get(g.id) !== false)
                .map(g => g.id);
            geometryLayerManager.setVisibleIds(visibleIds);
            renderMenuTree();
        }

        /** 关闭图形详情抽屉*/
        function closeGeometryDetailDrawer() {
            const drawer = document.getElementById('geo-detail-drawer');
            if (!drawer) return;
            drawer.classList.remove('open');
        }

        /** 渲染数据行*/
        function renderDataRows(rows) {
            if (!Array.isArray(rows) || rows.length === 0)
                return '<div class="text-xs text-slate-400 mt-2">DataJson 无数据</div>';
            const body = rows.map(r => `<tr><td>${(r.key ?? '').toString().replaceAll('<', '&lt;')}</td><td>${(r.value ?? '').toString().replaceAll('<', '&lt;')}</td></tr>`).join('');
            return `<table class="geo-data-table"><thead><tr><th>字段</th><th>值</th></tr></thead><tbody>${body}</tbody></table>`;
        }

        /** 打开图形详情抽屉*/
        async function openGeometryDetailDrawer(id) {
            const drawer = document.getElementById('geo-detail-drawer');
            const title = document.getElementById('geo-detail-title');
            const body = document.getElementById('geo-detail-body');
            const editBtn = document.getElementById('btn-geo-edit');
            if (!drawer || !title || !body || !editBtn) return;

            state.selectedGeometryId = id;
            title.textContent = '图形详情';
            body.innerHTML = '加载中...';
            editBtn.style.display = 'none';
            drawer.classList.add('open');

            try {
                const resp = await fetch(`?handler=GeometryDetail&id=${id}`);
                const res = await resp.json();
                if (res.code !== 0 || !res.data) {
                    body.textContent = res.msg || '获取图形详情失败';
                    return;
                }

                const d = res.data;
                title.textContent = d.name || `图形${d.id}`;
                body.innerHTML = `
                    <table class="geo-kv">
                        <tr><td>ID</td><td>${d.id ?? ''}</td></tr>
                        <tr><td>菜单</td><td>${d.menuName ?? '-'}</td></tr>
                        <tr><td>名称</td><td>${d.name ?? ''}</td></tr>
                        <tr><td>简称</td><td>${d.alias ?? ''}</td></tr>
                        <tr><td>经纬度</td><td>${d.gps ?? '-'}</td></tr>
                    </table>
                    <div class="text-xs text-slate-500 mt-2">DataJson</div>
                    ${renderDataRows(d.dataRows)}
                `;

                if (d.canEdit) {
                    editBtn.style.display = '';
                    editBtn.onclick = () => {
                        const manager = (window.top && window.top.EleManager) ? window.top.EleManager : window.EleManager;
                        if (!manager || typeof manager.openDrawer !== 'function') {
                            window.open(`/GIS/GeometryForm?id=${id}&md=edit`, '_blank');
                            return;
                        }
                        manager.openDrawer({
                            title: '编辑图形',
                            url: `/GIS/GeometryForm?id=${id}&md=edit`,
                            direction: 'rtl',
                            size: window.innerWidth < 768 ? '100%' : '45%',
                            resizable: true,
                            closeOnClickModal: false,
                            destroyOnClose: true
                        });
                        // 编辑抽屉保存关闭后，定时刷新地图图形。
                        setTimeout(() => loadGeometries(), 1200);
                        setTimeout(() => loadGeometries(), 4200);
                    };
                }
            } catch {
                body.textContent = '获取图形详情失败';
            }
        }

        /** 加载几何图形数据*/
        async function loadGeometries() {
            try {
                const resp = await fetch('?handler=GeometryLayerData');
                const res = await resp.json();
                if (res.code !== 0 || !Array.isArray(res.data)) return;

                state.geometries = res.data;
                state.geometryByMenuId = new Map();
                state.geometries.forEach(item => {
                    if (!state.geometryVisibleMap.has(item.id)) {
                        state.geometryVisibleMap.set(item.id, true);
                    }

                    const menuId = item.menuId;
                    if (!state.geometryByMenuId.has(menuId)) {
                        state.geometryByMenuId.set(menuId, []);
                    }
                    state.geometryByMenuId.get(menuId).push(item.id);
                });

                geometryLayerManager.setDataFromRows(state.geometries);
                geometryLayerManager.render();
                applyGeometryVisibility();
                renderMenuTree();
            } catch {
                // ignore geometry loading failures
            }
        }
    </script>
}

@page
@model App.Pages.GIS.ScenesModel
@{
    ViewData["Title"] = "GIS场景管理";
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="GIS场景" FormPage="SceneForm" EnableBatch="true">
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Width="220px" Label="名称"></EleInput>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus" Visible="@Auth.CheckPower(Power.GisGeometryEdit)">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete" Visible="@Auth.CheckPower(Power.GisGeometryDelete)">删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="180" Fixed="right" Shows="4">
                <Op Command="Edit"   Icon="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.GisSceneEdit)"></Op>
                <Op Command="Delete" Icon="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.GisSceneDelete)"></Op>
                <Op Popup="SceneMenus?sceneId={id}&objectName={name}" Icon="Files" Text="点位" Visible="@Auth.CheckPower(Power.GisSceneEdit)"></Op>
                <Op Popup="ScenePanels?sceneId={id}&name={name}" Icon="Paperclip" Text="面板" Visible="@Auth.CheckPower(Power.GisSceneEdit)"></Op>
            </EleOpColumn>
            <EleIconColumn For="Item.Icon" Label="图标" Width="80"></EleIconColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="150" Sortable="true"></EleColumn>
            <EleColumn For="Item.SortId" Label="排序" Width="100" Sortable="true"></EleColumn>
            <EleColumn For="Item.Desc" Label="描述" MinWidth="200"></EleColumn>
            <EleColumn For="Item.MapZoom" Label="缩放" Width="80"></EleColumn>
            <EleColumn For="Item.MapCenter" Label="中心点" Width="180"></EleColumn>
            <EleColumn For="Item.MapPitch" Label="倾斜" Width="80"></EleColumn>
            <EleColumn For="Item.MapStyle" Label="地图样式"></EleColumn>
            <EleColumn For="Item.MapProjection" Label="地图投影" Width="110" Format="Enum"></EleColumn>
            <EleColumn For="Item.Map3D" Label="启用3D"></EleColumn>
            <EleColumn For="Item.AutoRotate" Label="自动旋转"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="160" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

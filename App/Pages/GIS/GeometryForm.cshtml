@page
@model App.Pages.GIS.GeometryFormModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "GIS几何图形信息";
    var currentId = Request.Query["id"].ToString();
    var selectedId = Request.Query["menuId"].ToString();
    if (selectedId.IsEmpty())
        selectedId = Request.Query["selectId"].ToString();
    var menuTreeTs = DateTime.Now.Ticks;
    var editMode = (Model.Mode != PageMode.View).ToString().ToLower();
}

@section head {
    <style>
        /* GeoJSON 文本可能很长，保持单行省略，避免撑出输入框 */
        .geojson-selector .el-input__inner {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .json-kv-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
            font-size: 13px;
        }
        .json-kv-table th,
        .json-kv-table td {
            border: 1px solid #ebeef5;
            padding: 6px 8px;
            vertical-align: top;
            word-break: break-all;
        }
        .json-kv-table th {
            width: 180px;
            background: #f8fafc;
            color: #475569;
            font-weight: 600; 
        }
    </style>
}

@section body {
    <EleForm Model="form" LabelWidth="120px">
        <EleInput For="Item.Id" Label="ID" Enabled="false"></EleInput>
        <EleInput For="Item.Name" Label="名称" Required="true"></EleInput>
        <EleInput For="Item.Alias" Label="简称"></EleInput>
        <EleNumber For="Item.SortId" Label="排序" Min="0" Max="100000"></EleNumber>
        <EleTreeSelect For="Item.MenuId" Label="所属菜单" Api="/httpapi/gis/GetMenuTree?selectedId=@selectedId&_ts=@menuTreeTs" Clearable="true" CheckStrictly="true"></EleTreeSelect>
        <EleTreeSelect For="Item.OrgId" Label="责任组织" Api="/httpapi/orgs/GetAuthOrgTree"  ></EleTreeSelect>
        <EleSelector For="Item.GPS" TextFor="Item.GPS" Label="定位" PopupUrl="Locator" Icon="Location"></EleSelector>
        <EleInput For="Item.CreatorName" Label="编辑者" Enabled="false"></EleInput>
        <EleSelector For="Item.GeoJson" TextFor="Item.GeoJson" Label="图形数据" Class="geojson-selector" PopupUrl="GeometryEditor" KeyMode="Storage" Icon="Location" Rows="12" Editable="true" FillRow="true"></EleSelector>
        <EleSelector For="Item.DataJson" TextFor="Item.DataJson" Label="属性数据" Class="geojson-selector" PopupUrl="PropsEditor" KeyMode="Storage" Icon="Edit" Rows="12" Editable="true" FillRow="true"></EleSelector>
        <Bottom>
            <EleButton Type="Primary" Command="SaveClose" Visible="@(Model.Mode != PageMode.View)">保存</EleButton>
            <EleButton Id="btn-open-edit" Type="Primary" Visible="@(Model.Mode == PageMode.View && Auth.CheckPower(Power.GisGeometryEdit))">编辑</EleButton>
            <EleButton Command="Close">关闭</EleButton>
        </Bottom>
    </EleForm>
}

@section script {
    <script>
        (() => {
            const isEditMode = @editMode;
            const id = '@currentId';

            function parseDataJsonTable() {
                if (isEditMode) return;
                const wrap = document.getElementById('datajson-table-wrap');
                if (!wrap) return;

                const textarea = document.querySelector('textarea[name="item.dataJson"], textarea[name="Item.DataJson"], #item_dataJson, #Item_DataJson');
                const text = (textarea && textarea.value ? textarea.value : '').trim();
                if (!text) {
                    wrap.textContent = '暂无数据';
                    return;
                }

                let obj;
                try {
                    obj = JSON.parse(text);
                } catch {
                    wrap.innerHTML = `<table class="json-kv-table"><tr><th>raw</th><td>${text.replaceAll('<', '&lt;')}</td></tr></table>`;
                    return;
                }

                let rows = [];
                if (Array.isArray(obj)) {
                    rows = obj.map((v, i) => ({ key: `[${i}]`, value: typeof v === 'string' ? v : JSON.stringify(v) }));
                } else if (obj && typeof obj === 'object') {
                    rows = Object.keys(obj).map(k => ({ key: k, value: typeof obj[k] === 'string' ? obj[k] : JSON.stringify(obj[k]) }));
                } else {
                    rows = [{ key: 'value', value: String(obj) }];
                }

                const html = rows.map(r => `<tr><th>${String(r.key).replaceAll('<', '&lt;')}</th><td>${String(r.value).replaceAll('<', '&lt;')}</td></tr>`).join('');
                wrap.innerHTML = `<table class="json-kv-table">${html}</table>`;
            }

            function bindEditButton() {
                if (isEditMode) return;
                const btn = document.getElementById('btn-open-edit');
                if (!btn || !id) return;

                btn.addEventListener('click', () => {
                    const manager = (window.top && window.top.EleManager) ? window.top.EleManager : window.EleManager;
                    if (!manager || typeof manager.openDrawer !== 'function') {
                        window.open(`/GIS/GeometryForm?id=${id}&md=edit`, '_blank');
                        return;
                    }

                    manager.openDrawer({
                        title: '编辑图形',
                        url: `/GIS/GeometryForm?id=${id}&md=edit`,
                        direction: 'rtl',
                        size: window.innerWidth < 768 ? '100%' : '45%',
                        resizable: true,
                        closeOnClickModal: false,
                        destroyOnClose: true
                    });
                });
            }

            setTimeout(parseDataJsonTable, 200);
            bindEditButton();
        })();
    </script>
}

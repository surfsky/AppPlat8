@page
@model App.Pages.GIS.GeometryFormModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "点位信息";
    var currentId = Request.Query["id"].ToString();
    var selectedId = Request.Query["GisMenuId"].ToString();
    if (selectedId.IsEmpty())
        selectedId = Request.Query["menuId"].ToString();
    if (selectedId.IsEmpty())
        selectedId = Request.Query["selectId"].ToString();
    var menuTreeTs = DateTime.Now.Ticks;
    var editMode = (Model.Mode != PageMode.View).ToString().ToLower();
}

@section head {
    <style>
        html,
        body {
            height: 100%;
        }

        /* GeoJSON 文本可能很长，保持单行省略，避免撑出输入框 */
        .geojson-picker .el-input__inner {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .json-kv-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
            font-size: 13px;
        }
        .json-kv-table th,
        .json-kv-table td {
            border: 1px solid #ebeef5;
            padding: 6px 8px;
            vertical-align: top;
            word-break: break-all;
        }
        .json-kv-table th {
            width: 180px;
            background: #f8fafc;
            color: #475569;
            font-weight: 600; 
        }

        .geo-form-drawer {
            height: 100vh;
            overflow: hidden;
        }

        .geo-form-drawer #app {
            height: 100vh !important;
            overflow-y: auto !important;
            overflow-x: hidden;
            -webkit-overflow-scrolling: touch;
        }

        /* 点位抽屉使用紧凑底栏，减少底部占用高度 */
        .geo-form-drawer #app > div {
            padding-bottom: 52px;
        }
        .geo-form-drawer #app > div > div.fixed.bottom-0 {
            padding-top: 4px;
            padding-bottom: 4px;
        }
        .geo-form-drawer [data-ele-bottom='true'] {
            min-height: 36px !important;
            gap: 6px !important;
        }

        /* 条件显隐仅负责开关，不参与表单栅格布局，避免破坏 FillRow */
        .geo-field-toggle {
            display: contents;
        }
    </style>
}

@section body {
    <div class="geo-form-drawer">
        <EleForm Model="form" LabelWidth="120px">
            <EleInput For="Item.Id" Label="ID" Enabled="false"></EleInput>
            <EleInput For="Item.CreatorName" Label="编辑者" Enabled="false"></EleInput>
            <EleTreeSelect For="Item.MenuId" Label="所属菜单" Api="/httpapi/gis/GetMenuTree?selectedId=@selectedId&_ts=@menuTreeTs" Clearable="true" CheckStrictly="true"></EleTreeSelect>
            <EleSelect For="Item.Type" Label="类型" Clearable="true" ></EleSelect>
            <EleInput For="Item.Name" Label="名称" Required="true"></EleInput>
            <EleInput For="Item.Alias" Label="别称"></EleInput>
            <EleNumber For="Item.SortId" Label="排序" Min="0" Max="100000"></EleNumber>
            <EleInput For="Item.Url" Label="链接" FillRow="false" Placeholder="例如 /Checks/CheckObjects?orgId={{id}}"></EleInput>
            <EleInput For="Item.Addr" Label="地址" FillRow="true"></EleInput>
            <ElePicker For="Item.DataJson" TextFor="Item.DataJson" Label="属性" Class="geojson-picker" PopupUrl="PropsEditor" KeyMode="Storage" Icon="Edit" Rows="4" Editable="true" FillRow="true"></ElePicker>

            <EleLabel Label="更多" FillRow="true"></EleLabel>
            <div class="geo-field-toggle" v-show="!form.type || ['1','点','point','3','文字','text','5','监控','video','6','文件','file'].includes((form.type ?? '').toString().toLowerCase())">
                <ElePicker For="Item.Gps" TextFor="Item.Gps" Label="定位" PopupUrl="Locator" Icon="Location" Editable="true"></ElePicker>
            </div>

            <div class="geo-field-toggle" v-show="['4','图片','image','6','文件','file'].includes((form.type ?? '').toString().toLowerCase())">
                <EleFileUpload For="Item.File" Label="文件" FillRow="true" Placeholder="请选择附件文件" Exts=".jpg,.jpeg,.png,.gif,.webp,.mp4,.mov,.avi,.mkv,.obj,.fbx,.gltf,.glb,.zip,.rar,.7z,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt" MaxSizeMb="80" ViewerUrl="/Shared/FileViews/Viewer?src={0}"></EleFileUpload>
            </div>
            <div class="geo-field-toggle" v-show="['4','图片','image'].includes((form.type ?? '').toString().toLowerCase())">
                <ElePicker For="Item.Region" TextFor="Item.Region" Label="图片区域" PopupUrl="MapImage" KeyMode="Url" Icon="Location" Editable="true" FillRow="true"></ElePicker>
            </div>
            <div class="geo-field-toggle" v-show="['2','形状','shape'].includes((form.type ?? '').toString().toLowerCase())">
                <ElePicker For="Item.GeoJson" TextFor="Item.GeoJson" Label="形状数据" Class="geojson-picker" PopupUrl="GeometryEditor" KeyMode="Storage" Icon="Location" Rows="12" Editable="true" FillRow="true"></ElePicker>
            </div>
            <EleList Label="更多附件" FillRow="true" DataHandler="?handler=AttData&id=@currentId" PageSize="8" SortField="Id" SortDirection="DESC" Height="180px" EmptyText="暂无附件" ScrollClass="flex-1 overflow-auto px-0" ItemsClass="space-y-1 pb-1" ItemClass="py-2 px-0 border-b border-gray-100 rounded-none bg-transparent shadow-none">
                <ItemTemplate>
                    <div class="flex items-center justify-between gap-3">
                        <div class="min-w-0 flex-1">
                            <div class="text-sm text-gray-800 truncate">{{ item.name }}</div>
                            <div class="text-xs text-gray-500 truncate">{{ item.sizeText || item.createDtText || '' }}</div>
                        </div>
                        <a href="javascript:void(0)" class="text-xs text-blue-600" v-on:click.prevent="openLinkInDrawer(item.previewUrl, '附件预览', null)">预览</a>
                    </div>
                </ItemTemplate>
            </EleList>
            <EleButton Type="Primary" Look="Text" Icon="Document" Handler="ShowFiles" EnabledFor="Item.Id">管理附件</EleButton>
            <Bottom>
                <EleButton Type="Primary" Command="SaveClose" Visible="@(Model.Mode != PageMode.View)">保存</EleButton>
                <EleButton Command="Close">关闭</EleButton>
            </Bottom>
        </EleForm>
    </div>
}


@page
@model App.Pages.GIS.GeometryFormModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "GIS几何图形信息";
    var currentId = Request.Query["id"].ToString();
    var selectedId = Request.Query["GisMenuId"].ToString();
    if (selectedId.IsEmpty())
        selectedId = Request.Query["menuId"].ToString();
    if (selectedId.IsEmpty())
        selectedId = Request.Query["selectId"].ToString();
    var menuTreeTs = DateTime.Now.Ticks;
    var editMode = (Model.Mode != PageMode.View).ToString().ToLower();
}

@section head {
    <style>
        /* GeoJSON 文本可能很长，保持单行省略，避免撑出输入框 */
        .geojson-selector .el-input__inner {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .json-kv-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 8px;
            font-size: 13px;
        }
        .json-kv-table th,
        .json-kv-table td {
            border: 1px solid #ebeef5;
            padding: 6px 8px;
            vertical-align: top;
            word-break: break-all;
        }
        .json-kv-table th {
            width: 180px;
            background: #f8fafc;
            color: #475569;
            font-weight: 600; 
        }
    </style>
}

@section body {
    <EleForm Model="form" LabelWidth="120px">
        <EleInput For="Item.Id" Label="ID" Enabled="false"></EleInput>
        <EleInput For="Item.Name" Label="名称" Required="true"></EleInput>
        <EleInput For="Item.Alias" Label="简称"></EleInput>
        <EleNumber For="Item.SortId" Label="排序" Min="0" Max="100000"></EleNumber>
        <EleTreeSelect For="Item.MenuId" Label="所属菜单" Api="/httpapi/gis/GetMenuTree?selectedId=@selectedId&_ts=@menuTreeTs" Clearable="true" CheckStrictly="true"></EleTreeSelect>
        <EleInput For="Item.CreatorName" Label="编辑者" Enabled="false"></EleInput>
        <EleInput For="Item.Addr" Label="地址"></EleInput>
        <EleSelector For="Item.GPS" TextFor="Item.GPS" Label="定位" PopupUrl="Locator" Icon="Location" Editable="true"></EleSelector>
        <EleSelector For="Item.GeoJson" TextFor="Item.GeoJson" Label="图形数据" Class="geojson-selector" PopupUrl="GeometryEditor" KeyMode="Storage" Icon="Location" Rows="12" Editable="true" FillRow="true"></EleSelector>
        <EleSelector For="Item.DataJson" TextFor="Item.DataJson" Label="属性数据" Class="geojson-selector" PopupUrl="PropsEditor" KeyMode="Storage" Icon="Edit" Rows="12" Editable="true" FillRow="true"></EleSelector>
        <Bottom>
            <EleButton Type="Primary" Command="SaveClose" Visible="@(Model.Mode != PageMode.View)">保存</EleButton>
            <EleButton Command="Close">关闭</EleButton>
        </Bottom>
    </EleForm>
}


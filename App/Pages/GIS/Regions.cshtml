@page
@model App.Pages.GIS.RegionsModel
@{
    ViewData["Title"] = "GIS区域管理";
}

@section body {
    <EleTable Title="GIS区域" FormPage="RegionForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Width="200px" Label="名称" ></EleInput>
                <EleInput For="Item.RegionType" Width="150px" Label="类型" ></EleInput>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.GisRegionEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.GisRegionDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="150" Sortable="true"></EleColumn>
            <EleColumn For="Item.Alias" Label="简称" Width="120"></EleColumn>
            <EleColumn For="Item.RegionType" Label="类型" Width="100"></EleColumn>
            <EleColumn For="Item.Org.Name" Label="责任组织" Width="120"></EleColumn>
            <EleColumn For="Item.Creator" Label="编辑者" Width="100"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="200" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

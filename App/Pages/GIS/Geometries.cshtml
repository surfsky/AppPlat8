@page
@model App.Pages.GIS.GeometriesModel
@{
    ViewData["Title"] = "GIS几何图形管理";
    var queryMenuId = Request.Query["menuId"].ToString();
    var menuTreeTs = DateTime.Now.Ticks;
    var mapUrl = string.IsNullOrWhiteSpace(queryMenuId)
        ? "/GIS/GeometryMap"
        : $"/GIS/GeometryMap?menuId={queryMenuId}";
    var formPageUrl = string.IsNullOrWhiteSpace(queryMenuId)
        ? "/GIS/GeometryForm"
        : $"/GIS/GeometryForm?GisMenuId={queryMenuId}";
}

@section body {
    <EleTable PageSize="@SiteConfig.Instance.PageSize" Title="点位" FormPage="@formPageUrl" EnableBatch="true" >
        <Toolbar>
            <Filters>
                <EleInput For="Item.Name" Width="200px" Label="名称" ></EleInput>
                <EleSelect For="Item.Type" Width="160px" Label="类别" Clearable="true"></EleSelect>
                <EleTreeSelect For="Item.MenuId"
                               Width="220px"
                               Label="所属菜单"
                               Api="/httpapi/gis/GetMenuTree?selectedId=@queryMenuId&_ts=@menuTreeTs"
                               data-filter-default="@queryMenuId"
                               data-filter-model="menuId"
                               Clearable="true"
                               CheckStrictly="true"></EleTreeSelect>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">删除</EleButton>
                <EleButton Type="Info" Icon="Download" VClick="openImporter">导入简单点位</EleButton>
                <EleButton Type="Success" Icon="Location" NavigateUrl="@mapUrl">地图编辑</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.GisGeometryEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.GisGeometryDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Type" Label="类型" Width="100" Sortable="true"></EleColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="150" Sortable="true"></EleColumn>
            <EleColumn For="Item.Alias" Label="简称" Width="200"></EleColumn>
            <EleColumn For="Item.MenuName" Label="所属菜单" Width="160"></EleColumn>
            <EleColumn For="Item.Addr" Label="地址" MinWidth="220"></EleColumn>
            <EleColumn For="Item.Gps" Label="经纬度" Width="180"></EleColumn>
            <EleColumn For="Item.Url" Label="网址" Width="180"></EleColumn>
            <EleColumn For="Item.File" Label="文件" Width="180"></EleColumn>
            <EleColumn For="Item.CreatorName" Label="编辑者" Width="100" ></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="100" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

@section script {
    <script>
        var userMixin = {
            methods: {
                openImporter() {
                    const manager = window.top?.EleManager || window.EleManager;
                    if (manager) {
                        manager.openDrawer({
                            title: '导入简单点位',
                            url: '/GIS/GeometryImporter',
                            size: '50%',
                            destroyOnClose: true,
                            onClosed: () => {
                                // 导入完成后刷新表格
                                if (window.table) window.table.reload();
                            }
                        });
                    } else {
                        // 如果没有管理器，尝试直接打开新窗口或备选方案
                        window.open('/GIS/GeometryImporter', '_blank');
                    }
                }
            }
        };
    </script>
}

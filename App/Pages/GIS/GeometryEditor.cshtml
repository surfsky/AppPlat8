@page
@model App.Pages.Shared.GeometryEditorModel
@using System.Globalization
@using App.DAL.GIS
@{
    Layout = "_Layout";
    var defaultScene = GisScene.GetOrCreateDefaultScene();
    var mapCenterText = (defaultScene.MapCenter ?? string.Empty).Replace("，", ",").Trim();
    var mapCenterLng = 120.6034;
    var mapCenterLat = 27.5686;
    if (!string.IsNullOrWhiteSpace(mapCenterText))
    {
        var parts = mapCenterText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length >= 2
            && double.TryParse(parts[0], NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedLng)
            && double.TryParse(parts[1], NumberStyles.Float, CultureInfo.InvariantCulture, out var parsedLat))
        {
            mapCenterLng = parsedLng;
            mapCenterLat = parsedLat;
        }
    }
    var mapZoom = (defaultScene.MapZoom ?? 0) > 0 ? defaultScene.MapZoom.Value : 11;
}

@section head {
    <script src="https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.js"></script>
    <link href="https://api.mapbox.com/mapbox-gl-js/v2.9.1/mapbox-gl.css" rel="stylesheet" />
    <script src="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-draw/v1.4.3/mapbox-gl-draw.js"></script>
    <link href="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-draw/v1.4.3/mapbox-gl-draw.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script src="/gis/maphelper.js?v=3.5"></script>
    <link rel="stylesheet" href="~/Pages/GIS/GeometryEditor.cshtml.css?v=3.5" asp-append-version="true" />
}

@section body {
    <div id="app">
        <div class="panel">
            <div class="toolbar-row">
                <div class="toolbar-tools">
                <el-tooltip placement="bottom" content="浏览/选择：拖动地图，点击选择图形，双击可编辑标签">
                    <span class="draw-tool-tip">
                        <el-button type="primary" plain  class="draw-tool-btn" :class="{ 'is-active': activeTool === 'browse' }" @@click="enterBrowseMode">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                                <path d="M4 3l7.5 17 2.1-6.3L20 11.6 4 3z"></path>
                            </svg>
                        </el-button>
                    </span>
                </el-tooltip>
                <el-tooltip placement="bottom" content="绘制点：单击地图放置点位，随后弹出标签输入">
                    <span class="draw-tool-tip">
                        <el-button type="primary" plain  class="draw-tool-btn" :class="{ 'is-active': activeTool === 'point' }" @@click="drawPoint">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="10" r="5"></circle>
                                <path d="M12 15v6"></path>
                            </svg>
                        </el-button>
                    </span>
                </el-tooltip>
                <el-tooltip placement="bottom" content="绘制折线：逐点点击绘制，双击结束后弹出标签输入">
                    <span class="draw-tool-tip">
                        <el-button type="primary" plain  class="draw-tool-btn" :class="{ 'is-active': activeTool === 'line' }" @@click="drawLine">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <polyline points="3,16 9,9 14,13 21,6"></polyline>
                                <circle cx="3" cy="16" r="1.2" fill="currentColor" stroke="none"></circle>
                                <circle cx="9" cy="9" r="1.2" fill="currentColor" stroke="none"></circle>
                                <circle cx="14" cy="13" r="1.2" fill="currentColor" stroke="none"></circle>
                                <circle cx="21" cy="6" r="1.2" fill="currentColor" stroke="none"></circle>
                            </svg>
                        </el-button>
                    </span>
                </el-tooltip>
                <el-tooltip placement="bottom" content="绘制多边形：逐点点击绘制区域，双击结束后弹出标签输入">
                    <span class="draw-tool-tip">
                        <el-button type="primary" plain class="draw-tool-btn" :class="{ 'is-active': activeTool === 'polygon' }" @@click="drawPolygon">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M4 7l7-4 9 7-6 10H6z"></path>
                            </svg>
                        </el-button>
                    </span>
                </el-tooltip>
                <el-tooltip placement="bottom" content="绘制矩形：点击第一个角点，再点击对角点完成，并弹出标签输入">
                    <span class="draw-tool-tip">
                        <el-button type="primary" plain  class="draw-tool-btn" :class="{ 'is-active': activeTool === 'rectangle' }" @@click="drawRectangle">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="4" y="6" width="16" height="12" rx="1"></rect>
                            </svg>
                        </el-button>
                    </span>
                </el-tooltip>
                <el-tooltip placement="bottom" content="绘制圆形：点击圆心，再点击半径位置完成，并弹出标签输入">
                    <span class="draw-tool-tip">
                        <el-button type="primary" plain class="draw-tool-btn" :class="{ 'is-active': activeTool === 'circle' }" @@click="drawCircle">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="7"></circle>
                                <circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"></circle>
                            </svg>
                        </el-button>
                    </span>
                </el-tooltip>
                <div class="style-control-group">
                    <div class="style-card">
                        <span class="style-card-label">框色</span>
                        <el-color-picker class="style-color-picker" v-model="strokeColor" @@change="onStrokeColorChange" :show-alpha="false"></el-color-picker>
                    </div>
                    <div class="style-card">
                        <span class="style-card-label">填色</span>
                        <el-color-picker class="style-color-picker" v-model="fillColor" @@change="onFillColorChange" :show-alpha="false"></el-color-picker>
                    </div>
                    <label class="style-card style-card-select">
                        <span class="style-card-label">框宽</span>
                        <select class="style-value-select" :value="lineWidth" @@change="onLineWidthChange($event.target.value)">
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                            <option value="6">6</option>
                            <option value="8">8</option>
                            <option value="10">10</option>
                        </select>
                    </label>
                    <span class="style-card opacity-card" @@click.stop>
                        <span class="style-card-label">透明</span>
                        <button type="button" class="style-value-btn" @@click="toggleOpacitySlider">{{ fillOpacityPercent }}%</button>
                        <div v-show="showOpacitySlider" class="opacity-slider-pop">
                            <input
                                class="number-slider-vertical"
                                type="range"
                                :value="fillOpacityPercent"
                                min="0"
                                max="100"
                                step="5"
                                @@input="onOpacitySliderInput"
                            />
                            <span class="opacity-pop-text">{{ fillOpacityPercent }}%</span>
                        </div>
                    </span>
                </div>
                </div>
                <div class="toolbar-actions">
                <el-tooltip placement="bottom" content="属性">
                    <span class="draw-tool-tip">
                        <el-button type="primary" plain circle class="toolbar-action-btn" @@click="openPropsDrawer">
                            <i class="fa-regular fa-rectangle-list"></i>
                        </el-button>
                    </span>
                </el-tooltip>
                <el-tooltip placement="bottom" content="删除选中">
                    <span class="draw-tool-tip">
                        <el-button type="warning" circle class="toolbar-action-btn" @@click="removeSelected">
                            <i class="fa-regular fa-trash-can"></i>
                        </el-button>
                    </span>
                </el-tooltip>
                <el-tooltip placement="bottom" content="保存">
                    <span class="draw-tool-tip">
                        <el-button type="primary" circle class="toolbar-action-btn" @@click="confirmGeometry">
                            <i class="fa-regular fa-floppy-disk"></i>
                        </el-button>
                    </span>
                </el-tooltip>
                </div>
            </div>
        </div>

        <div id="map"></div>

        <div v-show="menuVisible" class="map-context-menu" :style="{ left: menuX + 'px', top: menuY + 'px' }" @@click.stop>
            <div class="menu-item" @@click="undoFromMenu"><i class="fa-solid fa-rotate-left menu-icon"></i><span>撤销</span></div>
            <div class="menu-item" @@click="redoFromMenu"><i class="fa-solid fa-rotate-right menu-icon"></i><span>恢复</span></div>
            <div class="menu-item" @@click="openPropsDrawerFromMenu"><i class="fa-regular fa-rectangle-list menu-icon"></i><span>属性</span></div>
            <div class="menu-item" @@click="duplicateSelectedFromMenu"><i class="fa-regular fa-copy menu-icon"></i><span>复制</span></div>
            <div class="menu-item" @@click="setLabelFromMenu"><i class="fa-solid fa-tag menu-icon"></i><span>设置标签</span></div>
            <div class="menu-item danger" @@click="removeSelectedFromMenu"><i class="fa-regular fa-trash-can menu-icon"></i><span>删除</span></div>
        </div>

    </div>
}

@section script {
    <script>
        window.__geometryEditorConfig = {
            accessToken: "@SiteConfig.Instance.MapKey",
            initGeoJson: `@Html.Raw((Model.GeoJson ?? string.Empty).Replace("\\", "\\\\").Replace("`", "\\`").Replace("$", "\\$"))`,
            initialCenter: [@mapCenterLng.ToString(CultureInfo.InvariantCulture), @mapCenterLat.ToString(CultureInfo.InvariantCulture)],
            initialZoom: @mapZoom.ToString(CultureInfo.InvariantCulture)
        };
    </script>
    <script src="~/Pages/GIS/GeometryEditor.cshtml.js?v=3.1" asp-append-version="true"></script>
}

@page
@using App.Web
@model App.Pages.IndexModel
@{
    Layout = null; // 使用自定义布局
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <!-- 关键：锁定视口，禁止缩放 -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, shrink-to-fit=no">
    <meta name="mobile-web-app-capable" content="yes">
    <!-- 启用全屏模式（仅iOS Safari生效） -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <!-- 核心：沉浸式状态栏配置（iOS/Android通用） -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <!-- 状态栏样式（仅iOS生效） -->
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <!-- Android 沉浸式状态栏 -->
    <meta name="theme-color" content="#3B71F8">
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#3B71F8">
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#3B71F8">
    <meta name="apple-mobile-web-app-title" content="@Model.SiteTitle">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icons/icon-180.png">


    <title>@Model.SiteTitle - Home</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/element-plus/dist/index.css">
    <script src="https://cdn.jsdelivr.net/npm/vue@3/dist/vue.global.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/element-plus"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="/ui/tailwindConfig.js"></script>
    <script src="/ui/MenuTree.js?v=@DateTime.Now.Ticks"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        /* 全局核心优化：防飘、防拖动、防回弹、防横向滑动 */
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow-x: hidden;
            touch-action: pan-y; /* 只允许纵向滚动 */
            overscroll-behavior: none; /* 禁止橡皮筋效果 */
            -webkit-overflow-scrolling: touch;
            -webkit-user-drag: none;
            user-select: none;
            background: #f5f5f5;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        iframe {
            border: none;
            width: 100%;
            height: 100%;
        }

        /* Smooth animations for sidebar and transitions */
        .sidebar {
            transition: all 0.3s ease;
        }

        .main-content {
            transition: all 0.3s ease;
        }

        .nav-item {
            transition: all 0.3s ease;
        }

        .nav-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }

        .nav-item.active {
            background-color: rgba(255, 255, 255, 0.2);
        }

        /* Slide animations for header */
        @@keyframes slideDown {
            from {
                transform: translateY(-100%);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        @@keyframes slideUp {
            from {
                transform: translateY(0);
                opacity: 1;
            }
            to {
                transform: translateY(-100%);
                opacity: 0;
            }
        }

        #topHeader {
            animation: slideDown 0.3s ease-out forwards;
        }

        #topHeader.hide-mobile {
            animation: slideUp 0.3s ease-out forwards;
        }

        /* Sub-items collapse/expand animation */
        .nav-sub-items {
            transition: all 0.3s ease;
            max-height: 2000px; /* Increased to support multi-level menus */
            overflow: hidden;
        }

        /* Use 'collapsed' instead of 'hidden' to avoid conflict with Tailwind's display:none */
        .nav-sub-items.collapsed {
            max-height: 0;
            opacity: 0;
        }

        /* Sidebar overlay for mobile - fixed positioning */
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 30;
            display: none;
        }

        .sidebar-overlay.active {
            display: block;
        }

        .ai-chat-drawer .el-drawer {
            height: 100vh;
            max-height: 100vh;
        }

        .ai-chat-drawer .el-drawer__header {
            margin-bottom: 0;
            flex: 0 0 auto;
        }

        .ai-chat-drawer .el-drawer__body {
            padding: 0;
            display: flex;
            flex: 1 1 auto;
            min-height: 0;
            overflow: hidden;
        }

        .ai-chat-drawer-content {
            width: 100%;
            height: 100%;
            min-height: 0;
            overflow: hidden;
        }

        .ai-chat-drawer-frame {
            width: 100%;
            height: 100%;
            border: 0;
        }

        @@media (min-width: 768px) {
            #sidebarMobile {
                will-change: width, transform, opacity;
                transition: width 0.28s cubic-bezier(0.22, 1, 0.36, 1), transform 0.28s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.22s ease;
                transform: translateX(0);
                opacity: 1;
            }

            #sidebarMobile.sidebar-desktop-collapsed {
                transform: translateX(-14px) !important;
                opacity: 0;
            }
        }

        .sidebar-toggle-zone {
            position: relative;
            width: 12px;
            flex: 0 0 12px;
            height: 100%;
            z-index: 25;
        }

        .sidebar-toggle-btn {
            position: absolute;
            left: 50%;
            top: 50%;
            transform: translate(-50%, -50%);
            width: 18px;
            height: 28px;
            border: 0;
            border-radius: 6px;
            background: #8ec5f8;
            color: #1f4f8a;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.18s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        .sidebar-toggle-zone:hover .sidebar-toggle-btn,
        .sidebar-toggle-btn.is-visible {
            opacity: 1;
            pointer-events: auto;
        }
    </style>
</head>
<body class="bg-slate-100">
    <div id="app" class="flex flex-col h-screen overflow-hidden">
        <!-- Unified Top Header Bar - Fixed Position, Always Visible -->
        <div id="topHeader" class="fixed top-0 left-0 right-0 z-50 bg-[#3B71F8] h-16 flex items-center justify-between px-4 shadow-lg">
            <!-- Left Section -->
            <div class="flex items-center gap-2 flex-shrink-0">
                <!-- Desktop: icon + site title -->
                <div class="hidden md:flex items-center gap-4">
                    <div class="w-8 h-8 bg-white rounded-lg flex items-center justify-center">
                        <i class="fas fa-rocket text-primary-600 text-base"></i>
                    </div>
                    <div class="text-white text-xl font-bold">@Model.SiteTitle</div>
                </div>

                <!-- Mobile: back button + page title -->
                <button
                    id="backBtn"
                    class="md:hidden w-10 h-10 rounded-full hover:bg-white hover:bg-opacity-20 flex items-center justify-center transition-all text-white"
                    :class="hasHistory ? 'opacity-100 pointer-events-auto' : 'opacity-30 pointer-events-none'"
                    @@click="navigateBack"
                    title="Back">
                    <i class="fas fa-chevron-left text-lg"></i>
                </button>
                <div class="md:hidden text-white text-xl font-bold">{{ currentTitle }}</div>
            </div>


            <!-- Right Section: Toolbar Icons -->
            <div class="flex items-center gap-1 sm:gap-2 flex-shrink-0">
                <!-- AI Chat Button -->
                <button class="w-10 h-10 rounded-full hover:bg-white hover:bg-opacity-20 flex items-center justify-center transition-all text-white" title="AI Chat" @@click="openAiChatDrawer">
                    <i class="fas fa-comments text-lg"></i>
                </button>
                <!-- Menu Button - only show on mobile -->
                <button id="menuBtn" class="md:hidden w-10 h-10 rounded-full hover:bg-white hover:bg-opacity-20 flex items-center justify-center transition-all text-white" @@click="openSidebar" title="Menu">
                    <i class="fas fa-bars text-lg"></i>
                </button>
                <!-- Refresh Button -->
                <button class="w-10 h-10 rounded-full hover:bg-white hover:bg-opacity-20 flex items-center justify-center transition-all text-white" title="刷新" @@click="refreshMainContent">
                    <i class="fas fa-rotate-right text-lg"></i>
                </button>
            </div>
        </div>

        <!-- Main Container - single main content, mobile only hides sidebar -->
        <div class="flex flex-1 overflow-hidden pt-16">
            <div
                id="sidebarMobile"
                class="sidebar w-60 md:w-auto bg-[#3B71F8] fixed md:relative left-0 top-16 md:top-0 h-[calc(100vh-64px)] md:h-full z-40 md:z-auto flex flex-col overflow-y-auto overflow-x-hidden -translate-x-full md:translate-x-0 transition-transform duration-300"
                :class="{ 'sidebar-desktop-collapsed': !isMobile && desktopSidebarCollapsed }"
                :style="!isMobile ? { width: desktopSidebarCollapsed ? '0px' : (sidebarPanelSize + 'px') } : null"
            >
                <div class="flex-1 flex flex-col gap-1 pt-4 px-3">
                    <menu-tree 
                        :menu-data="mainMenuItems" 
                        default-target="contentFrame" 
                        :text-color="menuTextColor"
                        :active-key="currentPage"
                        @@navigate="handleMenuNavigate"
                    ></menu-tree>
                </div>
                <div class="flex flex-col gap-2 px-3 py-3">
                    <menu-tree 
                        :menu-data="bottomMenuItems" 
                        default-target="contentFrame" 
                        :text-color="menuTextColor"
                        :active-key="currentPage"
                        @@navigate="handleMenuNavigate"
                    ></menu-tree>
                </div>
            </div>

            <div class="sidebar-toggle-zone hidden md:block">
                <button
                    class="sidebar-toggle-btn"
                    :class="{ 'is-visible': desktopSidebarCollapsed }"
                    @@click="toggleDesktopSidebar"
                    :title="desktopSidebarCollapsed ? '显示菜单' : '隐藏菜单'"
                >
                    <i :class="desktopSidebarCollapsed ? 'fas fa-chevron-right' : 'fas fa-chevron-left'"></i>
                </button>
            </div>

            <div id="sidebarOverlay" class="sidebar-overlay md:hidden" @@click="closeSidebar"></div>

            <div class="main-content flex-1 flex flex-col bg-slate-100 overflow-hidden h-full">
                <div class="flex-1 overflow-hidden">
                    <iframe id="contentFrame" src="/me/dashboard" class="w-full h-full"></iframe>
                </div>
            </div>
        </div>

        <!-- AI Chat Drawer -->
        <el-drawer
            v-model="aiDrawerVisible"
            title="AI 助手"
            direction="rtl"
            :size="aiDrawerSize"
            :with-header="true"
            :destroy-on-close="false"
            :append-to-body="true"
            :close-on-click-modal="false"
            class="ai-chat-drawer"
        >
            <div class="ai-chat-drawer-content">
                <iframe :src="aiChatUrl" class="ai-chat-drawer-frame"></iframe>
            </div>
        </el-drawer>
    </div>

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/service-worker.js').catch(function (error) {
                    console.warn('Service Worker register failed:', error);
                });
            });
        }

        const { createApp, ref, computed, onMounted, onBeforeUnmount } = Vue;

        const app = createApp({
            components: {
                'menu-tree': MenuTree
            },
            setup() {
                const currentPage = ref('dashboard');
                const currentTitle = ref('仪表板');
                const sidebarOpen = ref(false);
                const navigationHistory = ref([]);
                const hasHistory = computed(() => navigationHistory.value.length > 0);
                const menuTextColor = ref('#cbd5e1');
                const aiDrawerVisible = ref(false);
                const aiDrawerSize = ref('50%');
                const aiChatUrl = ref('/AI/Chat');
                const isMobile = ref(window.innerWidth < 768);
                const sidebarPanelSize = ref(240);
                const desktopSidebarCollapsed = ref(false);

                try {
                    const savedWidth = parseInt(localStorage.getItem('index.sidebar.size') || '', 10);
                    if (!Number.isNaN(savedWidth) && savedWidth >= 0 && savedWidth <= 420) {
                        sidebarPanelSize.value = savedWidth;
                    }
                } catch (e) {
                    // ignore localStorage access errors
                }

                try {
                    desktopSidebarCollapsed.value = localStorage.getItem('index.sidebar.collapsed') === '1';
                } catch (e) {
                    // ignore localStorage access errors
                }

                // Generate Menu Data from Model
                const menuItems = ref([]);

                // 获取 key，用横杆分隔的小写字符串如："me-dashboard"
                const getKey = (url) => {
                    if (!url) return null;
                    return url.toLowerCase().replace(/^\.\//, '').replace(/\//g, '-').replace(/\.html?$/, '');
                };
                
                // Helper to convert C# menu structure to JS structure
                const convertMenu = (nodes) => {
                    return nodes.map(node => {
                        const item = {
                            text: node.name,
                            key: getKey(node.navigateUrl) || ('group-' + node.id),
                            icon: node.imageUrl || (node.isTreeLeaf ? "fa fa-file" : "fa fa-folder"),
                            isOpen: node.expanded,
                            fixBottom: node.fixed,
                            target: node.target,
                            url: node.navigateUrl || null,
                        };
                        if (node.children && node.children.length > 0) {
                            item.children = convertMenu(node.children);
                        }
                        return item;
                    });
                };

                // Server-side data injection
                const serverMenuData = @Html.Raw(Model.Menus.ToJson());
                if (serverMenuData) {
                    const processedMenu = convertMenu(serverMenuData);
                    menuItems.value = processedMenu;
                }

                // Filtered Lists
                const mainMenuItems = computed(() => menuItems.value.filter(i => !i.fixBottom && !i.hidden));
                const bottomMenuItems = computed(() => menuItems.value.filter(i => i.fixBottom && !i.hidden));

                // Flatten menu for easy lookup
                const pageMap = {};
                const buildPageMap = (items) => {
                    items.forEach(item => {
                        if (item.children) {
                            buildPageMap(item.children);
                        } else {
                            pageMap[item.key] = { 
                                url: item.url, 
                                text: item.text,
                                target: item.target
                            };
                        }
                    });
                };
                // Watch menuItems changes to rebuild map
                buildPageMap(menuItems.value);

                const getActiveFrame = () => {
                    return document.getElementById('contentFrame');
                };


                const navigateTo = (page, title = '', pushHistory = true, loadIframe = true) => {
                    // Rebuild map if needed (lazy way)
                    if (Object.keys(pageMap).length === 0) buildPageMap(menuItems.value);

                    const pageConfig = pageMap[page];
                    if (!pageConfig) return;

                    // Handle different targets
                    if (pageConfig.target === '_blank') {
                        if (pageConfig.url) window.open(pageConfig.url, '_blank');
                        return;
                    }
                    if (pageConfig.target === '_top') {
                        if (pageConfig.url) window.top.location.href = pageConfig.url;
                        return;
                    }

                    // Default: Show in iframe
                    if (!pageConfig.url) return;

                    if (pushHistory) navigationHistory.value.push(currentPage.value);
                    currentPage.value = page;
                    currentTitle.value = title || pageConfig.text || page;
                    
                    if (loadIframe) {
                        const iframe = getActiveFrame();
                        iframe.src = pageConfig.url;
                    }

                    // Set location hash for direct navigation
                    try { location.hash = page; } catch (e) { /* ignore */ }

                    // Close sidebar on mobile
                    closeSidebar();

                };

                const handleMenuNavigate = (item) => {
                    navigateTo(item.key, item.text, true, false);
                };

                // Helper for iframe pages to request navigation
                window.navigateToFromIframe = (page, title) => {
                    navigateTo(page, title);
                };

                // Initialize on mount
                onMounted(() => {
                    buildPageMap(menuItems.value);

                    const updateAiDrawerSize = () => {
                        aiDrawerSize.value = window.innerWidth <= 768 ? '100%' : '50%';
                    };
                    const updateDeviceState = () => {
                        const mobile = window.innerWidth < 768;
                        isMobile.value = mobile;
                        const sidebar = document.getElementById('sidebarMobile');
                        const overlay = document.getElementById('sidebarOverlay');

                        if (!mobile) {
                            if (sidebar) {
                                sidebar.classList.remove('-translate-x-full');
                                sidebar.classList.add('translate-x-0');
                            }
                            if (overlay) {
                                overlay.classList.remove('active');
                            }
                            sidebarOpen.value = false;
                        } else {
                            if (sidebar) {
                                sidebar.classList.add('-translate-x-full');
                                sidebar.classList.remove('translate-x-0');
                            }
                            if (overlay) {
                                overlay.classList.remove('active');
                            }
                            sidebarOpen.value = false;
                        }
                    };
                    updateAiDrawerSize();
                    updateDeviceState();
                    window.addEventListener('resize', updateAiDrawerSize);
                    window.addEventListener('resize', updateDeviceState);
                    
                    // Check for direct hash navigation
                    const hash = (location.hash || '').replace('#', '').trim();
                    if (hash && pageMap[hash]) {
                        navigateTo(hash, pageMap[hash].text, false);
                    } else {
                        const iframe = getActiveFrame();
                        const defaultPageConfig = pageMap['dashboard'];
                        if (iframe && defaultPageConfig && defaultPageConfig.url) {
                            iframe.src = defaultPageConfig.url;
                        }
                    }
                });

                onBeforeUnmount(() => {
                    document.body.style.cursor = '';
                    document.body.style.userSelect = '';
                });

                const navigateBack = () => {
                    if (navigationHistory.value.length > 0) {
                        const prevPage = navigationHistory.value.pop();
                        currentPage.value = prevPage;
                        currentTitle.value = pageMap[prevPage]?.text || prevPage;
                        
                        const iframe = getActiveFrame();
                        const pageConfig = pageMap[prevPage];
                        if (iframe && pageConfig) {
                            iframe.src = pageConfig.url;
                        }

                    }
                };

                const openSidebar = () => {
                    if (!isMobile.value) return;
                    sidebarOpen.value = true;
                    const sidebar = document.getElementById('sidebarMobile');
                    const overlay = document.getElementById('sidebarOverlay');
                    
                    sidebar.classList.remove('-translate-x-full');
                    sidebar.classList.add('translate-x-0');
                    overlay.classList.add('active');
                };

                const closeSidebar = () => {
                    if (!isMobile.value) return;
                    sidebarOpen.value = false;
                    const sidebar = document.getElementById('sidebarMobile');
                    const overlay = document.getElementById('sidebarOverlay');
                    sidebar.classList.add('-translate-x-full');
                    sidebar.classList.remove('translate-x-0');
                    overlay.classList.remove('active');
                };

                const toggleDesktopSidebar = () => {
                    if (isMobile.value) return;
                    desktopSidebarCollapsed.value = !desktopSidebarCollapsed.value;
                    try {
                        localStorage.setItem('index.sidebar.collapsed', desktopSidebarCollapsed.value ? '1' : '0');
                    } catch (e) {
                        // ignore localStorage access errors
                    }
                };

                const refreshMainContent = () => {
                    const iframe = getActiveFrame();
                    if (!iframe) return;

                    try {
                        if (iframe.contentWindow) {
                            iframe.contentWindow.location.reload();
                            return;
                        }
                    } catch (e) {
                        // ignore and fallback to src reset
                    }

                    const currentSrc = iframe.getAttribute('src');
                    if (currentSrc) iframe.setAttribute('src', currentSrc);
                };

                const openAiChatDrawer = () => {
                    aiChatUrl.value = '/AI/Chat?t=' + Date.now();
                    aiDrawerVisible.value = true;
                };

                const persistSidebarSize = () => {
                    try {
                        localStorage.setItem('index.sidebar.size', String(sidebarPanelSize.value));
                    } catch (e) {
                        // ignore localStorage access errors
                    }
                };

                return {
                    currentPage,
                    currentTitle,
                    hasHistory,
                    sidebarOpen,
                    menuItems,
                    mainMenuItems,
                    bottomMenuItems,
                    menuTextColor,
                    isMobile,
                    sidebarPanelSize,
                    desktopSidebarCollapsed,
                    aiDrawerVisible,
                    aiDrawerSize,
                    aiChatUrl,
                    navigateTo,
                    navigateBack,
                    handleMenuNavigate,
                    openSidebar,
                    closeSidebar,
                    toggleDesktopSidebar,
                    refreshMainContent,
                    openAiChatDrawer,
                    persistSidebarSize
                };
            }
        });

        app.use(ElementPlus);
        app.mount('#app');
    </script>
</body>
</html>

@page
@{
    Layout = "_Layout";
    ViewData["Title"] = "容器 Container";
}

@section body {
    <EleContainer id="app" MaxWidth="full" Margin="8" PaddingX="4" H="full" Overflow="AutoY">
        <Column>
            <EleLabel Label="Container 响应式容器" Size="2xl" Bold="true" FillRow="true" />
            <EleContainer class="bg-blue-50 border border-blue-200 rounded p-4">
                <p class="font-medium text-blue-700">这是一个默认容器</p>
                <p class="text-sm text-blue-600 mt-2">宽度：100%，有水平内边距，自动居中。</p>
            </EleContainer>
            <EleContainer Margin="0" PaddingX="4" class="mt-4 bg-green-50 border border-green-200 rounded p-4">
                <p class="font-medium text-green-700">响应式容器示例</p>
                <p class="text-sm text-green-600 mt-2">默认断点：md=768 / lg=992 / xl=1200 / xxl=1400，窗口宽度越大容器固定宽度越大。</p>
            </EleContainer>
        </Column>
    </EleContainer>

    <EleApp />
}

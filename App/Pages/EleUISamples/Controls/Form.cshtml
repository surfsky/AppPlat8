@page
@model App.Pages.EleUISamples.FormModel

@{
    ViewData["Title"] = "表单控件示例";
}

@section body {
    <EleForm Model="form" LabelWidth="150px">
        <!-- Toolbar 示例：若存在 Toolbar，EleFormTagHelper 会将其渲染在表单上方 -->
        <Toolbar Position="Bottom">
            <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
            <EleButton Type="Primary" Command="Save" Icon="fas fa-floppy-disk">保存</EleButton>
            <EleButton Type="Primary" Command="Close" Icon="Close">关闭</EleButton>
        </Toolbar>

        <!-- 使用 For 表达式自动提取标签（从 UIAttribute）-->
        <EleLabel For="Item.Name" Size="16px" FillRow="true"></EleLabel>
        <EleInput For="Item.Name" Append="FirstName"></EleInput>
        <EleInput For="Item.Description" Type="TextArea" Rows="4"></EleInput>

        <!-- 数字 -->
        <EleLabel For="Item.Age" Size="16px" FillRow="true"></EleLabel>
        <EleNumber For="Item.Age"></EleNumber>
        <EleNumber For="Item.Score" Precision="2" Step="0.1" Prefix="¥" Suffix="RMB" ControlPosition="right"></EleNumber>

        <!-- 其他类型 -->
        <EleLabel Label="日期/切换" Size="16px" FillRow="true"></EleLabel>
        <EleDatePicker For="Item.Birthday"></EleDatePicker>
        <EleSwitch For="Item.IsEnabled"></EleSwitch>

        <!-- 列表控件 -->
        <EleLabel Label="选择框" Size="16px" FillRow="true"></EleLabel>
        <EleRadio For="Item.Gender" Items="男, 女, 未知"></EleRadio>
        <EleRadio For="Item.Gender" Items="男, 女, 未知" IsButton="true"></EleRadio>
        <EleSelect For="Item.City" Items="Model.CityList"></EleSelect>
        <EleSelect For="Item.Types" Items="Model.TypeList" Multiple="true"></EleSelect> 
        <EleSelect For="Item.RoleIds" Items="Model.RoleList" Multiple="true"></EleSelect> 

        <!-- 树形选择 -->
        <EleLabel Label="树形选择" Size="16px" FillRow="true"></EleLabel>
        <EleTreeSelect For="Item.OrgId" Api="/httpapi/orgs/GetAuthOrgTree" Clearable="true"></EleTreeSelect>
        <EleTreeSelect For="Item.DeptId" Items="Model.DeptTree" Clearable="true"></EleTreeSelect>

        <!-- 文件上传 -->
        <EleLabel Label="文件上传" Size="16px" FillRow="true"></EleLabel>
        <EleImageUpload For="Item.Photo" ItemWidth="160" LimitWidth="1024"></EleImageUpload>
        <EleImageUpload For="Item.Photos" Multi="true" MultiLimit="5" ItemWidth="160" LimitWidth="1024"></EleImageUpload>
        <EleIconSelect For="Item.Icon" ItemWidth="64"></EleIconSelect>

        <!-- 弹出选择器 -->
        <EleLabel Label="弹出选择器" Size="16px" FillRow="true"></EleLabel>
        <EleSelector For="Item.UserId" Text="Item.UserName" Title="选择用户" Src="/Shared/UserSelector?multi=0"></EleSelector>
    </EleForm>
}

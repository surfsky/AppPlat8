@page
@model App.Pages.OA.ProjectsModel
@{
    ViewData["Title"] = "项目管理";
}

@section body {
    <EleTable Title="项目" FormPage="ProjectForm" EnableBatch="true" >
        <Toolbar>
            <EleInput For="Item.Name" Width="200px" Label="名称" LabelWidth="60px"></EleInput>
            <EleInput For="Item.PersonInCharge" Width="200px" Label="责任人" LabelWidth="80px"></EleInput>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn UPower="ProjectEdit" DPower="ProjectDelete" Width="100" Fixed="right">
                <template #more="scope">
                    <el-dropdown-item @@click="openUrl('/OA/ProjectHistories?projectId=' + scope.row.id, '项目进度')">进度历史</el-dropdown-item>
                </template>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="150" Sortable="true"></EleColumn>
            <EleColumn For="Item.Alias" Label="简称" Width="120"></EleColumn>
            <EleColumn For="Item.Org.Name" Label="组织" Width="120"></EleColumn>
            <EleColumn For="Item.PersonInCharge" Label="责任人" Width="100"></EleColumn>
            <EleColumn For="Item.DevCompany" Label="开发厂商" Width="150"></EleColumn>
            <EleColumn For="Item.Progress" Label="进度(%)" Width="100"></EleColumn>
            <EleColumn For="Item.ContractDt" Label="合同时间" Width="110" FormatString="yyyy-MM-dd"></EleColumn>
        </Columns>
    </EleTable>
}

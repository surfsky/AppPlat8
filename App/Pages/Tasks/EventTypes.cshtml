@page
@model App.Pages.OA.EventTypesModel
@{
    ViewData["Title"] = "事件类别管理";
}

@section body {
    <EleTable Title="事件类别" FormPage="EventTypeForm" EnableBatch="true" >
        <Toolbar>
            <EleInput For="Item.Name" Width="200px" Label="名称" LabelWidth="60px"></EleInput>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn UPower="EventEdit" DPower="EventDelete" Width="100" Fixed="right"></EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" MinWidth="150"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="创建时间" Width="200" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

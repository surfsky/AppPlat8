@page
@model App.Pages.OA.TaskLogsModel
@{
    ViewData["Title"] = "任务处理历史";
}

@section body {
    <EleTable Title="任务处理历史" EnableBatch="true" >
        <Toolbar>
            <Filters>
            <EleInput For="Item.Status" ></EleInput>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Handler="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.TaskEdit)"></Op>
                <Op Handler="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.TaskDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.Handler" Label="处理人" Width="120"></EleColumn>
            <EleColumn For="Item.Progress" Label="进度(%)" Width="100"></EleColumn>
            <EleColumn For="Item.Status" Label="状态" Width="100"></EleColumn>
            <EleColumn For="Item.CreateDt" Label="处理时间" Width="200" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
        </Columns>
    </EleTable>
}

@section script {
    <script>
        var originalLoad = tableMixin.methods.load;
        tableMixin.methods.load = function() {
            var urlParams = new URLSearchParams(window.location.search);
            var taskId = urlParams.get('taskId');
            this.searchParams = this.searchParams || {};
            if (taskId) {
                this.searchParams.taskId = taskId;
                this.extraParams = { taskId: taskId };
            }
            originalLoad.call(this);
        }
    </script>
}

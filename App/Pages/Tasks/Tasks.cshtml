@page
@model App.Pages.OA.TasksModel
@{
    ViewData["Title"] = "任务管理";
}

@section body {
    <EleTable Title="任务" FormPage="TaskForm" EnableBatch="true">
        <Toolbar>
            <Filters>
            <EleInput For="Item.Name" Width="200px" Label="名称" LabelWidth="60px"></EleInput>
            <EleInput For="Item.PersonInCharge" Width="200px" Label="责任人" LabelWidth="80px"></EleInput>
            </Filters>
            <div class="flex w-80">
                <EleButton Type="Primary" Command="Search" Icon="Search">查询</EleButton>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </div>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn UPower="TaskEdit" DPower="TaskDelete" Width="100" Fixed="right">
                <template #more="scope">
                    <el-dropdown-item @@click="openUrl('/OA/TaskHistories?taskId=' + scope.row.id, '处理历史')">处理历史</el-dropdown-item>
                </template>
            </EleOpColumn>
            <EleColumn For="Item.Name" Label="名称" Link="true" MinWidth="150" Sortable="true"></EleColumn>
            <EleColumn For="Item.Initiator" Label="发起人" Width="100"></EleColumn>
            <EleColumn For="Item.PersonInCharge" Label="责任人" Width="100"></EleColumn>
            <EleColumn For="Item.Org.Name" Label="责任组织" Width="120"></EleColumn>
            <EleColumn For="Item.Cycle" Label="提交周期" Width="100"></EleColumn>
            <EleColumn For="Item.Progress" Label="进度(%)" Width="100"></EleColumn>
            <EleColumn For="Item.Status" Label="状态" Width="100"></EleColumn>
            <EleColumn For="Item.NextReportDt" Label="下次填报" Width="110" FormatString="yyyy-MM-dd"></EleColumn>
        </Columns>
    </EleTable>
}

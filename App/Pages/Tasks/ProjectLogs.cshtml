@page
@model App.Pages.OA.ProjectLogsModel
@{
    ViewData["Title"] = "项目进度历史";
}

@section body {
    <EleTable Title="项目进度历史" FormPage="ProjectLogForm" EnableBatch="true" >
        <Toolbar>
            <Filters>
                <EleInput For="Item.Project.Name" Width="250px" Label="项目" ></EleInput>
            </Filters>
            <Buttons>
                <EleButton Type="Primary" Command="Add" Icon="Plus">新增</EleButton>
                <EleButton Type="Danger" Command="BatchDelete" Icon="Delete">批量删除</EleButton>
            </Buttons>
        </Toolbar>
        <Columns>
            <EleNumColumn></EleNumColumn>
            <EleOpColumn Width="100" Fixed="right">
                <Op Command="Edit" Tooltip="编辑" Visible="@Auth.CheckPower(Power.ProjectEdit)"></Op>
                <Op Command="Delete" Tooltip="删除" Visible="@Auth.CheckPower(Power.ProjectDelete)"></Op>
            </EleOpColumn>
            <EleColumn For="Item.LogDt" Label="时间" Width="200" FormatString="yyyy-MM-dd HH:mm"></EleColumn>
            <EleColumn For="Item.Person" Label="人员" Width="120"></EleColumn>
            <EleColumn For="Item.Status" Label="状态" Width="100"></EleColumn>
            <EleColumn For="Item.Progress" Label="进度(%)" Width="100"></EleColumn>
            <EleColumn For="Item.Description" Label="说明" MinWidth="200"></EleColumn>
        </Columns>
    </EleTable>
}

@section script {
    <script>
        // Override default load to include projectId
        var originalLoad = tableMixin.methods.load;
        tableMixin.methods.load = function() {
            var urlParams = new URLSearchParams(window.location.search);
            var projectId = urlParams.get('projectId');
            this.searchParams = this.searchParams || {};
            if (projectId) {
                this.searchParams.projectId = projectId;
                this.extraParams = { projectId: projectId }; // Pass to Edit Form
            }
            originalLoad.call(this);
        }
    </script>
}

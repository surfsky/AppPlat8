@page
@model App.Pages.DashboardModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - @Model.SiteTitle</title>
    <script src="/js/echarts.min.js"></script>
    <script src="/gis/gis-chart-helper.js"></script>
    <style>
        :root {
            --bg: #f3f6fb;
            --card-bg: #ffffff;
            --line: #dbe6f3;
            --text: #1e293b;
            --subtext: #64748b;
            --brand: #0ea5e9;
        }
        html, body { margin: 0; padding: 0; background: var(--bg); color: var(--text); font-family: "PingFang SC", "Microsoft YaHei", sans-serif; }
        .wrap { max-width: 1680px; margin: 0 auto; padding: 20px; }
        .header { display: flex; align-items: end; justify-content: space-between; margin-bottom: 16px; }
        .title { font-size: 30px; font-weight: 700; letter-spacing: .02em; }
        .sub { color: var(--subtext); font-size: 14px; }
        .grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(320px, 1fr));
            gap: 14px;
        }
        .card {
            background: var(--card-bg);
            border: 1px solid var(--line);
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(15, 23, 42, 0.06);
            min-height: 260px;
            display: flex;
            flex-direction: column;
        }
        .card-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 14px 10px;
            border-bottom: 1px solid var(--line);
        }
        .card-title {
            margin: 0;
            font-size: 18px;
            color: #0f172a;
            font-weight: 700;
        }
        .card-info { color: #64748b; font-size: 12px; }
        .card-body {
            flex: 1;
            min-height: 190px;
            padding: 10px 12px 12px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .chart-box {
            width: 100%;
            min-height: 170px;
            height: 190px;
        }
        .content-html {
            color: #334155;
            font-size: 13px;
            line-height: 1.6;
            word-break: break-word;
        }
        .empty {
            border: 1px dashed #cbd5e1;
            border-radius: 10px;
            background: rgba(255,255,255,0.7);
            color: #94a3b8;
            padding: 18px;
            text-align: center;
        }
        @@media (max-width: 1200px) {
            .grid { grid-template-columns: repeat(2, minmax(280px, 1fr)); }
        }
        @@media (max-width: 768px) {
            .wrap { padding: 12px; }
            .title { font-size: 24px; }
            .grid { grid-template-columns: 1fr; gap: 10px; }
        }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="header">
            <div>
                <div class="title">欢迎来到 @Model.SiteTitle</div>
                <div class="sub">运营看板（Light Theme）</div>
            </div>
        </div>

        <div id="dashboard-panels" class="grid"></div>
    </div>

    <script>
        (function () {
            const container = document.getElementById('dashboard-panels');
            if (!container) return;
            const pageTheme = (() => {
                try {
                    const t = new URLSearchParams(window.location.search || '').get('theme');
                    return (t || 'light').toLowerCase() === 'dark' ? 'dark' : 'light';
                } catch {
                    return 'light';
                }
            })();

            const escapeHtml = (text) => String(text || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/\"/g, '&quot;')
                .replace(/'/g, '&#39;');

            function createCard(item) {
                const card = document.createElement('section');
                card.className = 'card';
                const title = item.title || item.Title || '未命名面板';
                const info = item.info || item.Info || '';
                const content = item.content || item.Content || '';
                const hasChart = !!(item.chartJson || item.ChartJson);

                card.innerHTML = `
                    <div class="card-head">
                        <h3 class="card-title">${escapeHtml(title)}</h3>
                        <span class="card-info">${escapeHtml(info)}</span>
                    </div>
                    <div class="card-body">
                        ${hasChart ? `<div class="chart-box" data-panel-id="${item.id || item.Id}"></div>` : ''}
                        ${content ? `<div class="content-html">${content}</div>` : ''}
                    </div>
                `;
                return card;
            }

            async function render() {
                try {
                    const resp = await fetch(`?handler=PanelData&theme=${encodeURIComponent(pageTheme)}`);
                    if (!resp.ok) {
                        container.innerHTML = '<div class="empty">面板数据加载失败</div>';
                        return;
                    }
                    const res = await resp.json();
                    const code = res?.code ?? res?.Code ?? -1;
                    const data = res?.data ?? res?.Data;
                    const list = code === 0 && Array.isArray(data) ? data : [];
                    if (list.length === 0) {
                        container.innerHTML = '<div class="empty">暂无可展示的Dashboard面板</div>';
                        return;
                    }

                    const sorted = list.slice().sort((a, b) => (a.position || a.Position || 0) - (b.position || b.Position || 0));
                    container.innerHTML = '';
                    sorted.forEach(item => container.appendChild(createCard(item)));

                    const chartEls = container.querySelectorAll('.chart-box[data-panel-id]');
                    for (let i = 0; i < chartEls.length; i += 1) {
                        const el = chartEls[i];
                        const panelId = Number(el.getAttribute('data-panel-id'));
                        const item = sorted.find(t => Number(t.id || t.Id) === panelId);
                        if (!item || !window.GisChartHelper) continue;
                        await window.GisChartHelper.renderChart(el, item.chartJson || item.ChartJson, pageTheme);
                    }
                } catch {
                    container.innerHTML = '<div class="empty">面板数据加载失败</div>';
                }
            }

            render();
            window.addEventListener('resize', () => {
                const chartEls = container.querySelectorAll('.chart-box[data-panel-id]');
                chartEls.forEach(el => {
                    if (el.__chartInstance && typeof el.__chartInstance.resize === 'function') {
                        el.__chartInstance.resize();
                    }
                });
            });
        })();
    </script>
</body>
</html>

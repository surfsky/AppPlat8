@page
@model App.Pages.DashboardModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - @Model.SiteTitle</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
    </style>
</head>
<body class="bg-slate-50">
    <div class="min-h-screen p-8">
        <div class="max-w-7xl mx-auto">
            <!-- Header -->
            <div class="mb-8">
                <h1 class="text-4xl font-bold text-slate-900 mb-2">欢迎来到 @Model.SiteTitle</h1>
                <p class="text-slate-600">Dashboard</p>
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-purple-500">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-sm">总用户数</p>
                            <p class="text-3xl font-bold text-slate-900 mt-2">1,234</p>
                        </div>
                        <i class="fas fa-users text-4xl text-purple-100"></i>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-blue-500">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-sm">活跃用户</p>
                            <p class="text-3xl font-bold text-slate-900 mt-2">856</p>
                        </div>
                        <i class="fas fa-user-check text-4xl text-blue-100"></i>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-green-500">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-sm">数据条数</p>
                            <p class="text-3xl font-bold text-slate-900 mt-2">12,345</p>
                        </div>
                        <i class="fas fa-database text-4xl text-green-100"></i>
                    </div>
                </div>

                <div class="bg-white rounded-lg shadow p-6 border-l-4 border-orange-500">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-slate-500 text-sm">今日操作</p>
                            <p class="text-3xl font-bold text-slate-900 mt-2">567</p>
                        </div>
                        <i class="fas fa-chart-line text-4xl text-orange-100"></i>
                    </div>
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-xl font-bold text-slate-900 mb-4">最近活动</h2>
                <div class="space-y-4">
                    <div class="flex items-center py-3 border-b border-slate-200">
                        <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center mr-4">
                            <i class="fas fa-user-plus text-purple-600"></i>
                        </div>
                        <div class="flex-1">
                            <p class="text-slate-900 font-medium">新用户注册</p>
                            <p class="text-slate-500 text-sm">张三注册了新账户</p>
                        </div>
                        <p class="text-slate-400 text-sm">2 小时前</p>
                    </div>

                    <div class="flex items-center py-3 border-b border-slate-200">
                        <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center mr-4">
                            <i class="fas fa-file-alt text-blue-600"></i>
                        </div>
                        <div class="flex-1">
                            <p class="text-slate-900 font-medium">提交数据</p>
                            <p class="text-slate-500 text-sm">李四提交了新数据</p>
                        </div>
                        <p class="text-slate-400 text-sm">4 小时前</p>
                    </div>

                    <div class="flex items-center py-3">
                        <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center mr-4">
                            <i class="fas fa-check-circle text-green-600"></i>
                        </div>
                        <div class="flex-1">
                            <p class="text-slate-900 font-medium">任务完成</p>
                            <p class="text-slate-500 text-sm">王五完成了系统维护</p>
                        </div>
                        <p class="text-slate-400 text-sm">6 小时前</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

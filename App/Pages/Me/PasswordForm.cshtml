@page
@model App.Pages.Me.PasswordFormModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "修改密码";
}

@section body {
    <EleForm LabelWidth="100px">
        <EleInput For="Item.OldPassword" Label="旧密码" Type="Password" Required="true" ShowPassword="true"></EleInput>
        <EleInput For="Item.NewPassword" Label="新密码" Type="Password" Required="true" ShowPassword="true"></EleInput>
        <EleInput For="Item.ConfirmPassword" Label="确认密码" Type="Password" Required="true" ShowPassword="true"></EleInput>
    </EleForm>
}
